@startuml sie-graph-analytics-uc-v1

' ============================================================
' VISUAL THEME
' ============================================================

left to right direction
skinparam shadowing false
skinparam roundcorner 12
skinparam ArrowColor #57606A
skinparam DefaultFontName "SansSerif"
skinparam backgroundColor #FFFFFF

skinparam actorBackgroundColor #FFFFFF
skinparam actorBorderColor #57606A

skinparam usecaseBackgroundColor #F6F8FA
skinparam usecaseBorderColor #57606A

skinparam rectangleBackgroundColor #FFFFFF
skinparam rectangleBorderColor #57606A

skinparam noteBackgroundColor #FFF8C5
skinparam noteBorderColor #57606A

' ============================================================

title UC - SIE Graph Analytics - v1

note as FeasibilityNote
  **SAFe mapping:** Epic E-2 Operational Drift & Blast-Radius Intelligence
  Capability: Graph Analytics
  Feature: Graph Analytics

  **Plane ownership:** Description plane (structural sensing/computation);
  feeds Systemic Reasoning and Coherence governance.

  **Requires capabilities:** Graph Reasoning, Evidence+State substrate,
  Versioning+Provenance (graph snapshots), Security+Access.

  **Hard dependencies:** graph DB, visualization engine (rendering outside SIE),
  simulation engine.

  **Feasibility tier:** NOW
  (core traversal + coupling metrics are straightforward once graph exists).
end note

' ============================================================
' ACTORS
' ============================================================

actor "System Architect" as Architect
actor "Change Manager" as ChangeMgr
actor "Performance Engineer" as PerfEng
actor "Capacity Planner" as CapPlanner
actor "Risk Manager" as RiskMgr

actor "Graph Database" as GraphDB <<system>>
actor "Visualization Engine" as VizEngine <<system>>
actor "Simulation Engine" as SimEngine <<system>>
actor "Metrics Store" as MetricsStore <<system>>

' ============================================================
' USE CASES
' ============================================================

rectangle "Graph Analytics" {

  ' --- Impact Visualization ---
  package "Impact Visualization" {
    usecase "Render Dependency\nGraphs with Highlights" as UC_RenderGraphs
    usecase "Show Propagation\nPaths" as UC_PropagationPaths
    usecase "Support Interactive\nExploration" as UC_InteractiveExplore
    usecase "Generate Impact\nSummary Diagrams" as UC_ImpactDiagrams
  }

  ' --- What-If Analysis ---
  package "What-If Analysis" {
    usecase "Evaluate Constraints\non Hypothetical State" as UC_HypotheticalState
    usecase "Compare Current vs\nProposed Outcomes" as UC_CompareOutcomes
    usecase "Identify Unintended\nConsequences" as UC_UnintendedConsequences
    usecase "Support Change\nApproval Workflow" as UC_ChangeApproval
  }

  ' --- Bottleneck Detection ---
  package "Bottleneck Detection" {
    usecase "Detect Governance\nBottlenecks" as UC_GovBottlenecks
    usecase "Identify Performance\nBottlenecks" as UC_PerfBottlenecks
    usecase "Flag Approval Process\nBottlenecks" as UC_ApprovalBottlenecks
    usecase "Recommend Bottleneck\nRelief" as UC_BottleneckRelief
  }

  ' --- Coupling Metrics ---
  package "Coupling Metrics" {
    usecase "Calculate Afferent\nand Efferent Coupling" as UC_CalculateCoupling
    usecase "Identify Highly\nCoupled Components" as UC_HighlyCoupled
    usecase "Track Coupling\nTrends" as UC_CouplingTrends
    usecase "Recommend Decoupling\nStrategies" as UC_DecouplingStrategies
  }

  ' --- Critical Path Analysis ---
  package "Critical Path Analysis" {
    usecase "Determine Constraint\nEvaluation Critical Path" as UC_EvalCriticalPath
    usecase "Identify Single Points\nof Governance Failure" as UC_GovSPOF
    usecase "Map Critical Business\nCapability Paths" as UC_BusinessCapPaths
    usecase "Prioritize Resilience\nInvestments" as UC_ResilienceInvest
  }
}

' ============================================================
' RELATIONSHIPS - Actors to Use Cases
' ============================================================

' Architect interactions
Architect --> UC_RenderGraphs
Architect --> UC_PropagationPaths
Architect --> UC_CalculateCoupling
Architect --> UC_HighlyCoupled
Architect --> UC_DecouplingStrategies

' Change Manager interactions
ChangeMgr --> UC_HypotheticalState
ChangeMgr --> UC_CompareOutcomes
ChangeMgr --> UC_UnintendedConsequences
ChangeMgr --> UC_ChangeApproval
ChangeMgr --> UC_ImpactDiagrams

' Performance Engineer interactions
PerfEng --> UC_PerfBottlenecks
PerfEng --> UC_EvalCriticalPath
PerfEng --> UC_CouplingTrends
PerfEng --> UC_BottleneckRelief

' Capacity Planner interactions
CapPlanner --> UC_InteractiveExplore
CapPlanner --> UC_GovBottlenecks
CapPlanner --> UC_BusinessCapPaths
CapPlanner --> UC_ResilienceInvest

' Risk Manager interactions
RiskMgr --> UC_GovSPOF
RiskMgr --> UC_ApprovalBottlenecks
RiskMgr --> UC_UnintendedConsequences
RiskMgr --> UC_ResilienceInvest

' ============================================================
' RELATIONSHIPS - System Actors
' ============================================================

UC_RenderGraphs --> VizEngine
UC_PropagationPaths --> GraphDB
UC_InteractiveExplore --> VizEngine
UC_ImpactDiagrams --> VizEngine

UC_HypotheticalState --> SimEngine
UC_CompareOutcomes --> SimEngine
UC_UnintendedConsequences --> SimEngine
UC_ChangeApproval --> SimEngine

UC_GovBottlenecks --> GraphDB
UC_PerfBottlenecks --> MetricsStore
UC_ApprovalBottlenecks --> MetricsStore
UC_BottleneckRelief --> GraphDB

UC_CalculateCoupling --> GraphDB
UC_HighlyCoupled --> GraphDB
UC_CouplingTrends --> MetricsStore
UC_DecouplingStrategies --> GraphDB

UC_EvalCriticalPath --> GraphDB
UC_GovSPOF --> GraphDB
UC_BusinessCapPaths --> GraphDB
UC_ResilienceInvest --> GraphDB

' ============================================================
' RELATIONSHIPS - Include/Extend
' ============================================================

UC_RenderGraphs ..> UC_PropagationPaths : <<include>>
UC_HypotheticalState ..> UC_CompareOutcomes : <<include>>
UC_UnintendedConsequences ..> UC_HypotheticalState : <<include>>
UC_HighlyCoupled ..> UC_CalculateCoupling : <<include>>
UC_GovSPOF ..> UC_EvalCriticalPath : <<include>>

' ============================================================
' NOTES
' ============================================================

note right of UC_RenderGraphs
  **Dependency Graph Visualization:**
  
  [Payment Service]
       ↓
  [Auth Service] ← AFFECTED
       ↓
  [User DB] ← AFFECTED
  
  Impact: 3 components
  Severity: HIGH (auth in path)
end note

note right of UC_HypotheticalState
  **What-If Scenario:**
  
  Proposed: Upgrade Auth to v2.0
  
  Current state: 12 violations
  Proposed state: 8 violations
  New violations: 2
  Resolved: 6
  
  Recommendation: PROCEED
end note

note right of UC_CalculateCoupling
  **Coupling Metrics:**
  
  OrderService:
  - Afferent (incoming): 8
  - Efferent (outgoing): 12
  - Instability: 0.60
  
  Warning: High coupling risk
  Consider: Extract shared logic
end note

note right of UC_GovSPOF
  **Governance SPOF Detection:**
  
  PolicyEngine-Primary:
  - Evaluates: 100% of decisions
  - Failover: None configured
  - Recovery: Manual
  
  Risk: Single point of failure
  Action: Add standby instance
end note

@enduml
