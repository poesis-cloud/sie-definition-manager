@startuml sie-analytics-market-value-v1

' ============================================================
' VISUAL THEME
' ============================================================

skinparam shadowing false
skinparam linetype ortho
skinparam roundcorner 12
skinparam ArrowColor #57606A
skinparam DefaultFontName "SansSerif"
skinparam backgroundColor #FFFFFF

skinparam packageStyle rectangle
skinparam packageBackgroundColor #F6F8FA
skinparam packageBorderColor #57606A

skinparam noteBackgroundColor #FFF8C5
skinparam noteBorderColor #57606A

' ============================================================

frame "PD - SIE - Analytics Capability Market Value Prioritization - v1" {

  note as Criteria
    **Market value criteria (prioritization axis)**

    1. **Adoption gating / Trust**: required for customers to safely deploy
       (auditability, approval gates, evidence retention, access control).
    2. **Buyer urgency / Pain intensity**: tied to risk, outages, compliance,
       and high-frequency incidents.
    3. **Time-to-value**: can be valuable with minimal integrations.
    4. **Differentiation**: hard to replicate with off-the-shelf components.
    5. **Expansion leverage**: enables higher-order intelligence without breaking
       the closed-loop (Definition -> Remediation -> State -> Description).

    **Systemics mapping**
    - Highest market value concentrates around **homeostasis** (risk control) and
      **governance legitimacy** (trace + evidence + explainability).
    - “Intelligence” claims have market value only when bounded by Assurance+Safety
      and compiled into Definition-plane deliverables.
  end note

  package "P0 - Adoption Gates (sellable baseline)" as P0 {

    package "Assurance & Safety" as P0_Safety {
      note as P0_Safety_N
        Automation eligibility, approval gates, confidence thresholds,
        provenance for LLM outputs and actions.
      end note
    }

    package "Decision Intelligence" as P0_Decision {
      note as P0_Decision_N
        Decision log + audit trail + evidence preservation.
        (Compliance reporting value is highest in regulated contexts.)
      end note
    }

    package "Explanation Engine" as P0_Explain {
      note as P0_Explain_N
        Deterministic traces + counterfactual narratives.
        Converts "black box" into governable controller behavior.
      end note
    }

    package "Temporal Analytics" as P0_Temporal {
      note as P0_Temporal_N
        Drift/trend/anomaly detection is a universal pain;
        provides fast operational ROI.
      end note
    }

    package "Homeostasis Control" as P0_Homeostasis {
      note as P0_Homeostasis_N
        Continuous drift control that closes the loop:
        - assess deviation vs desired state
        - emit safe actuation intent
        - reconcile feedback into updated definitions
      end note
    }

    package "Graph Analytics" as P0_Graph {
      note as P0_Graph_N
        Dependency traversal + blast radius are concrete,
        high-frequency engineering needs.
      end note
    }

    package "Multi-Stakeholder Views" as P0_Views {
      note as P0_Views_N
        Market value is in **view contracts + RBAC query constraints**.
        Rendering/dashboards remain domain-app scope.
      end note
    }
  }

  package "P1 - Differentiators (pricing power)" as P1 {

    package "Constraint Intelligence" as P1_Constraint {
      note as P1_Constraint_N
        Conflict/coherence/coverage analysis: strong differentiation when
        constraints become large and interdependent.
      end note
    }

    package "Policy Intelligence" as P1_Policy {
      note as P1_Policy_N
        Translation + operationalization + simulation are valuable,
        but require strong assurance and bounded semantics.
      end note
    }

    package "Actuation & Remediation" as P1_Actuation {
      note as P1_Actuation_N
        Highest ROI when integrated (MTTR reduction), but integration-heavy.
        Start market value with recommendation + escalation, then automation.
      end note
    }
  }

  package "P2 - Accelerators (enablers, bundle with P0/P1)" as P2 {

    package "Semantic Intelligence" as P2_Semantic {
      note as P2_Semantic_N
        On its own, often perceived as commodity. Market value rises when
        it is constrained by types/formal checks and produces auditable artifacts.
      end note
    }

    package "Knowledge Management" as P2_KM {
      note as P2_KM_N
        Useful once decision/policy provenance exists; otherwise risks being
        "documentation shelfware".
      end note
    }
  }

  package "P3 - Research / Integration-Heavy (avoid over-promising)" as P3 {

    package "Systemic Reasoning" as P3_Systemic {
      note as P3_Systemic_N
        Cross-domain code->business mapping is integration-dominant and belongs
        in domain adapters (e.g., ITIP) with explicit contracts.

        Treat "emergence detection" as bounded heuristic monitoring.
      end note
    }
  }

  ' Relationship cues (not strict dependencies)
  P0_Safety ..> P1_Constraint : legitimizes
  P0_Safety ..> P1_Policy : legitimizes
  P0_Safety ..> P1_Actuation : gates
  P0_Decision ..> P0_Explain : feeds evidence
  P0_Graph ..> P3_Systemic : substrate
  P0_Temporal ..> P3_Systemic : substrate
  P0_Views ..> P0_Decision : consumes
  P0_Views ..> P0_Explain : consumes
}

@enduml
