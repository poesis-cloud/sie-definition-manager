@startuml sie-adaptation-governance-instances-v1

' ============================================================
' VISUAL THEME
' ============================================================

left to right direction
skinparam shadowing false
skinparam linetype ortho
skinparam roundcorner 12
skinparam ArrowColor #57606A
skinparam DefaultFontName "SansSerif"
skinparam backgroundColor #FFFFFF

skinparam packageStyle rectangle
skinparam packageBackgroundColor #F6F8FA
skinparam packageBorderColor #57606A

skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #57606A
skinparam classFontColor #24292F

skinparam noteBackgroundColor #FFF8C5
skinparam noteBorderColor #57606A

frame "CD - SIE - Governance - Adaptation Instances - v1" {

  note as InitNote
    **Initialization (SIE instance bootstrap)**

    This diagram specifies the default, auto-defined *governance* definitions
    used for Adaptation (second-order regulation within the viability envelope).

    At initialization time, SIE seeds these definitions in the Definition Plane,
    and binds the Supervisor controller to exactly one BehavioralRule (CSDM invariant).

    **Mapping to feature backlog**
    - E-3 Policy Intelligence: Rule Operationalization, Policy Versioning, Policy Simulation
    - E-3 Constraint Intelligence: Gap/Coverage/Conflict signals that drive Adaptation diagnosis
    - EN-3 Definition Deliverable Compiler: publishes new BehavioralRules and provisions operators
  end note

  ' ------------------------------------------------------------
  ' Primitives grouped by type
  ' ------------------------------------------------------------

  package "EventArchetypes" {
    object "EA-ADP-001\nMismatchAssessmentEvent" as EA_MismatchAssessmentEvent <<EventArchetype>> {
      name = "MismatchAssessmentEvent"
    }

    object "EA-ADP-002\nBehavioralRuleCandidateEvent" as EA_BehavioralRuleCandidateEvent <<EventArchetype>> {
      name = "BehavioralRuleCandidateEvent"
    }

    object "EA-ADP-003\nOperatorProvisioningEvent" as EA_OperatorProvisioningEvent <<EventArchetype>> {
      name = "OperatorProvisioningEvent"
    }
  }

  package "StateObjectArchetypes" {

    object "SOA-ADP-001\nConstraintPublicationChecklist" as SOA_ADP_001 <<StateObjectArchetype>> {
      name = "ConstraintPublicationChecklist"
    }

    object "SOA-ADP-002\nVarietyFeasibilityAssessment" as SOA_ADP_002 <<StateObjectArchetype>> {
      name = "VarietyFeasibilityAssessment"
    }

  }

  package "Policies" {
    object "FP-META-003\nFeasibility Assessment Policy" as FP_META_003 <<FunctionalPolicy>> {
      name = "FeasibilityAssessmentPolicy"
      status = PUBLISHED
      scopedPurposes = [PURP_ADP_001]
      applicabilityConditions = (see note)
      constraint = (see note)
    }
    note right of FP_META_003
      applicabilityConditions:
      {
        "type": "LiteralExpression",
        "value": true
      }

      constraint:
      {
        "type": "InvariantConstraint",
        "condition": {
          "type": "OrExpression",
          "operands": [
            {
              "type": "ComparisonExpression",
              "operator": "NOT_EQUALS",
              "left": {
                "type": "StateObjectArchetypeReferenceExpression",
                "name": "ConstraintPublicationChecklist",
                "propertyPath": ["constraintStatus"]
              },
              "right": { "type": "LiteralExpression", "value": "APPROVED" }
            },
            {
              "type": "ComparisonExpression",
              "operator": "EQUALS",
              "left": {
                "type": "StateObjectArchetypeReferenceExpression",
                "name": "ConstraintPublicationChecklist",
                "propertyPath": ["feasibilityAssessmentPerformed"]
              },
              "right": { "type": "LiteralExpression", "value": true }
            }
          ]
        }
      }

      **Constraint (from SIE meta-governance):**

      constraint.status == APPROVED IMPLIES
      feasibility assessment MUST be performed
      BEFORE status == PUBLISHED
    end note

    object "VP-META-003\nVariety Validation Policy" as VP_META_003 <<ViabilityPolicy>> {
      name = "VarietyValidationPolicy"
      status = PUBLISHED
      scopedCapacities = [CAP_ADP_001]
      applicabilityConditions = (see note)
      constraint = (see note)
    }
    note right of VP_META_003
      applicabilityConditions:
      {
        "type": "LiteralExpression",
        "value": true
      }

      constraint:
      {
        "type": "InvariantConstraint",
        "condition": {
          "type": "OrExpression",
          "operands": [
            {
              "type": "ComparisonExpression",
              "operator": "GREATER_OR_EQUAL",
              "left": {
                "type": "StateObjectArchetypeReferenceExpression",
                "name": "VarietyFeasibilityAssessment",
                "propertyPath": ["mechanismVariety"]
              },
              "right": {
                "type": "StateObjectArchetypeReferenceExpression",
                "name": "VarietyFeasibilityAssessment",
                "propertyPath": ["constraintVariety"]
              }
            },
            {
              "type": "ComparisonExpression",
              "operator": "EQUALS",
              "left": {
                "type": "StateObjectArchetypeReferenceExpression",
                "name": "VarietyFeasibilityAssessment",
                "propertyPath": ["outcome"]
              },
              "right": { "type": "LiteralExpression", "value": "NOT_FEASIBLE" }
            }
          ]
        }
      }

      **Constraint (from SIE meta-governance):**

      feasibility.outcome == NOT_FEASIBLE
      WHEN mechanism.variety < constraint.variety
    end note
  }

  package "ControllerMechanisms" {
    object "SUP-ADP-001\nSupervisorControllerMechanism\n(Adaptation Supervisor)" as SUP_ADP_001 <<SupervisorControllerMechanism>> {
      implementedBehavioralRule = BR_ADP_001
    }
  }

  package "Purposes" {
    object "PURP-ADP-001\nAdaptation Purpose" as PURP_ADP_001 <<Purpose>> {
      name = "AdaptationPurpose"
      description = "Second-order regulation within the current definition envelope. Diagnose mismatches and define updated BehavioralRules under feasibility/variety gates."
    }
  }

  package "Functions" {
    object "FN-ADP-001\nAdaptation Diagnosis" as FN_ADP_001 <<Function>> {
      name = "AdaptationDiagnosis"
      purpose = PURP_ADP_001
    }
  }

  package "Capacities" {
    object "CAP-ADP-001\nDefinition Update Capacity" as CAP_ADP_001 <<Capacity>> {
      name = "DefinitionUpdateCapacity"
      description = "Capacity to update definitions within the viability envelope without breaking constraints."
    }
  }

  package "Modalities" {
    object "MOD-ADP-001\nDefinition Modality" as MOD_ADP_001 <<Modality>> {
      name = "DefinitionUpdate"
      capacity = CAP_ADP_001
    }
  }

  package "BehavioralRules" {
    object "BR-ADP-001\nAdaptation BehavioralRule" as BR_ADP_001 <<BehavioralRule>> {
      name = "AdaptationBehavioralRule"
      status = PUBLISHED

      applyingFunctionalPolicies = [FP_META_003]
      applyingViabilityPolicies = [VP_META_003]
      applyingStructuralPolicies = []

      scopedFunctions = [FN_ADP_001]
      scopedModalities = [MOD_ADP_001]

      triggeringReceptor = R_ADP_001

      applicabilityConditions = (see note)

      iterationConditions = (see note)

      controlSequence = [BRC_ADP_001, BRC_ADP_002]
    }

    note right of BR_ADP_001
    applicabilityConditions:
    {
      "type": "ComparisonExpression",
      "operator": "IN",
      "left": {
        "type": "ContextVariableReferenceExpression",
        "name": "MismatchAssessmentReceptor",
        "propertyPath": ["recommendedPath"]
      },
      "right": {
        "type": "LiteralExpression",
        "value": ["ADAPT", "OPEN_EMERGENCE"]
      }
    }

    iterationConditions:
    {
      "type": "ComparisonExpression",
      "operator": "EQUALS",
      "left": {
        "type": "ContextVariableReferenceExpression",
        "name": "MismatchAssessmentReceptor",
        "propertyPath": ["requiresFurtherDiagnosis"]
      },
      "right": {
        "type": "LiteralExpression",
        "value": true
      }
    }
    end note
  }

  package "Receptors" {
    object "R-ADP-001\nAdaptation Trigger Receptor" as R_ADP_001 <<Receptor>> {
      name = "MismatchAssessmentReceptor"
      receivedEventArchetype = EA_MismatchAssessmentEvent
    }

    object "R-ADP-REMED-001\nCandidate Intake Receptor" as R_ADP_REMED_001 <<Receptor>> {
      name = "BehavioralRuleCandidateIntakeReceptor"
      receivedEventArchetype = EA_BehavioralRuleCandidateEvent
    }

    object "R-ADP-REMED-002\nOperator Provisioning Receptor" as R_ADP_REMED_002 <<Receptor>> {
      name = "OperatorProvisioningReceptor"
      receivedEventArchetype = EA_OperatorProvisioningEvent
    }
  }

  package "Effectors" {
    object "EFF-ADP-001\nPublish BehavioralRule Candidate" as EFF_ADP_001 <<Effector>> {
      name = "BehavioralRuleCandidateEffector"
      producedEventArchetype = EA_BehavioralRuleCandidateEvent
    }

    object "EFF-ADP-002\nOperatorProvisioning Effector" as EFF_ADP_002 <<Effector>> {
      name = "OperatorProvisioningEffector"
      producedEventArchetype = EA_OperatorProvisioningEvent
    }

    object "EFF-ADP-TRG-001\nMismatch Assessment Emitter" as EFF_ADP_TRG_001 <<Effector>> {
      name = "MismatchAssessmentEmitter"
      producedEventArchetype = EA_MismatchAssessmentEvent
    }
  }

  package "BehavioralRuleControls" {
    object "BRC-ADP-001\nDiagnose Control Performance" as BRC_ADP_001 <<BehavioralRuleControl>> {
      name = "ControlPerformanceDiagnosisControl"
      applyingRule = BR_ADP_001

      applicabilityConditions = (see note)

      iterationConditions = (see note)

      effectorEventSourceMapping = (see note)

      effector = EFF_ADP_001
      feedbackReceptor = null
    }

    note right of BRC_ADP_001
    applicabilityConditions:
    {
      "type": "ComparisonExpression",
      "operator": "EQUALS",
      "left": {
        "type": "ContextVariableReferenceExpression",
        "name": "MismatchAssessmentReceptor",
        "propertyPath": ["diagnosisNeeded"]
      },
      "right": {
        "type": "LiteralExpression",
        "value": true
      }
    }

    iterationConditions:
    {
      "type": "ComparisonExpression",
      "operator": "EQUALS",
      "left": {
        "type": "ContextVariableReferenceExpression",
        "name": "MismatchAssessmentReceptor",
        "propertyPath": ["repeatDiagnosis"]
      },
      "right": {
        "type": "LiteralExpression",
        "value": true
      }
    }

    effectorEventSourceMapping:
    {
      "type": "EventStructureSourceMapping",
      "targetArchetype": "BehavioralRuleCandidateEvent",
      "mappings": [
        {
          "type": "PropertyMapping",
          "targetPath": ["scope"],
          "source": {
            "type": "ContextVariableReferenceExpression",
            "name": "MismatchAssessmentReceptor",
            "propertyPath": ["scope"]
          }
        },
        {
          "type": "PropertyMapping",
          "targetPath": ["rationale"],
          "source": {
            "type": "ContextVariableReferenceExpression",
            "name": "MismatchAssessmentReceptor",
            "propertyPath": ["diagnosisSummary"]
          }
        },
        {
          "type": "PropertyMapping",
          "targetPath": ["createdAt"],
          "source": {
            "type": "FunctionCallExpression",
            "functionName": "now",
            "arguments": []
          }
        }
      ]
    }
    end note

    object "BRC-ADP-002\nProvision New Operator Definition" as BRC_ADP_002 <<BehavioralRuleControl>> {
      name = "ProvisionNewOperatorControl"
      applyingRule = BR_ADP_001

      applicabilityConditions = (see note)

      iterationConditions = (see note)

      effectorEventSourceMapping = (see note)

      effector = EFF_ADP_002
      feedbackReceptor = null
    }

    note right of BRC_ADP_002
    applicabilityConditions:
    {
      "type": "ComparisonExpression",
      "operator": "EQUALS",
      "left": {
        "type": "ContextVariableReferenceExpression",
        "name": "MismatchAssessmentReceptor",
        "propertyPath": ["candidateRuleStatus"]
      },
      "right": {
        "type": "LiteralExpression",
        "value": "PUBLISHED"
      }
    }

    iterationConditions:
    {
      "type": "ComparisonExpression",
      "operator": "EQUALS",
      "left": {
        "type": "ContextVariableReferenceExpression",
        "name": "MismatchAssessmentReceptor",
        "propertyPath": ["waitingForRealization"]
      },
      "right": {
        "type": "LiteralExpression",
        "value": true
      }
    }

    effectorEventSourceMapping:
    {
      "type": "EventStructureSourceMapping",
      "targetArchetype": "OperatorProvisioningEvent",
      "mappings": [
        {
          "type": "PropertyMapping",
          "targetPath": ["boundBehavioralRuleId"],
          "source": {
            "type": "ContextVariableReferenceExpression",
            "name": "MismatchAssessmentReceptor",
            "propertyPath": ["candidateRuleId"]
          }
        },
        {
          "type": "PropertyMapping",
          "targetPath": ["provisionMode"],
          "source": {
            "type": "LiteralExpression",
            "value": "REPLACE_OPERATOR"
          }
        },
        {
          "type": "PropertyMapping",
          "targetPath": ["requestedAt"],
          "source": {
            "type": "FunctionCallExpression",
            "functionName": "now",
            "arguments": []
          }
        }
      ]
    }
    end note
  }

  package "Interactions" {
    object "INT-ADP-TRG-001\nMismatchAssessment Dispatch" as INT_ADP_TRG_001 <<Interaction>> {
      name = "MismatchAssessmentDispatch"
      effector = EFF_ADP_TRG_001
      receptor = R_ADP_001
    }

    object "INT-ADP-001\nCandidate Publication" as INT_ADP_001 <<Interaction>> {
      name = "BehavioralRuleCandidatePublication"
      effector = EFF_ADP_001
      receptor = R_ADP_REMED_001
    }

    object "INT-ADP-002\nOperator Provisioning" as INT_ADP_002 <<Interaction>> {
      name = "OperatorProvisioningDispatch"
      effector = EFF_ADP_002
      receptor = R_ADP_REMED_002
    }
  }

  ' ------------------------------------------------------------
  ' Relationships
  ' ------------------------------------------------------------

  SUP_ADP_001 --> BR_ADP_001 : implements

  BR_ADP_001 --> FP_META_003 : applies
  BR_ADP_001 --> VP_META_003 : applies

  BR_ADP_001 --> R_ADP_001 : triggeringReceptor

  FN_ADP_001 --> PURP_ADP_001 : serves
  MOD_ADP_001 --> CAP_ADP_001 : constitutes

  BR_ADP_001 *-- BRC_ADP_001 : has
  BRC_ADP_001 --> EFF_ADP_001 : effector

  BR_ADP_001 *-- BRC_ADP_002 : has
  BRC_ADP_002 --> EFF_ADP_002 : effector

  INT_ADP_TRG_001 --> EFF_ADP_TRG_001 : effector
  INT_ADP_TRG_001 --> R_ADP_001 : receptor

  INT_ADP_001 --> EFF_ADP_001 : effector
  INT_ADP_001 --> R_ADP_REMED_001 : receptor

  INT_ADP_002 --> EFF_ADP_002 : effector
  INT_ADP_002 --> R_ADP_REMED_002 : receptor

}

@enduml
