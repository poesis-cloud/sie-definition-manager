@startuml sie-homeostasis-seq-001-assess-drift-v1

' ============================================================
' VISUAL THEME
' ============================================================

skinparam shadowing false
skinparam linetype ortho
skinparam roundcorner 12
skinparam ArrowColor #57606A
skinparam DefaultFontName "SansSerif"
skinparam backgroundColor #FFFFFF

skinparam noteBackgroundColor #FFF8C5
skinparam noteBorderColor #57606A

title SIE Governance Sequence - Homeostasis - Assess Drift - v1

autonumber

participant "Description Plane - EVAL-HOM-TRG-001" as EFF_HOM_TRG_001
participant "Definition Plane - R-HOM-001" as R_HOM_001
participant "Definition Plane - OP-HOM-001" as OP_HOM_001
participant "Remediation Plane - EFF-HOM-001" as EFF_HOM_001
participant "Remediation Plane - R-HOM-REMED-001" as R_HOM_REMED_001

EFF_HOM_TRG_001 -> R_HOM_001 : [INT-HOM-TRG-001] ControlIntentEvent(phase=ASSESS)
note over OP_HOM_001
  Executes BR-HOM-001 controlSequence
  - BRC-HOM-001 Assess Drift
end note
EFF_HOM_001 -> R_HOM_REMED_001 : [INT-HOM-001] RuleExecutionRequestEvent

@enduml
