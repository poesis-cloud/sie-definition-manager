@startuml sie-coherence-seq-002-detect-incoherence-propose-resolve-sync-v1

' ============================================================
' VISUAL THEME
' ============================================================

skinparam shadowing false
skinparam linetype ortho
skinparam roundcorner 12
skinparam ArrowColor #57606A
skinparam DefaultFontName "SansSerif"
skinparam backgroundColor #FFFFFF

skinparam noteBackgroundColor #FFF8C5
skinparam noteBorderColor #57606A

title SIE Governance Sequence - Coherence - Incoherence -> Resolution -> Sync - v1

autonumber

participant "Event Bus" as Bus
participant "Definition Plane - GOV-COH-001" as GOV_COH_001

Bus -> GOV_COH_001 : [INT-COH-TRG-001] deliver CoherenceRequestEvent(phase=CHECK)

note over GOV_COH_001
  Executes BR-COH-001 controlSequence (branch)
  - BRC-COH-005 Detect Incoherence
  - BRC-COH-006 Propose Resolution
  - BRC-COH-007 Apply Sync
  - BRC-COH-008 Auto-Define Sensor
  - BRC-COH-009 Deprecate Sensor
end note

GOV_COH_001 -> GOV_COH_001 : BRC-COH-005 Detect Incoherence
GOV_COH_001 -> Bus : [INT-COH-005] publish IncoherenceDetectedEvent

GOV_COH_001 -> GOV_COH_001 : BRC-COH-006 Propose Resolution
GOV_COH_001 -> Bus : [INT-COH-006] publish ResolutionProposedEvent

GOV_COH_001 -> GOV_COH_001 : BRC-COH-007 Apply Sync
GOV_COH_001 -> Bus : [INT-COH-007] publish GraphSyncAppliedEvent

GOV_COH_001 -> GOV_COH_001 : BRC-COH-008 Auto-Define Sensor
GOV_COH_001 -> Bus : [INT-COH-008] publish SensorAutoDefinedEvent

GOV_COH_001 -> GOV_COH_001 : BRC-COH-009 Deprecate Sensor
GOV_COH_001 -> Bus : [INT-COH-009] publish SensorDeprecatedEvent

@enduml
