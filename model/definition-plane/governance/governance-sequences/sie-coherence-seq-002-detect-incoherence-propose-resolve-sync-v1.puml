@startuml sie-coherence-seq-002-detect-incoherence-propose-resolve-sync-v1

' ============================================================
' VISUAL THEME
' ============================================================

skinparam shadowing false
skinparam linetype ortho
skinparam roundcorner 12
skinparam ArrowColor #57606A
skinparam DefaultFontName "SansSerif"
skinparam backgroundColor #FFFFFF

skinparam noteBackgroundColor #FFF8C5
skinparam noteBorderColor #57606A

title SIE Governance Sequence - Coherence - Incoherence -> Resolution -> Sync - v1

autonumber

participant "Description Plane - EVAL-COH-TRG-001" as EFF_COH_TRG_001
participant "Definition Plane - R-COH-001" as R_COH_001
participant "Definition Plane - GOV-COH-001" as GOV_COH_001

participant "Remediation Plane - EFF-COH-005" as EFF_COH_005
participant "Remediation Plane - R-COH-REMED-005" as R_COH_REMED_005

participant "Remediation Plane - EFF-COH-006" as EFF_COH_006
participant "Remediation Plane - R-COH-REMED-006" as R_COH_REMED_006

participant "Remediation Plane - EFF-COH-007" as EFF_COH_007
participant "Remediation Plane - R-COH-REMED-007" as R_COH_REMED_007

participant "Remediation Plane - EFF-COH-008" as EFF_COH_008
participant "Remediation Plane - R-COH-REMED-008" as R_COH_REMED_008

participant "Remediation Plane - EFF-COH-009" as EFF_COH_009
participant "Remediation Plane - R-COH-REMED-009" as R_COH_REMED_009

EFF_COH_TRG_001 -> R_COH_001 : [INT-COH-TRG-001] CoherenceRequestEvent(phase=CHECK)

note over GOV_COH_001
  Executes BR-COH-001 controlSequence (branch)
  - BRC-COH-005 Detect Incoherence
  - BRC-COH-006 Propose Resolution
  - BRC-COH-007 Apply Sync
  - BRC-COH-008 Auto-Define Sensor
  - BRC-COH-009 Deprecate Sensor
end note

EFF_COH_005 -> R_COH_REMED_005 : [INT-COH-005] IncoherenceDetectedEvent
EFF_COH_006 -> R_COH_REMED_006 : [INT-COH-006] ResolutionProposedEvent
EFF_COH_007 -> R_COH_REMED_007 : [INT-COH-007] GraphSyncAppliedEvent
EFF_COH_008 -> R_COH_REMED_008 : [INT-COH-008] SensorAutoDefinedEvent
EFF_COH_009 -> R_COH_REMED_009 : [INT-COH-009] SensorDeprecatedEvent

@enduml
