@startuml sie-homeostasis-seq-003-enforce-retention-v1

' ============================================================
' VISUAL THEME
' ============================================================

skinparam shadowing false
skinparam linetype ortho
skinparam roundcorner 12
skinparam ArrowColor #57606A
skinparam DefaultFontName "SansSerif"
skinparam backgroundColor #FFFFFF

skinparam noteBackgroundColor #FFF8C5
skinparam noteBorderColor #57606A

title SIE Governance Sequence - Homeostasis - Enforce Retention - v1

autonumber

participant "Description Plane - EVAL-HOM-TRG-001" as EFF_HOM_TRG_001
participant "Definition Plane - R-HOM-001" as R_HOM_001
participant "Definition Plane - OP-HOM-001" as OP_HOM_001
participant "Remediation Plane - EFF-HOM-003" as EFF_HOM_003
participant "Description Plane - R-HOM-DESC-003" as R_HOM_DESC_003

EFF_HOM_TRG_001 -> R_HOM_001 : [INT-HOM-TRG-001] ControlIntentEvent(phase=RETENTION)
note over OP_HOM_001
  Executes BR-HOM-001 controlSequence
  - BRC-HOM-003 Enforce Evidence Retention
end note
EFF_HOM_003 -> R_HOM_DESC_003 : [INT-HOM-003] RetentionAppliedEvent

@enduml
