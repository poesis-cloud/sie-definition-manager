@startuml sie-coherence-seq-001-check-plan-evidence-supervisor-v1

' ============================================================
' VISUAL THEME
' ============================================================

skinparam shadowing false
skinparam linetype ortho
skinparam roundcorner 12
skinparam ArrowColor #57606A
skinparam DefaultFontName "SansSerif"
skinparam backgroundColor #FFFFFF

skinparam noteBackgroundColor #FFF8C5
skinparam noteBorderColor #57606A

title SIE Governance Sequence - Coherence - Check Plan + Evidence + Supervisor - v1

autonumber

participant "Description Plane - EVAL-COH-TRG-001" as EFF_COH_TRG_001
participant "Definition Plane - R-COH-001" as R_COH_001
participant "Definition Plane - GOV-COH-001" as GOV_COH_001

participant "Remediation Plane - EFF-COH-001" as EFF_COH_001
participant "Remediation Plane - R-COH-REMED-001" as R_COH_REMED_001

participant "Remediation Plane - EFF-COH-002" as EFF_COH_002
participant "Remediation Plane - R-COH-REMED-002" as R_COH_REMED_002

participant "Remediation Plane - EFF-COH-003" as EFF_COH_003
participant "Remediation Plane - R-COH-REMED-003" as R_COH_REMED_003

participant "Remediation Plane - EFF-COH-004" as EFF_COH_004
participant "Remediation Plane - R-COH-REMED-004" as R_COH_REMED_004

EFF_COH_TRG_001 -> R_COH_001 : [INT-COH-TRG-001] CoherenceRequestEvent(phase=CHECK)

note over GOV_COH_001
  Executes BR-COH-001 controlSequence
  - BRC-COH-001 Plan
  - BRC-COH-002 Ground Evidence
  - BRC-COH-003 Supervisor Check
  - BRC-COH-004 Report
end note

EFF_COH_001 -> R_COH_REMED_001 : [INT-COH-001] CoherenceCheckPlanEvent
EFF_COH_002 -> R_COH_REMED_002 : [INT-COH-002] EvidenceGroundingRequestEvent
EFF_COH_003 -> R_COH_REMED_003 : [INT-COH-003] SupervisorCheckRequestEvent
EFF_COH_004 -> R_COH_REMED_004 : [INT-COH-004] CoherenceReportEvent

@enduml
