@startuml sie-emergence-seq-002-request-decision-publish-v1

' ============================================================
' VISUAL THEME
' ============================================================

skinparam shadowing false
skinparam linetype ortho
skinparam roundcorner 12
skinparam ArrowColor #57606A
skinparam DefaultFontName "SansSerif"
skinparam backgroundColor #FFFFFF

skinparam noteBackgroundColor #FFF8C5
skinparam noteBorderColor #57606A

title SIE Governance Sequence - Emergence - Request Decision + Publish - v1

autonumber

participant "Description Plane - EVAL-EMG-TRG-001" as EFF_EMG_TRG_001
participant "Definition Plane - R-EMG-001" as R_EMG_001
participant "Definition Plane - GOV-EMG-001" as GOV_EMG_001
participant "Remediation Plane - EFF-EMG-001" as EFF_EMG_001
participant "Remediation Plane - R-EMG-REMED-001" as R_EMG_REMED_001
participant "Remediation Plane - EFF-EMG-002" as EFF_EMG_002
participant "Human (Decision Owner) - R-DO-001" as R_DO_001
participant "Human (Decision Owner) - EFF-DO-001" as EFF_DO_001
participant "Definition Plane - R-EMG-002" as R_EMG_002
participant "Remediation Plane - EFF-EMG-003" as EFF_EMG_003
participant "Remediation Plane - R-EMG-REMED-003" as R_EMG_REMED_003

EFF_EMG_TRG_001 -> R_EMG_001 : [INT-EMG-TRG-001] EmergenceTriggerEvent
note over GOV_EMG_001
  Executes BR-EMG-001 controlSequence
  - BRC-EMG-001 Open Emergence Case
end note
EFF_EMG_001 -> R_EMG_REMED_001 : [INT-EMG-001] EmergenceCaseOpenedEvent

note over GOV_EMG_001
  - BRC-EMG-002 Request Decision
end note
EFF_EMG_002 -> R_DO_001 : [INT-EMG-002] DecisionRequestEvent
EFF_DO_001 -> R_EMG_002 : [INT-EMG-003] DecisionResponseEvent

note over GOV_EMG_001
  - BRC-EMG-003 Publish New Definitions
end note
EFF_EMG_003 -> R_EMG_REMED_003 : [INT-EMG-004] DefinitionChangedEvent

@enduml
