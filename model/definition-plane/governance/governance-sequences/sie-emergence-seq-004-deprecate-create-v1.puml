@startuml sie-emergence-seq-004-deprecate-create-v1

' ============================================================
' VISUAL THEME
' ============================================================

skinparam shadowing false
skinparam linetype ortho
skinparam roundcorner 12
skinparam ArrowColor #57606A
skinparam DefaultFontName "SansSerif"
skinparam backgroundColor #FFFFFF

skinparam noteBackgroundColor #FFF8C5
skinparam noteBorderColor #57606A

title SIE Governance Sequence - Emergence - Deprecate + Create Primitive - v1

autonumber

actor "Decision Owner" as DecisionOwner

participant "Event Bus" as Bus
participant "Definition Plane - GOV-EMG-001" as GOV_EMG_001

Bus -> GOV_EMG_001 : [INT-EMG-TRG-001] deliver EmergenceTriggerEvent
GOV_EMG_001 -> GOV_EMG_001 : BRC-EMG-001 Open Emergence Case
GOV_EMG_001 -> Bus : [INT-EMG-001] publish EmergenceCaseOpenedEvent

note over GOV_EMG_001
  Executes BR-EMG-001 controlSequence
  - BRC-EMG-006 Deprecate+Create Primitive
end note
GOV_EMG_001 -> GOV_EMG_001 : BRC-EMG-005 Escalate For Approval
GOV_EMG_001 -> Bus : [INT-EMG-006] publish ApprovalRequiredEvent
Bus -> DecisionOwner : deliver ApprovalRequiredEvent

DecisionOwner -> Bus : [INT-EMG-003] publish DecisionResponseEvent
Bus -> GOV_EMG_001 : deliver DecisionResponseEvent

GOV_EMG_001 -> GOV_EMG_001 : BRC-EMG-006 Deprecate+Create Primitive
GOV_EMG_001 -> Bus : [INT-EMG-007] publish PrimitiveDeprecateAndCreateEvent

@enduml
