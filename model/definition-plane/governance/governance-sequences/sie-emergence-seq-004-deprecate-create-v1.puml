title SIE Governance Sequence - Emergence - Deprecate + Create Primitive - v1

autonumber

participant "Description Plane - EVAL-EMG-TRG-001" as EFF_EMG_TRG_001
participant "Definition Plane - R-EMG-001" as R_EMG_001
participant "Definition Plane - GOV-EMG-001" as GOV_EMG_001
participant "Remediation Plane - EFF-EMG-001" as EFF_EMG_001
participant "Remediation Plane - R-EMG-REMED-001" as R_EMG_REMED_001
participant "Remediation Plane - EFF-EMG-005" as EFF_EMG_005
participant "Human (Decision Owner) - R-DO-002" as R_DO_002
participant "Human (Decision Owner) - EFF-DO-001" as EFF_DO_001
participant "Definition Plane - R-EMG-002" as R_EMG_002
participant "Remediation Plane - EFF-EMG-006" as EFF_EMG_006
participant "Remediation Plane - R-EMG-REMED-006" as R_EMG_REMED_006

