@startuml sie-coherence-seq-003-feasibility-workflow-v1

' ============================================================
' VISUAL THEME
' ============================================================

skinparam shadowing false
skinparam linetype ortho
skinparam roundcorner 12
skinparam ArrowColor #57606A
skinparam DefaultFontName "SansSerif"
skinparam backgroundColor #FFFFFF

skinparam noteBackgroundColor #FFF8C5
skinparam noteBorderColor #57606A

title SIE Governance Sequence - Coherence - Feasibility Checks - v1

autonumber

participant "Event Bus" as Bus
participant "Definition Plane - GOV-COH-001" as GOV_COH_001

Bus -> GOV_COH_001 : [INT-COH-TRG-001] deliver CoherenceRequestEvent(phase=FEASIBILITY)
note over GOV_COH_001
  Executes BR-COH-001 controlSequence (branch)
  - BRC-COH-010 Request Feasibility Checks
  - BRC-COH-011 Aggregate Feasibility
end note
GOV_COH_001 -> GOV_COH_001 : BRC-COH-010 Request Feasibility Checks
GOV_COH_001 -> Bus : [INT-COH-010] publish FeasibilityAssessmentRequestedEvent

GOV_COH_001 -> GOV_COH_001 : BRC-COH-011 Aggregate Feasibility
GOV_COH_001 -> Bus : [INT-COH-011] publish FeasibilityAggregatedEvent

@enduml
