skinparam noteBorderColor #57606A

title SIE - Meta-Governance: SIE's Own BehavioralRules - v1

' ============================================================
' META-GOVERNANCE OVERVIEW
' ============================================================

note as MetaGovNote
  **Meta-Governance: SIE Governing Itself**

  This diagram contains SIE's own BehavioralRules (meta-rules) that
  operationalize SIE's meta-policies.

  The meta-policies themselves are defined in:
  - `sie-governance-policies-v1.puml`
end note

frame "SIE Meta-Governance BehavioralRules - v1" {

  ' ============================================================
  ' REFERENCED POLICIES (STUBS)
  '
  ' BehavioralRules reference Policies via `applies`. We keep the policy
  ' *definitions* in a separate diagram; here we only declare identifiers.
  ' ============================================================

  package "Referenced Policies (stubs)" as PolicyRefs {
    class "FP-META-001\nEmergence Trigger Policy" as FP001 <<FunctionalPolicy>>
    class "VP-META-001\nEmergence Confidence Policy" as VP001 <<ViabilityPolicy>>
    class "SP-META-001\nPrimitive Immutability Policy" as SP001 <<StructuralPolicy>>

    class "FP-META-002\nIncoherence Detection Policy" as FP002 <<FunctionalPolicy>>
    class "VP-META-002\nResolution Timeliness Policy" as VP002 <<ViabilityPolicy>>
    class "SP-META-002\nGraph Consistency Policy" as SP002 <<StructuralPolicy>>

    class "FP-META-003\nFeasibility Assessment Policy" as FP003 <<FunctionalPolicy>>
    class "VP-META-003\nVariety Validation Policy" as VP003 <<ViabilityPolicy>>

    class "SP-META-003\nEvidence Retention Policy" as SP003 <<StructuralPolicy>>
    class "VP-META-004\nEvidence Minimization Policy" as VP004 <<ViabilityPolicy>>
  }

  ' ============================================================
  ' META-SUPERVISOR: EMERGENCE RULES
  ' ============================================================

  package "Emergence Rules (Meta-Supervisor)" as EmergenceRules {
    
    class "BR-META-001\nAuto-Approve High Confidence" as BR001 <<BehavioralRule>> {
      **name**: "AutoApproveHighConfidence"
      **applies**: [VP-META-001]
      **applicabilityConditions**: |
        emergence.proposal.confidence >= 0.85 AND
        emergence.proposal.impact.breaking == false AND
        config.automationMode IN [SEMI_AUTONOMOUS, FULLY_AUTONOMOUS]
      **controlSequence**: |
        1. SET emergence.decision.status = AUTO_APPROVED
        2. SET emergence.status = APPROVED
        3. EMIT EmergenceApprovedEvent
        4. TRIGGER enactment
    }
    
    class "BR-META-002\nEscalate Low Confidence" as BR002 <<BehavioralRule>> {
      **name**: "EscalateLowConfidence"
      **applies**: [VP-META-001]
      **applicabilityConditions**: |
        emergence.proposal.confidence < 0.7 OR
        emergence.proposal.impact.breaking == true
      **controlSequence**: |
        1. SET emergence.decision.status = PENDING
        2. EMIT ApprovalRequiredEvent(approvers)
        3. AWAIT approval OR timeout(24h)
        4. IF timeout THEN EMIT EscalationEvent
    }
    
    class "BR-META-003\nDeprecate Before Create" as BR003 <<BehavioralRule>> {
      **name**: "DeprecateBeforeCreate"
      **applies**: [SP-META-001]
      **applicabilityConditions**: |
        emergence.operation == MODIFY AND
        target.status != DRAFT
      **controlSequence**: |
        1. CREATE new_primitive = COPY(target, modifications)
        2. SET target.status = DEPRECATED
        3. SET target.supersededBy = new_primitive.id
        4. EMIT PrimitiveDeprecatedEvent
        5. EMIT PrimitiveCreatedEvent
    }
  }

  ' ============================================================
  ' META-SUPERVISOR: COHERENCE RULES
  ' ============================================================

  package "Coherence Rules (Meta-Supervisor)" as CoherenceRules {
    
    class "BR-META-004\nDetect Circular Dependency" as BR004 <<BehavioralRule>> {
      **name**: "DetectCircularDependency"
      **applies**: [FP-META-002]
      **applicabilityConditions**: |
        primitive.created OR primitive.linked
      **controlSequence**: |
        1. QUERY neo4j: MATCH path = (a)-[*]->(a)
        2. IF path EXISTS THEN
           CREATE Incoherence(type=CIRCULAR_DEPENDENCY)
        3. EMIT IncoherenceDetectedEvent
    }
    
    class "BR-META-005\nAuto-Resolve Stale Reference" as BR005 <<BehavioralRule>> {
      **name**: "AutoResolveStaleReference"
      **applies**: [FP-META-002, VP-META-002]
      **applicabilityConditions**: |
        incoherence.type == STALE_REFERENCE AND
        incoherence.severity IN [INFO, WARNING]
      **controlSequence**: |
        1. FIND replacement = LATEST(incoherence.staleTarget.supersededBy)
        2. IF replacement EXISTS THEN
           PROPOSE ResolutionAction(UPDATE_REFERENCE, replacement)
        3. IF config.automationMode == FULLY_AUTONOMOUS THEN
           EXECUTE resolution
        4. EMIT ResolutionProposedEvent
    }
    
    class "BR-META-006\nSync Graph on Change" as BR006 <<BehavioralRule>> {
      **name**: "SyncGraphOnChange"
      **applies**: [SP-META-002]
      **applicabilityConditions**: |
        cdc.event.table IN [primitive_tables]
      **controlSequence**: |
        1. TRANSFORM cdc.event TO neo4j.mutation
        2. APPLY neo4j.mutation
        3. IF lag > 30s THEN EMIT SyncLagAlertEvent
    }
  }

  ' ============================================================
  ' META-SUPERVISOR: FEASIBILITY RULES
  ' ============================================================

  package "Feasibility Rules (Meta-Supervisor)" as FeasibilityRules {
    
    class "BR-META-007\nTrigger Feasibility Check" as BR007 <<BehavioralRule>> {
      **name**: "TriggerFeasibilityCheck"
      **applies**: [FP-META-003]
      **applicabilityConditions**: |
        constraint.status CHANGED TO APPROVED
      **controlSequence**: |
        1. IDENTIFY assessors = 
           IF constraint IS Policy THEN supervisors(scope)
           ELSE operators(scope)
        2. FOR EACH assessor:
           EMIT FeasibilityAssessmentRequestedEvent
        3. AWAIT all assessments OR timeout(4h)
    }
    
    class "BR-META-008\nAggregate Feasibility" as BR008 <<BehavioralRule>> {
      **name**: "AggregateFeasibility"
      **applies**: [FP-META-003, VP-META-003]
      **applicabilityConditions**: |
        ALL(assessments) RECEIVED OR timeout
      **controlSequence**: |
        1. IF ANY(assessment.outcome == NOT_FEASIBLE) THEN
           SET constraint.status = NOT_FEASIBLE
        2. ELSE IF ANY(assessment.outcome == FEASIBLE_WITH_ADJUSTMENTS) THEN
           SET constraint.status = FEASIBLE_WITH_ADJUSTMENTS
        3. ELSE
           SET constraint.status = FEASIBLE
        4. EMIT FeasibilityAggregatedEvent
    }
  }

  ' ============================================================
  ' META-SUPERVISOR: EVIDENCE / RETENTION RULES
  ' ============================================================

  package "Evidence Rules (Meta-Supervisor)" as EvidenceRules {

    class "BR-META-009\nEnforce Evidence Retention" as BR009 <<BehavioralRule>> {
      **name**: "EnforceEvidenceRetention"
      **applies**: [SP-META-003, VP-META-004]
      **applicabilityConditions**: |
        schedule.tick OR config.retentionPolicyChanged
      **controlSequence**: |
        1. COMPUTE rawWindow = max(mismatch.persistenceWindow,
                                  control.diagnosisWindow,
                                  adaptation.outcomeEvaluationWindow)
        2. COMPUTE derivedWindow = max(adaptation.outcomeEvaluationWindow,
                                      emergence.caseEvidenceWindow)
        3. ENSURE snapshots retained for governance.auditWindow
        4. APPLY bounding/sampling/pointer strategy for RAW tier
        5. COMPACT/EXPIRE RAW beyond rawWindow
        6. EXPIRE DERIVED beyond derivedWindow (unless linked to open cases)
        7. ARCHIVE required SNAPSHOTS (replayable bundles)
        8. EMIT RetentionAppliedEvent(windows, scope)
    }
  }

  ' ============================================================
  ' META-SUPERVISOR: SENSOR AUTO-DEFINITION RULES
  ' ============================================================

  package "Sensor Auto-Definition Rules (Meta-Supervisor)" as SensorRules {
    
    class "BR-META-011\nAuto-Define Sensor for Policy" as BR011 <<BehavioralRule>> {
      **name**: "AutoDefineSensorForPolicy"
      **applies**: [FP-META-001]
      **applicabilityConditions**: |
        policy.observability IS NOT EMPTY AND
        policy.status == INTEGRATED AND
        NOT EXISTS sensor WHERE sensor.measures == policy
      **controlSequence**: |
        1. DERIVE measurementSchema FROM references(policy.constraint)
        2. CREATE EventArchetype(name=policy.name + "Measurement", schema=measurementSchema)
        3. CREATE SensorMechanism(
             receptor=ActuationFeedbackEventArchetype,
             effector=measurementEventArchetype)
        4. CREATE Interaction(sensor.effector → governor.receptor)
        5. EMIT SensorAutoDefinedEvent
    }
    
    class "BR-META-010\nDeprecate Orphan Sensor" as BR010 <<BehavioralRule>> {
      **name**: "DeprecateOrphanSensor"
      **applies**: [SP-META-001]
      **applicabilityConditions**: |
        sensor.measures.policy.status == DEPRECATED AND
        sensor.status != DEPRECATED
      **controlSequence**: |
        1. SET sensor.status = DEPRECATED
        2. SET sensor.effector.eventArchetype.status = DEPRECATED
        3. EMIT SensorDeprecatedEvent
    }
  }

  ' ============================================================
  ' RELATIONSHIPS
  ' ============================================================

  BR001 .up.> VP001 : applies
  BR002 .up.> VP001 : applies
  BR003 .up.> SP001 : applies
  BR004 .up.> FP002 : applies
  BR005 .up.> FP002 : applies
  BR005 .up.> VP002 : applies
  BR006 .up.> SP002 : applies
  BR007 .up.> FP003 : applies
  BR008 .up.> FP003 : applies
  BR008 .up.> VP003 : applies
  BR009 .up.> SP003 : applies
  BR009 .up.> VP004 : applies
  BR010 .up.> SP001 : applies
  BR011 .up.> FP001 : applies
}

