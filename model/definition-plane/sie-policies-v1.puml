@startuml sie-governance-policies-v1

' ============================================================
' VISUAL THEME
' ============================================================

skinparam shadowing false
skinparam linetype ortho
skinparam roundcorner 12
skinparam ArrowColor #57606A
skinparam DefaultFontName "SansSerif"
skinparam backgroundColor #FFFFFF

skinparam packageStyle rectangle
skinparam packageBackgroundColor #F6F8FA
skinparam packageBorderColor #57606A

skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #57606A
skinparam classFontColor #24292F

skinparam noteBackgroundColor #FFF8C5
skinparam noteBorderColor #57606A

title SIE - Meta-Governance: SIE's Own Policies - v1

' ============================================================
' META-GOVERNANCE OVERVIEW
' ============================================================

note as MetaGovNote
  **Meta-Governance: SIE Governing Itself**

  SIE is a system that uses the same governance patterns it defines.
  These are SIE's own Policies that govern how SIE operates on
  user-defined systems.

  **Recursion**: SIE's meta-governance policies ARE SystemicPrimitives
  in SIE's own Definition Plane instance.

  **Hierarchy**:
  - Meta-Governor: Owns meta-policies about SIE operation
end note

frame "SIE Meta-Governance Policies - v1" {

  ' ============================================================
  ' META-GOVERNOR: EMERGENCE GOVERNANCE
  ' ============================================================

  package "Emergence Governance (Meta-Governor)" as EmergenceGov {

    class "FP-META-001\nEmergence Trigger Policy" as FP001 <<FunctionalPolicy>> {
      **name**: "EmergenceTriggerPolicy"
      **constraint**: |
        emergence.openedBy.type MUST be one of:
        [MISMATCH_DETECTED, COHERENCE_ESCALATION,
         USER_REQUEST, OBSERVATION_RECEIVED,
         LLM_PROPOSAL, SCHEDULED_ANALYSIS]
    }

    class "VP-META-001\nEmergence Confidence Policy" as VP001 <<ViabilityPolicy>> {
      **name**: "EmergenceConfidencePolicy"
      **constraint**: |
        emergence.proposal.confidence >= 0.7
        OR emergence.decision.mode == MANUAL
    }

    class "SP-META-001\nPrimitive Immutability Policy" as SP001 <<StructuralPolicy>> {
      **name**: "PrimitiveImmutabilityPolicy"
      **constraint**: |
        primitive.status != DRAFT IMPLIES
        primitive.attributes ARE IMMUTABLE
    }
  }

  ' ============================================================
  ' META-GOVERNOR: COHERENCE GOVERNANCE
  ' ============================================================

  package "Coherence Governance (Meta-Governor)" as CoherenceGov {

    class "FP-META-002\nIncoherence Detection Policy" as FP002 <<FunctionalPolicy>> {
      **name**: "IncoherenceDetectionPolicy"
      **constraint**: |
        coherence_check MUST detect:
        [LOGICAL_CONTRADICTION, CIRCULAR_DEPENDENCY,
         ORPHANED_CONSTRAINT, STALE_REFERENCE]
    }

    class "VP-META-002\nResolution Timeliness Policy" as VP002 <<ViabilityPolicy>> {
      **name**: "ResolutionTimelinessPolicy"
      **constraint**: |
        incoherence.severity == CRITICAL IMPLIES
        resolution.proposed_within <= 1h
    }

    class "SP-META-002\nGraph Consistency Policy" as SP002 <<StructuralPolicy>> {
      **name**: "GraphConsistencyPolicy"
      **constraint**: |
        neo4j.graph MUST be CDC-synchronized
        with postgresql.source_of_truth
        within 30s
    }
  }

  ' ============================================================
  ' META-GOVERNOR: FEASIBILITY GOVERNANCE
  ' ============================================================

  package "Feasibility Governance (Meta-Governor)" as FeasibilityGov {

    class "FP-META-003\nFeasibility Assessment Policy" as FP003 <<FunctionalPolicy>> {
      **name**: "FeasibilityAssessmentPolicy"
      **constraint**: |
        constraint.status == APPROVED IMPLIES
        feasibility_assessment MUST be performed
        BEFORE status == PUBLISHED
    }

    class "VP-META-003\nVariety Validation Policy" as VP003 <<ViabilityPolicy>> {
      **name**: "VarietyValidationPolicy"
      **constraint**: |
        feasibility.outcome == NOT_FEASIBLE
        WHEN mechanism.variety < constraint.variety
    }
  }

  ' ============================================================
  ' META-GOVERNOR: EVIDENCE / RETENTION GOVERNANCE
  ' ============================================================

  package "Evidence Governance (Meta-Governor)" as EvidenceGov {

    class "SP-META-003\nEvidence Retention Policy" as SP003 <<StructuralPolicy>> {
      **name**: "EvidenceRetentionPolicy"
      **constraint**: |
        // Retention is tiered: RAW measured evidence vs DERIVED activable evidence vs SNAPSHOTS.
        // RAW: high-volume State-derived Description objects (StateObject/EventInstance).
        // DERIVED: mismatch + assessments + operational feedback evidence.
        // SNAPSHOTS: bounded, typed solver projections / case bundles for replay.

        description.retention.tier[RAW].window MUST be >= max(
          mismatch.persistenceWindow,
          control.diagnosisWindow,
          adaptation.outcomeEvaluationWindow
        )
        AND description.retention.tier[RAW].boundedUniverse MUST be defined

        description.retention.tier[DERIVED].window MUST be >= max(
          adaptation.outcomeEvaluationWindow,
          emergence.caseEvidenceWindow
        )

        description.retention.tier[SNAPSHOT].window MUST be >= governance.auditWindow
        AND description.retention.tier[SNAPSHOT].replayable == true

        // Boundary guardrail: Description is not a full State mirror.
        description.retention.tier[RAW].strategy IN [POINTERS, SAMPLED, BOUNDED]
    }

    class "VP-META-004\nEvidence Minimization Policy" as VP004 <<ViabilityPolicy>> {
      **name**: "EvidenceMinimizationPolicy"
      **constraint**: |
        // Keep the smallest evidence that preserves control + audit coherence.
        description.retention.preferPointers == true
        AND description.retention.redactSensitiveFields == true
        AND description.retention.storeDerivedEvidenceLongerThanRaw == true
    }
  }
}

@enduml
