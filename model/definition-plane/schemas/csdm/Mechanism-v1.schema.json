{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "sie://schemas/csdm/v1/Mechanism.json",
  "title": "Mechanism (CSDM v1)",
  "description": "Atomic causal unit of behavior: receives events via receptors and produces events via effectors.",
  "allOf": [
    { "$ref": "sie://schemas/csdm/v1/SystemicPrimitive.json" }
  ],
  "type": "object",
  "required": ["name"],
  "properties": {
    "name": { "$ref": "sie://schemas/csdm/v1/common.json#/definitions/Name80" },
    "receptors": { "type": "array", "items": { "$ref": "sie://schemas/csdm/v1/common.json#/definitions/UUID" } },
    "effectors": { "type": "array", "items": { "$ref": "sie://schemas/csdm/v1/common.json#/definitions/UUID" } }
  }
}
