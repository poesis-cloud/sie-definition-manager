{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "sie://schemas/csdm/v1/Function.json",
  "title": "Function (CSDM v1)",
  "description": "A system function serving exactly one purpose.",
  "allOf": [
    { "$ref": "sie://schemas/csdm/v1/SystemicPrimitive.json" }
  ],
  "type": "object",
  "required": ["name", "purpose"],
  "properties": {
    "name": { "$ref": "sie://schemas/csdm/v1/common.json#/definitions/Name80" },
    "purpose": {
      "$ref": "sie://schemas/csdm/v1/common.json#/definitions/UUID",
      "description": "Reference to Purpose primitive served by this function."
    }
  }
}
