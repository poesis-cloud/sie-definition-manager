{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "sie://schemas/events/v1/CoherenceRequestEvent.json",
  "title": "CoherenceRequestEvent (Events v1)",
  "description": "Request to run coherence workflows.",
  "type": "object",
  "additionalProperties": false,
  "required": ["phase", "scope", "requestedAt"],
  "properties": {
    "phase": {
      "type": "string",
      "enum": ["CHECK", "FEASIBILITY", "ADMISSION"]
    },
    "scope": {
      "description": "Opaque scope selector for governance workflows.",
      "type": "object",
      "additionalProperties": true
    },
    "definitionBundle": {
      "description": "Optional candidate definition bundle for admission/validation workflows.",
      "type": ["object", "null"],
      "additionalProperties": true
    },
    "requestedAt": { "$ref": "sie://schemas/csdm/v1/common.json#/definitions/DateTime" }
  }
}
