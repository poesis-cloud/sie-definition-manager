{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "sie://schemas/events/v1/ActuationControlEvent.json",
  "title": "ActuationControlEvent (Events v1)",
  "description": "Request to perform an actuation against the State plane.",
  "type": "object",
  "additionalProperties": false,
  "required": ["actuationType", "resourceId", "desiredState"],
  "properties": {
    "actuationType": {
      "type": "string",
      "enum": ["create", "modify", "delete", "acquire"]
    },
    "resourceId": { "type": "string" },
    "desiredState": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
