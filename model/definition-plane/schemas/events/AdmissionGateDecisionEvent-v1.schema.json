{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "sie://schemas/events/v1/AdmissionGateDecisionEvent.json",
  "title": "AdmissionGateDecisionEvent (Events v1)",
  "description": "Coherence admission gate decision for a candidate definition bundle. This is a governance gate (not authorization).",
  "type": "object",
  "additionalProperties": false,
  "required": ["decisionType", "scope", "outcome", "decidedAt"],
  "properties": {
    "decisionType": {
      "type": "string",
      "description": "Gate decision category (e.g., DEFINITION_ADMISSION)."
    },
    "scope": {
      "description": "Opaque scope selector for governance workflows.",
      "type": "object",
      "additionalProperties": true
    },
    "outcome": {
      "type": "string",
      "enum": ["PASS", "FAIL", "NEEDS_REVIEW"]
    },
    "reasons": {
      "type": "array",
      "items": { "type": "string" }
    },
    "references": {
      "description": "Optional pointers to underlying reports/artifacts.",
      "type": ["object", "null"],
      "additionalProperties": true
    },
    "decidedAt": { "$ref": "sie://schemas/csdm/v1/common.json#/definitions/DateTime" }
  }
}
