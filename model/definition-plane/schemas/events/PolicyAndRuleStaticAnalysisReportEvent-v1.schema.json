{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "sie://schemas/events/v1/PolicyAndRuleStaticAnalysisReportEvent.json",
  "title": "PolicyAndRuleStaticAnalysisReportEvent (Events v1)",
  "description": "Static analysis/lint report for policies and behavioral rules (conflicts, dead code, shadowing, stale references).",
  "type": "object",
  "additionalProperties": false,
  "required": ["scope", "status", "analyzedAt"],
  "properties": {
    "scope": {
      "description": "Opaque scope selector for governance workflows.",
      "type": "object",
      "additionalProperties": true
    },
    "status": {
      "type": "string",
      "enum": ["PASS", "FAIL", "WARN"]
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kind", "message", "severity"],
        "properties": {
          "kind": { "type": "string" },
          "message": { "type": "string" },
          "severity": { "type": "string", "enum": ["INFO", "WARN", "ERROR"] },
          "subjectRef": { "type": ["string", "null"] }
        }
      }
    },
    "analyzedAt": { "$ref": "sie://schemas/csdm/v1/common.json#/definitions/DateTime" }
  }
}
