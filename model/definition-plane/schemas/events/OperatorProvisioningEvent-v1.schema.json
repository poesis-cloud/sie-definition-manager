{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "sie://schemas/events/v1/OperatorProvisioningEvent.json",
  "title": "OperatorProvisioningEvent (Events v1)",
  "description": "Request to provision / replace an Operator realization.",
  "type": "object",
  "additionalProperties": false,
  "required": ["boundBehavioralRuleId", "provisionMode", "requestedAt"],
  "properties": {
    "boundBehavioralRuleId": { "$ref": "sie://schemas/csdm/v1/common.json#/definitions/UUID" },
    "provisionMode": {
      "type": "string",
      "enum": ["ADD_OPERATOR", "REPLACE_OPERATOR", "UPDATE_OPERATOR", "ROLLBACK_OPERATOR"]
    },
    "requestedAt": { "$ref": "sie://schemas/csdm/v1/common.json#/definitions/DateTime" }
  }
}
