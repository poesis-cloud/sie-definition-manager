{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "sie://schemas/events/v1/ConstraintSatisfiabilityReportEvent.json",
  "title": "ConstraintSatisfiabilityReportEvent (Events v1)",
  "description": "Report for satisfiability/consistency checking of constraint sets (e.g., SMT-backed).",
  "type": "object",
  "additionalProperties": false,
  "required": ["scope", "satisfiable", "checkedAt"],
  "properties": {
    "scope": {
      "description": "Opaque scope selector for governance workflows.",
      "type": "object",
      "additionalProperties": true
    },
    "satisfiable": { "type": "boolean" },
    "unsatCore": {
      "description": "Optional unsatisfiable core / conflict summary.",
      "type": ["object", "null"],
      "additionalProperties": true
    },
    "checkedAt": { "$ref": "sie://schemas/csdm/v1/common.json#/definitions/DateTime" }
  }
}
