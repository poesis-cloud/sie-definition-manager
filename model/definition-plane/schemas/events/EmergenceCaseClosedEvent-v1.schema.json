{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "sie://schemas/events/v1/EmergenceCaseClosedEvent.json",
  "title": "EmergenceCaseClosedEvent (Events v1)",
  "description": "Emitted when an emergence case is closed (terminal state).",
  "type": "object",
  "additionalProperties": false,
  "required": ["scope", "outcome", "closedAt"],
  "properties": {
    "scope": {
      "description": "Opaque scope selector for governance workflows.",
      "type": "object",
      "additionalProperties": true
    },
    "outcome": {
      "type": "string",
      "enum": ["APPROVED", "REJECTED", "ABORTED"]
    },
    "closedAt": {
      "$ref": "sie://schemas/csdm/v1/common.json#/definitions/DateTime"
    },
    "reason": {
      "type": ["string", "null"]
    }
  }
}
