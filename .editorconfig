root = true

[*]
indent_style = space
indent_size = 2
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.java]
indent_size = 2

[*.{yaml,yml}]
indent_size = 2

[*.{json,jsonschema}]
indent_size = 2

[*.sql]
indent_size = 2

[*.{puml,plantuml}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[Makefile]
indent_style = tab
