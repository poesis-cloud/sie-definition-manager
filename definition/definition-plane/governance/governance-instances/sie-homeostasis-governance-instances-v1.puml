                "name": "EvidenceRetentionSpec",
                "propertyPath": ["mismatchPersistenceWindowSeconds"]
              }
            },
            {
              "type": "ComparisonExpression",
              "operator": "GREATER_OR_EQUAL",
              "left": {
                "type": "StateObjectArchetypeReferenceExpression",
                "name": "EvidenceRetentionSpec",
                "propertyPath": ["rawWindowSeconds"]
              },
              "right": {
                "type": "StateObjectArchetypeReferenceExpression",
                "name": "EvidenceRetentionSpec",
                "propertyPath": ["controlDiagnosisWindowSeconds"]
              }
            },
            {
              "type": "ComparisonExpression",
              "operator": "GREATER_OR_EQUAL",
              "left": {
                "type": "StateObjectArchetypeReferenceExpression",
                "name": "EvidenceRetentionSpec",
                "propertyPath": ["rawWindowSeconds"]
              },
              "right": {
                "type": "StateObjectArchetypeReferenceExpression",
                "name": "EvidenceRetentionSpec",
                "propertyPath": ["adaptationOutcomeEvaluationWindowSeconds"]
              }
            },
            {
              "type": "ComparisonExpression",
              "operator": "EQUALS",
              "left": {
                "type": "StateObjectArchetypeReferenceExpression",
                "name": "EvidenceRetentionSpec",
                "propertyPath": ["rawBoundedUniverseDefined"]
              },
              "right": { "type": "LiteralExpression", "value": true }
            },
            {
              "type": "ComparisonExpression",
              "operator": "GREATER_OR_EQUAL",
              "left": {
                "type": "StateObjectArchetypeReferenceExpression",
                "name": "EvidenceRetentionSpec",
                "propertyPath": ["derivedWindowSeconds"]
              },
              "right": {
                "type": "StateObjectArchetypeReferenceExpression",
                "name": "EvidenceRetentionSpec",
                "propertyPath": ["adaptationOutcomeEvaluationWindowSeconds"]
              }
            },
            {
              "type": "ComparisonExpression",
              "operator": "GREATER_OR_EQUAL",
              "left": {
                "type": "StateObjectArchetypeReferenceExpression",
                "name": "EvidenceRetentionSpec",
                "propertyPath": ["derivedWindowSeconds"]
              },
              "right": {
                "type": "StateObjectArchetypeReferenceExpression",
                "name": "EvidenceRetentionSpec",
                "propertyPath": ["emergenceCaseEvidenceWindowSeconds"]
              }
            },
            {
              "type": "ComparisonExpression",
              "operator": "GREATER_OR_EQUAL",
              "left": {
                "type": "StateObjectArchetypeReferenceExpression",
                "name": "EvidenceRetentionSpec",
                "propertyPath": ["snapshotWindowSeconds"]
              },
              "right": {
                "type": "StateObjectArchetypeReferenceExpression",
                "name": "EvidenceRetentionSpec",
                "propertyPath": ["governanceAuditWindowSeconds"]
              }
            },
            {
              "type": "ComparisonExpression",
              "operator": "EQUALS",
              "left": {
                "type": "StateObjectArchetypeReferenceExpression",
                "name": "EvidenceRetentionSpec",
                "propertyPath": ["snapshotReplayable"]
              },
              "right": { "type": "LiteralExpression", "value": true }
            },
            {
              "type": "ComparisonExpression",
              "operator": "IN",
              "left": {
                "type": "StateObjectArchetypeReferenceExpression",
                "name": "EvidenceRetentionSpec",
                "propertyPath": ["rawStrategy"]
              },
              "right": {
                "type": "LiteralExpression",
                "value": ["POINTERS", "SAMPLED", "BOUNDED"]
              }
            }
          ]
        }
      }

      **Constraint (from SIE meta-governance):**

      Retention is tiered: RAW measured evidence vs DERIVED activable evidence vs SNAPSHOTS.

      - RAW window >= max(mismatch.persistenceWindow, control.diagnosisWindow, adaptation.outcomeEvaluationWindow)
      - RAW boundedUniverse MUST be defined
      - DERIVED window >= max(adaptation.outcomeEvaluationWindow, emergence.caseEvidenceWindow)
      - SNAPSHOT window >= governance.auditWindow AND replayable == true
      - Guardrail: Description is not a full State mirror; RAW strategy IN [POINTERS, SAMPLED, BOUNDED]
    end note
