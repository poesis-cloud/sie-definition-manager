  package "Policies" {
    object "FP-HOM-001\nConvergence Policy" as FP_HOM_001 <<FunctionalPolicy>> {
      name = "ConvergencePolicy"
      status = PUBLISHED
      scopedPurposes = [PURP_HOM_001]
      applicabilityConditions = (see note)
      constraint = (see note)
    }
    note right of FP_HOM_001
      applicabilityConditions:
      {
        "type": "LiteralExpression",
        "value": true
      }

      constraint:
      {
        "type": "InvariantConstraint",
        "condition": {
          "type": "AndExpression",
          "operands": [
            {
              "type": "ComparisonExpression",
              "operator": "LESS_OR_EQUAL",
              "left": {
                "type": "StateObjectArchetypeReferenceExpression",
                "name": "HomeostasisConvergenceObservation",
                "propertyPath": ["deviationError"]
              },
              "right": {
                "type": "StateObjectArchetypeReferenceExpression",
                "name": "HomeostasisConvergenceObservation",
                "propertyPath": ["tolerance"]
              }
            },
            {
              "type": "ComparisonExpression",
              "operator": "GREATER_OR_EQUAL",
              "left": {
                "type": "StateObjectArchetypeReferenceExpression",
                "name": "HomeostasisConvergenceObservation",
                "propertyPath": ["stableForSeconds"]
              },
              "right": {
                "type": "StateObjectArchetypeReferenceExpression",
                "name": "HomeostasisConvergenceObservation",
                "propertyPath": ["requiredStableWindowSeconds"]
              }
            },
            {
              "type": "ComparisonExpression",
              "operator": "EQUALS",
              "left": {
                "type": "StateObjectArchetypeReferenceExpression",
                "name": "HomeostasisConvergenceObservation",
                "propertyPath": ["oscillating"]
              },
              "right": { "type": "LiteralExpression", "value": false }
            }
          ]
        }
      }

      **Constraint (from SIE governance):**

      Homeostasis attempt is considered *converged* when the measured deviation
      error reaches the declared tolerance and remains stable for a bounded window.

      If not converged within the window (or oscillating/unstable), OperationalFeedback
      MUST surface variety hints and/or failure modes for Coherence/Adaptation dispatch.
    end note

