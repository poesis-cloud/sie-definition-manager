      applicabilityConditions:
      {
        "type": "LiteralExpression",
        "value": true
      }

      constraint:
      {
        "type": "InvariantConstraint",
        "condition": {
          "type": "AndExpression",
          "operands": [
            {
              "type": "ComparisonExpression",
              "operator": "IN",
              "left": { "type": "LiteralExpression", "value": "LOGICAL_CONTRADICTION" },
              "right": {
                "type": "StateObjectArchetypeReferenceExpression",
                "name": "CoherenceCheckCoverageReport",
                "propertyPath": ["implementedDetectors"]
