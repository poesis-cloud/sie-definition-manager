              "left": { "type": "LiteralExpression", "value": "CIRCULAR_DEPENDENCY" },
              "right": {
                "type": "StateObjectArchetypeReferenceExpression",
                "name": "CoherenceCheckCoverageReport",
                "propertyPath": ["implementedDetectors"]
              }
            },
            {
              "type": "ComparisonExpression",
              "operator": "IN",
              "left": { "type": "LiteralExpression", "value": "ORPHANED_CONSTRAINT" },
              "right": {
                "type": "StateObjectArchetypeReferenceExpression",
                "name": "CoherenceCheckCoverageReport",
                "propertyPath": ["implementedDetectors"]
              }
            },
            {
              "type": "ComparisonExpression",
              "operator": "IN",
              "left": { "type": "LiteralExpression", "value": "STALE_REFERENCE" },
              "right": {
                "type": "StateObjectArchetypeReferenceExpression",
                "name": "CoherenceCheckCoverageReport",
                "propertyPath": ["implementedDetectors"]
              }
            }
          ]
        }
      }

      **Constraint (from SIE meta-governance):**

      coherence_check MUST detect:
      [LOGICAL_CONTRADICTION, CIRCULAR_DEPENDENCY,
       ORPHANED_CONSTRAINT, STALE_REFERENCE]
    end note

