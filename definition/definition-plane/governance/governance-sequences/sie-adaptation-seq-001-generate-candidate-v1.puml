@startuml sie-adaptation-seq-001-generate-candidate-v1

' ============================================================
' VISUAL THEME
' ============================================================

skinparam shadowing false
skinparam linetype ortho
skinparam roundcorner 12
skinparam ArrowColor #57606A
skinparam DefaultFontName "SansSerif"
skinparam backgroundColor #FFFFFF

skinparam noteBackgroundColor #FFF8C5
skinparam noteBorderColor #57606A

title SIE Governance Sequence - Adaptation - Generate Candidate - v1

autonumber

participant "Event Bus" as Bus
participant "Definition Plane - SUP-ADP-001" as SUP_ADP_001

Bus -> SUP_ADP_001 : [INT-ADP-TRG-001] deliver MismatchAssessmentEvent
note over SUP_ADP_001
  Executes BR-ADP-001 controlSequence
  - BRC-ADP-001 Propose Candidate Rule
end note
SUP_ADP_001 -> SUP_ADP_001 : BRC-ADP-001 Propose Candidate Rule
SUP_ADP_001 -> Bus : [INT-ADP-001] publish BehavioralRuleCandidateEvent

@enduml
