@startuml sie-homeostasis-seq-002-actuate-remediation-v1

' ============================================================
' VISUAL THEME
' ============================================================

skinparam shadowing false
skinparam linetype ortho
skinparam roundcorner 12
skinparam ArrowColor #57606A
skinparam DefaultFontName "SansSerif"
skinparam backgroundColor #FFFFFF

skinparam noteBackgroundColor #FFF8C5
skinparam noteBorderColor #57606A

title SIE Governance Sequence - Homeostasis - Actuate Remediation - v1

autonumber

participant "Event Bus" as Bus
participant "Definition Plane - OP-HOM-001" as OP_HOM_001
actor "State Plane" as State

Bus -> OP_HOM_001 : [INT-HOM-TRG-001] ControlIntentEvent(phase=ACTUATE)
note over OP_HOM_001
  Executes BR-HOM-001 controlSequence
  - BRC-HOM-002 Actuation Gate
end note
OP_HOM_001 -> OP_HOM_001 : BRC-HOM-002 Modify State (Actuation)
OP_HOM_001 -> Bus : [INT-HOM-002] publish ActuationControlEvent
Bus -> State : deliver ActuationControlEvent
note over State, OP_HOM_001
  Operational feedback is observed in State
  and re-enters via State -> Description -> Definition.
end note
State -> Bus : [INT-HOM-FB-001] publish ActuationFeedbackEvent
Bus -> OP_HOM_001 : deliver ActuationFeedbackEvent

@enduml
