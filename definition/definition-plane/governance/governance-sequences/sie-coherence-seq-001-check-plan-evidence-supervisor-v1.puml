@startuml sie-coherence-seq-001-check-plan-evidence-supervisor-v1

' ============================================================
' VISUAL THEME
' ============================================================

skinparam shadowing false
skinparam linetype ortho
skinparam roundcorner 12
skinparam ArrowColor #57606A
skinparam DefaultFontName "SansSerif"
skinparam backgroundColor #FFFFFF

skinparam noteBackgroundColor #FFF8C5
skinparam noteBorderColor #57606A

title SIE Governance Sequence - Coherence - Check Plan + Evidence + Supervisor - v1

autonumber

participant "Event Bus" as Bus
participant "Definition Plane - GOV-COH-001" as GOV_COH_001

Bus -> GOV_COH_001 : [INT-COH-TRG-001] deliver CoherenceRequestEvent(phase=CHECK)

note over GOV_COH_001
  Executes BR-COH-001 controlSequence
  - BRC-COH-001 Plan
  - BRC-COH-002 Ground Evidence
  - BRC-COH-003 Supervisor Check
  - BRC-COH-004 Report
end note

GOV_COH_001 -> GOV_COH_001 : BRC-COH-001 Plan
GOV_COH_001 -> Bus : [INT-COH-001] publish CoherenceCheckPlanEvent

GOV_COH_001 -> GOV_COH_001 : BRC-COH-002 Ground Evidence
GOV_COH_001 -> Bus : [INT-COH-002] publish DescriptionQueryEvent

GOV_COH_001 -> GOV_COH_001 : BRC-COH-003 Supervisor Check
GOV_COH_001 -> Bus : [INT-COH-003] publish SupervisorCheckRequestEvent

GOV_COH_001 -> GOV_COH_001 : BRC-COH-004 Report
GOV_COH_001 -> Bus : [INT-COH-004] publish CoherenceReportEvent

@enduml
