@startuml sie-systemic-process-sequence-v1

' ============================================================
' VISUAL THEME
' ============================================================

skinparam shadowing false
skinparam linetype ortho
skinparam roundcorner 12
skinparam ArrowColor #57606A
skinparam DefaultFontName "SansSerif"
skinparam backgroundColor #FFFFFF

skinparam sequence {
  ParticipantBackgroundColor #FFFFFF
  ParticipantBorderColor #57606A
  LifeLineBackgroundColor #F6F8FA
  LifeLineBorderColor #57606A
  ArrowColor #57606A
  DividerBackgroundColor #F6F8FA
}

skinparam noteBackgroundColor #FFF8C5
skinparam noteBorderColor #57606A

title SIE - Systemic Processes End-to-End (Functional workflow, bus-agnostic) - v1

autonumber

' ============================================================
' PARTICIPANTS (Functional workflow)
' - Description Plane (Left): Observations, Evidence, Analytics
' - Definition Plane (Center): Governance Controllers (Operator/Supervisor/Governor)
' - Remediation Plane (Right): Execution, Actuation, Deployment
' - Event Bus transport is intentionally omitted (technical). Where relevant, interactions are annotated
'   as "may be mediated by an Event Bus".
' ============================================================

box "Description Plane" #F8F4F8
  participant "Interface\n(Evidence & Analytics)" as DescInterface
end box

box "Definition Plane" #E8F4E8
  participant "Operator\n(owns Homeostasis)" as Operator
  participant "Supervisor\n(owns Adaptation)" as Supervisor
  participant "Governor\n(owns Emergence + Coherence)" as Governor
end box

box "Remediation Plane" #F4F8F8
  participant "Interface\n(Execution & Actuation)" as RemedInterface
end box

actor "Decision Owner\n(human input)" as DecisionOwner

note over DescInterface, RemedInterface
  **Plane Responsibilities & Functional Flow:**
  - **Description**: Senses State, computes Evidence, evaluates policies, holds historical data.
  - **Definition**: Consumes Evidence, executes Governance Logic, evolves Definitions.
  - **Remediation**: Realizes Definitions (Actuation), orchestrates workflows.

  **Closed-loop boundary:**
  1. State -> Description (Observation)
  2. Description -> Definition (Evidence/Triggers)
  3. Definition -> Remediation (Instructions/Deliverables)
  4. Remediation -> State (Actuation)
end note

' ============================================================
' END-TO-END FLOW (includes ALL controls)
' ============================================================

== 0) Triggers (inbound to Definition plane) ==
note over Operator, Governor
  Typical inbound deliveries from Description/Remediation:
  - ControlIntentEvent (drives Homeostasis phases)
  - MismatchAssessmentEvent (drives Adaptation)
  - CoherenceRequestEvent (CHECK / FEASIBILITY / ADMISSION)
  - EmergenceTriggerEvent
  - ActuationFeedbackEvent (observed feedback)

  **Transport note:** these may be mediated by an Event Bus.
end note

DescInterface -> Operator : ControlIntentEvent / MismatchAssessmentEvent / ...
DescInterface -> Governor : EmergenceTriggerEvent / CoherenceRequestEvent

== 1) Homeostasis (Operator; BRC-HOM-001..003) ==
note over Operator
  Trigger: ControlIntentEvent arrives (from evidence; may be mediated by Event Bus)
end note

alt ControlIntentEvent.phase == "ASSESS"
  loop while ControlIntentEvent.repeatAssessment == true
    Operator -> Operator : BRC-HOM-001 Assess Drift / Stability
    note right
      EventSourceMapping:
      - intentId -> RuleExecutionRequestEvent.intentId
      - scope -> RuleExecutionRequestEvent.scope
    end note
    Operator -> RemedInterface : RuleExecutionRequestEvent
    RemedInterface -> RemedInterface : Execute Rule Logic (RuleExecutionRequest)
    
    alt Execution Success
        RemedInterface -> Operator : RuleExecutionFeedbackEvent(status=SUCCESS)
    else Execution Failure
        RemedInterface -> Operator : RuleExecutionFeedbackEvent(status=FAILURE)
        note right: Logic execution failure feedback
        Operator -> Operator : Handle Failure / Re-Assess
    end
  end
else ControlIntentEvent.phase == "ACTUATE"
  loop while ControlIntentEvent.repeatActuation == true
    Operator -> Operator : BRC-HOM-002 Modify State (Actuation)
    note right
      EventSourceMapping:
      - resourceId -> ActuationControlEvent.resourceId
      - desiredState -> ActuationControlEvent.desiredState
      - "MODIFICATION" -> ActuationControlEvent.actuationType
    end note
    Operator -> RemedInterface : ActuationControlEvent
    RemedInterface -> RemedInterface : Perform Actuation (ActuationControl)

    alt Actuation Success
        RemedInterface -> Operator : ActuationFeedbackEvent(status=SUCCESS)
        Operator -> DescInterface : ActuationFeedbackEvent (Forward for Verification)
        DescInterface -> Operator : ControlIntentEvent (Update Loop Condition)
    else Actuation Failure
        RemedInterface -> Operator : ActuationFeedbackEvent(status=FAILURE)
        note right: Actuation failure feedback
        Operator -> Operator : Handle Failure / Re-Assess
    end
  end
else ControlIntentEvent.phase == "RETENTION"
  Operator -> Operator : BRC-HOM-003 Enforce Evidence Retention
  note right
    EventSourceMapping:
    - rawWindow -> RetentionAppliedEvent.rawWindow
    - derivedWindow -> RetentionAppliedEvent.derivedWindow
  end note
  Operator -> DescInterface : RetentionAppliedEvent
  DescInterface -> DescInterface : Enforce Data Policy (RetentionApplied)
else (phase not applicable)
  note over Operator
    No Homeostasis control applies.
  end note
end

alt Homeostasis not converged / oscillating / insufficient variety
  Operator -> Supervisor : MismatchAssessmentEvent(diagnosisNeeded=true) (may be mediated by Event Bus)
else Homeostasis converged
  note over Operator
    No Adaptation escalation required.
  end note
end

== 2) Adaptation (Supervisor; BRC-ADP-001..002) ==
note over Supervisor
  Trigger: MismatchAssessmentEvent arrives (from evidence; may be mediated by Event Bus)
end note

alt MismatchAssessmentEvent.diagnosisNeeded == true
  loop while MismatchAssessmentEvent.repeatDiagnosis == true
    Supervisor -> Supervisor : BRC-ADP-001 Diagnose Control Performance
    note right
      EventSourceMapping:
      - scope -> BehavioralRuleCandidateEvent.scope
      - diagnosisSummary -> BehavioralRuleCandidateEvent.rationale
    end note
    Supervisor -> DescInterface : BehavioralRuleCandidateEvent
    DescInterface -> DescInterface : Log Candidate Proposal (BehavioralRuleCandidate)
  end
else (no diagnosis)
  note over Supervisor
    BRC-ADP-001 not applicable.
  end note
end

alt MismatchAssessmentEvent.candidateRuleStatus == "PUBLISHED"
  loop while MismatchAssessmentEvent.waitingForRealization == true
    Supervisor -> Supervisor : BRC-ADP-002 Provision New Operator Definition
    note right
      EventSourceMapping:
      - candidateRuleId -> OperatorProvisioningEvent.boundBehavioralRuleId
      - "REPLACE_OPERATOR" -> OperatorProvisioningEvent.provisionMode
    end note
    Supervisor -> Operator : OperatorProvisioningEvent (may be mediated by Event Bus)
    Supervisor -> RemedInterface : OperatorProvisioningEvent (Start deployment)
    RemedInterface -> RemedInterface : Provision Operator (OperatorProvisioning)
    
    alt Provisioning Success
        RemedInterface -> Supervisor : OperatorProvisioningFeedbackEvent(status=SUCCESS)
    else Provisioning Failure
        RemedInterface -> Supervisor : OperatorProvisioningFeedbackEvent(status=FAILURE)
        note right: Provisioning failure feedback
        Supervisor -> Supervisor : Handle Failure / Diagnosis
    end
  end
else (candidate not published)
  note over Supervisor
    BRC-ADP-002 not applicable.
  end note
end

Supervisor -> Governor : CoherenceRequestEvent(phase=CHECK) (may be mediated by Event Bus)

== 3) Coherence (Governor; BRC-COH-001..018) ==
group CHECK + FEASIBILITY
  alt CoherenceRequestEvent.phase == "CHECK"
    Governor -> Governor : BRC-COH-001 Select Check Set
    note right
       EventSourceMapping: scope -> CheckPlan.scope
    end note
    Governor -> DescInterface : CoherenceCheckPlanEvent
    DescInterface -> DescInterface : Initialize Check Context (CoherenceCheckPlan)

    Governor -> Governor : BRC-COH-002 Request Evidence Grounding
    note right
       EventSourceMapping: scope -> EvidenceSelectors
    end note
    Governor -> DescInterface : EvidenceGroundingRequestEvent
    DescInterface -> DescInterface : Fetch Evidence (EvidenceGroundingRequest)

    alt Evidence Found
        DescInterface -> Governor : EvidenceGroundingResponseEvent(status=FOUND)
    else Evidence Missing/Error
        DescInterface -> Governor : EvidenceGroundingResponseEvent(status=MISSING)
        Governor -> Governor : Handle Missing Evidence (Abort/Retry)
    end

    Governor -> Governor : BRC-COH-003 Request Supervisor Checks
    note right
       EventSourceMapping: ["LOGICAL..","CIRCULAR.."] -> checkSet
    end note
    Governor -> Supervisor : SupervisorCheckRequestEvent (may be mediated by Event Bus)
    Supervisor -> Supervisor : BRC-SUP-COH-013 Generate Coherence Report (Supervisor Checks)
    note right
       EventSourceMapping: checkSet -> report.checkSet
    end note
    Supervisor --> Governor : CoherenceReportEvent (partial; may be mediated by Event Bus)

    Governor -> Governor : BRC-COH-004 Aggregate Reports
    note right
       EventSourceMapping: "COMPLETED" -> report.status
    end note
    Governor -> DescInterface : CoherenceReportEvent
    DescInterface -> DescInterface : Store/Analyze Report (CoherenceReport)
  end

  alt CoherenceReport.status == "CRITICAL_FAILURE"
    Governor -> Governor : Abort Coherence Check
  else CoherenceReport.status != "CRITICAL_FAILURE"
     Governor -> Governor : BRC-COH-005 Detect Circular Dependency
  note right
     EventSourceMapping: scope -> IncoherenceDetected.scope
  end note
  Governor -> DescInterface : IncoherenceDetectedEvent
  DescInterface -> DescInterface : Register Incoherence (IncoherenceDetected)

  Governor -> Governor : BRC-COH-006 Auto-Resolve Stale Reference
  note right
     EventSourceMapping: scope -> ResolutionProposed.scope
  end note
  Governor -> DescInterface : ResolutionProposedEvent
  DescInterface -> DescInterface : Propose Resolution (ResolutionProposed)

  Governor -> Governor : BRC-COH-007 Apply Graph Sync
  note right
     EventSourceMapping: {} -> mutation
  end note
  Governor -> DescInterface : GraphSyncAppliedEvent
  DescInterface -> DescInterface : Update Graph (GraphSyncApplied)

  Governor -> Governor : BRC-COH-008 Auto-Define Missing Sensor
  note right
     EventSourceMapping: 00..00 -> policyId
  end note
  Governor -> RemedInterface : SensorAutoDefinedEvent
  RemedInterface -> RemedInterface : Deploy Sensor Config (SensorAutoDefined)

  Governor -> Governor : BRC-COH-009 Deprecate Unused Sensor
  note right
     EventSourceMapping: 00..00 -> sensorId
  end note
  Governor -> RemedInterface : SensorDeprecatedEvent
  RemedInterface -> RemedInterface : Remove Sensor Config (SensorDeprecated)
  end

  alt CoherenceRequestEvent.phase == "FEASIBILITY"
    Governor -> Governor : BRC-COH-010 Request Feasibility Checks
    note right
       EventSourceMapping: scope -> FeasibilityAssessmentRequested.scope
    end note
    Governor -> DescInterface : FeasibilityAssessmentRequestedEvent
    DescInterface -> DescInterface : Assess Feasibility (FeasibilityAssessmentRequested)

    Governor -> Governor : BRC-COH-011 Aggregate Feasibility Reports
    note right
       EventSourceMapping: scope -> FeasibilityAggregated.scope
    end note
    Governor -> DescInterface : FeasibilityAggregatedEvent
    DescInterface -> DescInterface : Aggregate Feasibility (FeasibilityAggregated)
  end
end

group ADMISSION (BRC-COH-012..018; reuses 005..009)
  note over Governor
    In ADMISSION phase, Coherence also executes controls 005..009 before 012..018.
  end note

  alt CoherenceRequestEvent.phase == "ADMISSION"
  
    Governor -> Governor : BRC-COH-012 Validate DefinitionBundle
    note right
       EventSourceMapping: scope -> DefinitionBundleValidationReport.scope
    end note
    Governor -> DescInterface : DefinitionBundleValidationReportEvent
    DescInterface -> DescInterface : Log Validation (DefinitionBundleValidationReport)

    Governor -> Governor : BRC-COH-012A Request Supervisor Admission Checks
    note right
       EventSourceMapping: ["CONSISTENCY", "SAT", "ACTUATION"] -> checkSet
    end note
    Governor -> Supervisor : SupervisorCheckRequestEvent (ADMISSION checkSet; may be mediated by Event Bus)
    
    ' Explicitly showing Supervisor response flow here for clarity
    Supervisor -> Supervisor : BRC-SUP-COH-013 Generate Coherence Report
    Supervisor --> Governor : CoherenceReportEvent

    Governor -> Governor : BRC-COH-013 Policy & Rule Static Analysis
    note right
       Validation Scope: Functional, Viability, Structural
       Verifies BRC logic compiles against Policies
       EventSourceMapping: scope -> AnalysisReport.scope
    end note
    Governor -> DescInterface : PolicyAndRuleStaticAnalysisReportEvent
    DescInterface -> DescInterface : Log Static Analysis (PolicyAndRuleStaticAnalysisReport)

    Governor -> Governor : BRC-COH-014 Constraint Satisfiability Checking
    note right
       EventSourceMapping: scope -> SatReport.scope
    end note
    Governor -> DescInterface : ConstraintSatisfiabilityReportEvent
    DescInterface -> DescInterface : Log SAT Result (ConstraintSatisfiabilityReport)

    Governor -> Governor : BRC-COH-015 Execute Definition Test Suite
    note right
       EventSourceMapping: scope -> TestSuiteReport.scope
    end note
    Governor -> DescInterface : DefinitionTestSuiteReportEvent
    DescInterface -> DescInterface : Log Test Results (DefinitionTestSuiteReport)

    Governor -> Governor : BRC-COH-016 Admission Gate Decision
    note right
       EventSourceMapping: scope -> AdmissionGateDecision.scope
    end note
    Governor -> Supervisor : AdmissionGateDecisionEvent (trigger for Provisioning)
    Governor -> DescInterface : AdmissionGateDecisionEvent (Audit)
    DescInterface -> DescInterface : Audit Decision (AdmissionGateDecision)

    alt AdmissionGateDecisionEvent.outcome == "PASS"
      note over Governor
        Admission gate computed PASS.
      end note
    else AdmissionGateDecisionEvent.outcome == "FAIL"
      note over Governor
        Admission gate computed FAIL.
      end note
    else AdmissionGateDecisionEvent.outcome == "NEEDS_REVIEW"
      Governor -> DecisionOwner : DecisionRequestEvent (manual review; may be mediated by Event Bus)
      DecisionOwner --> Governor : DecisionResponseEvent (may be mediated by Event Bus)
    end

    Governor -> Governor : BRC-COH-017 Record Governance Decision
    Governor -> DescInterface : GovernanceDecisionRecordedEvent
    DescInterface -> DescInterface : Archive Decision Record (GovernanceDecisionRecorded)

    Governor -> Governor : BRC-COH-018 Controlled Activation Plan
    Governor -> Operator : ControlledActivationPlanEvent (instruction to Operator)
    Governor -> RemedInterface : ControlledActivationPlanEvent
    RemedInterface -> RemedInterface : Execute Activation Plan (ControlledActivationPlan)

    alt Activation Success
        RemedInterface -> Governor : ControlledActivationFeedbackEvent(status=SUCCESS)
    else Activation Failure
        RemedInterface -> Governor : ControlledActivationFeedbackEvent(status=FAILURE)
        Governor -> Governor : Handle Activation Failure
    end
  end
end

== 4) Emergence (Governor; BRC-EMG-001..007) ==
note over Governor
  Trigger: EmergenceTriggerEvent arrives (from evidence; may be mediated by Event Bus)
end note

Governor -> Governor : BRC-EMG-001 Open Emergence Case
note right
   EventSourceMapping: trigger -> EmergenceCase
end note
Governor -> DescInterface : EmergenceCaseOpenedEvent
DescInterface -> DescInterface : Open Tracking Case (EmergenceCaseOpened)

alt EmergenceTriggerEvent.proposal.confidence >= 0.7
  Governor -> Governor : BRC-EMG-004 Auto-Approve High Confidence
  note right
     EventSourceMapping: caseId -> EmergenceApproved
  end note
  Governor -> DescInterface : EmergenceApprovedEvent
  DescInterface -> DescInterface : Log Approval (EmergenceApproved)

  Governor -> Governor : BRC-EMG-NEW Request Admission Check
  note right
     EventSourceMapping: proposal -> CoherenceRequest(ADMISSION)
  end note
  Governor -> Governor : CoherenceRequestEvent(phase=ADMISSION)
  
  alt AdmissionGateDecisionEvent.outcome == "PASS"
    Governor -> Governor : BRC-EMG-003 Publish New Definitions
  note right
     EventSourceMapping: proposal.definitions -> DefinitionChanged
  end note
  Governor -> Operator : DefinitionChangedEvent
  Governor -> RemedInterface : DefinitionChangedEvent (Update Runtime)
  RemedInterface -> RemedInterface : Update Runtime Definitions (DefinitionChanged)

  alt Runtime Update Success
     RemedInterface -> Governor : DefinitionUpdateFeedbackEvent(status=SUCCESS)
  else Runtime Update Failure
     RemedInterface -> Governor : DefinitionUpdateFeedbackEvent(status=FAILURE)
     Governor -> Governor : Handle Update Failure
  end

  Governor -> Governor : BRC-EMG-006 Deprecate Before Create
  note right
     EventSourceMapping: proposal.obsolete -> DeprecateAndCreate
  end note
  Governor -> RemedInterface : PrimitiveDeprecateAndCreateEvent
  RemedInterface -> RemedInterface : Manage Lifecycle (PrimitiveDeprecateAndCreate)
  else
    note over Governor
       Admission Check Failed (Block Publication)
    end
  end
else EmergenceTriggerEvent.proposal.confidence < 0.7
  loop while DecisionResponseEvent.received == false
    Governor -> Governor : BRC-EMG-002 Request Decision
    note right
       EventSourceMapping: proposal -> DecisionRequest
    end note
    Governor -> DecisionOwner : DecisionRequestEvent (may be mediated by Event Bus)

    Governor -> Governor : BRC-EMG-005 Escalate Low Confidence
    note right
       EventSourceMapping: proposal -> ApprovalRequired
    end note
    Governor -> DecisionOwner : ApprovalRequiredEvent (may be mediated by Event Bus)

    DecisionOwner --> Governor : DecisionResponseEvent (may be mediated by Event Bus)
  end

  alt DecisionResponseEvent.outcome == "APPROVED"
    Governor -> Governor : BRC-EMG-003 Publish New Definitions
    note right
       EventSourceMapping: proposal.definitions -> DefinitionChanged
    end note
    Governor -> Operator : DefinitionChangedEvent
    Governor -> RemedInterface : DefinitionChangedEvent
    RemedInterface -> RemedInterface : Update Runtime Definitions (DefinitionChanged)

    Governor -> Governor : BRC-EMG-006 Deprecate Before Create
    note right
       EventSourceMapping: proposal.obsolete -> DeprecateAndCreate
    end note
    Governor -> RemedInterface : PrimitiveDeprecateAndCreateEvent
    RemedInterface -> RemedInterface : Manage Lifecycle (PrimitiveDeprecateAndCreate)
  else (not approved)
    note over Governor
      Decision did not approve; no definition publication.
    end note
  end
end

Governor -> Governor : BRC-EMG-007 Close Emergence Case
note right
   EventSourceMapping: caseId -> EmergenceCaseClosed
end note
Governor -> DescInterface : EmergenceCaseClosedEvent
DescInterface -> DescInterface : Close Tracking Case (EmergenceCaseClosed)

== 5) Close the loop ==
note over DescInterface, RemedInterface
  Outcomes of Remediation (Actuation) and Description (Evidence) re-enter the Definition Plane
  as new triggers, completing the Systemic Governance Loop.
end note

@enduml