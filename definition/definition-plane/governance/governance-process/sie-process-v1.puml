@startuml sie-systemic-process-sequence-v1

' ============================================================
' VISUAL THEME
' ============================================================

skinparam shadowing false
skinparam linetype ortho
skinparam roundcorner 12
skinparam ArrowColor #57606A
skinparam DefaultFontName "SansSerif"
skinparam backgroundColor #FFFFFF

skinparam sequence {
  ParticipantBackgroundColor #FFFFFF
  ParticipantBorderColor #57606A
  LifeLineBackgroundColor #F6F8FA
  LifeLineBorderColor #57606A
  ArrowColor #57606A
  DividerBackgroundColor #F6F8FA
}

skinparam noteBackgroundColor #FFF8C5
skinparam noteBorderColor #57606A

title SIE - Systemic Processes End-to-End (Functional workflow, bus-agnostic) - v1

autonumber

' ============================================================
' PARTICIPANTS (Functional workflow)
' - Observations Plane (Left): Truth (Sensing, Measurement, Interpretation)
' - Governance Plane (Center): Meaning (Policies, Rules, Structure)
' - Operations Plane (Right): Change (Execution, Actuation, Coordination)
' - Event Bus transport is intentionally omitted (technical). Where relevant, interactions are annotated
'   as "may be mediated by an Event Bus".
' ============================================================

box "Observations Plane" #F8F4F8
  participant "Observations\n(Interface)" as Observations
end box

box "Governance Plane" #E8F4E8
  participant "Operator\n(Homeostasis)" as Operator
  participant "Supervisor\n(Adaptation)" as Supervisor
  participant "Governor\n(Emergence/Coh.)" as Governor
end box

box "Operations Plane" #F4F8F8
  participant "Operations\n(Interface)" as Operations
end box

actor "Decision Owner\n(human input)" as DecisionOwner

note over Observations, Operations
  **The Systemic Triad (Mechanism-Centric):**
  - **Governance**: Defines and assigns Controller Mechanisms (Logic + Rights).
  - **Observations**: Hosts Observer Mechanisms; Pushes Observation Signal (Evidence).
  - **Operations**: Hosts Actor Mechanisms; Pushes Operation Feedback (Outcome).

  **Interface Interactions:**
  - **Provisioning**: Gov -> Obs/Ops (AssignMechanism)
  - **Signaling**: Obs/Ops -> Gov (ObservationSignal / OperationFeedback)
  - **Analysis**: Gov -> Obs (QueryDescription)
  - **Validation**: Osp -> Gov (RequestAuthorization)
end note

' ============================================================
' END-TO-END FLOW (includes ALL controls)
' ============================================================

== 0) Constitution (Mechanism Assignment) ==
note over Governor, Operations
  Governance provisions the runtime planes by assigning "Controller Mechanisms".
  Each mechanism bundles: Definition (Logic) + Identity (Credentials) + Config.
end note

Governor -> Observations : INT-GOV-INF-001 AssignMechanism (Observer)
note right: Payload: EA-GOV-INF-001 (PROVISION)

Governor -> Operations : INT-GOV-INF-001 AssignMechanism (Actor)
note right: Payload: EA-GOV-INF-001 (PROVISION)

== 1) Triggers (inbound to Governance) ==
note over Operator, Governor
  Runtime signals flow back from planes via the Standard Interfaces.
  Payloads are wrapped in:
  - EA-GOV-INF-002 ObservationSignalEvent
  - EA-GOV-INF-003 OperationFeedbackEvent
end note

Observations -> Operator : ObservationSignal (ControlIntent / Mismatch)
Observations -> Governor : ObservationSignal (Emergence / Coherence)

== 2) Homeostasis (Operator; BRC-HOM-001..003) ==
note over Operator
  Trigger: ObservationSignalEvent (ControlIntent) arrives.
end note

alt ControlIntent.phase == "ASSESS"
  loop while ControlIntent.repeatAssessment == true
    Operator -> Operator : BRC-HOM-001 Assess Drift / Stability
    
    Operator -> Operations : Request Rule Execution (via Mechanism Update or Command)
    Operations -> Operations : Execute Rule Logic
    
    alt Execution Success
        Operations -> Operator : OperationFeedbackEvent (RuleExecutionFeedback=SUCCESS)
    else Execution Failure
        Operations -> Operator : OperationFeedbackEvent (RuleExecutionFeedback=FAILURE)
        Operator -> Operator : Handle Failure / Re-Assess
    end
  end
else ControlIntent.phase == "ACTUATE"
  loop while ControlIntent.repeatActuation == true
    Operator -> Operator : BRC-HOM-002 Modify State (Actuation)
    note right
      Standard Command: ActuationControl
    end note
    Operator -> Operations : ActuationControlEvent
    Operations -> Operations : Perform Actuation

    alt Actuation Success
        Operations -> Operator : OperationFeedbackEvent (ActuationFeedback=SUCCESS)
        Operations -> Observations : ActuationFeedbackEvent (Consequence Reporting)
        Observations -> Operator : ObservationSignalEvent (ControlIntent Update)
    else Actuation Failure
        Operations -> Operator : OperationFeedbackEvent (ActuationFeedback=FAILURE)
        Operator -> Operator : Handle Failure / Re-Assess
    end
  end
else ControlIntent.phase == "RETENTION"
  Operator -> Operator : BRC-HOM-003 Enforce Evidence Retention
  Operator -> Observations : RetentionAppliedEvent
  Observations -> Observations : Enforce Data Policy
else (phase not applicable)
  note over Operator
    No Homeostasis control applies.
  end note
end

alt Homeostasis not converged
  Operator -> Supervisor : ObservationSignal (MismatchAssessment=TRUE)
else Homeostasis converged
  note over Operator
    No Adaptation escalation required.
  end note
end

== 3) Adaptation (Supervisor; BRC-ADP-001..002) ==
note over Supervisor
  Trigger: ObservationSignal (MismatchAssessment) arrives.
end note

alt MismatchAssessment.diagnosisNeeded == true
  loop while MismatchAssessment.repeatDiagnosis == true
    Supervisor -> Supervisor : BRC-ADP-001 Diagnose Control Performance
    Supervisor -> Observations : ObservationSignal (BehavioralRuleCandidate)
    Observations -> Observations : Log Candidate Proposal
  end
end

alt MismatchAssessment.candidateRuleStatus == "PUBLISHED"
  loop while MismatchAssessment.waitingForRealization == true
    Supervisor -> Supervisor : BRC-ADP-002 Provision New Operator Definition
    
    Supervisor -> Operator : MechanismAssignmentEvent (Update Definition)
    
    Supervisor -> Operations : INT-GOV-INF-001 AssignMechanism (Update Internal Logic)
    note right: Payload: EA-GOV-INF-001 (UPDATE)
    
    Operations -> Operations : Provision Operator Mechanism
    
    alt Provisioning Success
        Operations -> Supervisor : OperationFeedbackEvent (Provisioning=SUCCESS)
        Operations -> Observations : OperationFeedbackEvent (Consequence Reporting)
    else Provisioning Failure
        Operations -> Supervisor : OperationFeedbackEvent (Provisioning=FAILURE)
        Supervisor -> Supervisor : Handle Failure / Diagnosis
    end
  end
end

Supervisor -> Governor : ObservationSignal (CoherenceRequest=CHECK)

== 4) Coherence (Governor; BRC-COH-001..018) ==
group CHECK + FEASIBILITY
  alt CoherenceRequest.phase == "CHECK"
    Governor -> Governor : BRC-COH-001 Select Check Set
    Governor -> Observations : CoherenceCheckPlanEvent
    Observations -> Observations : Initialize Check Context

    Governor -> Governor : BRC-COH-002 Request Evidence Grounding
    
    Governor -> Observations : INT-GOV-INF-006 QueryDescription (EvidenceSelectors)
    note right: Payload: EA-GOV-INF-006 DescriptionQueryEvent
    
    Observations -> Observations : Fetch Evidence
    
    alt Evidence Found
        Observations -> Governor : INT-GOV-INF-007 ReturnDescription (Snapshot)
        note right: Payload: EA-GOV-INF-007 DescriptionSnapshotEvent
    else Evidence Missing
        Observations -> Governor : ReturnDescription (Empty/Error)
        Governor -> Governor : Handle Missing Evidence
    end

    Governor -> Governor : BRC-COH-003 Request Supervisor Checks
    Governor -> Supervisor : SupervisorCheckRequestEvent
    Supervisor -> Supervisor : BRC-SUP-COH-013 Generate Coherence Report
    Supervisor --> Governor : CoherenceReportEvent

    Governor -> Governor : BRC-COH-004 Aggregate Reports
    Governor -> Observations : CoherenceReportEvent
    Observations -> Observations : Store/Analyze Report
  end

  alt CoherenceReport.status == "CRITICAL_FAILURE"
    Governor -> Governor : Abort Coherence Check
  else CoherenceReport.status != "CRITICAL_FAILURE"
     Governor -> Governor : BRC-COH-005 Detect Circular Dependency
  Governor -> Observations : IncoherenceDetectedEvent
  Observations -> Observations : Register Incoherence

  Governor -> Governor : BRC-COH-006 Auto-Resolve Stale Reference
  Governor -> Observations : ResolutionProposedEvent
  Observations -> Observations : Propose Resolution

  Governor -> Governor : BRC-COH-007 Apply Graph Sync
  Governor -> Observations : GraphSyncAppliedEvent
  Observations -> Observations : Update Graph

  Governor -> Governor : BRC-COH-008 Auto-Define Missing Sensor
  Governor -> Operations : SensorAutoDefinedEvent
  Operations -> Operations : Deploy Sensor Config

  Governor -> Governor : BRC-COH-009 Deprecate Unused Sensor
  Governor -> Operations : SensorDeprecatedEvent
  Operations -> Operations : Remove Sensor Config
  end

  alt CoherenceRequest.phase == "FEASIBILITY"
    Governor -> Governor : BRC-COH-010 Request Feasibility Checks
    Governor -> Observations : FeasibilityAssessmentRequestedEvent
    Observations -> Observations : Assess Feasibility

    Governor -> Governor : BRC-COH-011 Aggregate Feasibility Reports

    Governor -> Observations : FeasibilityAggregatedEvent
    Observations -> Observations : Aggregate Feasibility (FeasibilityAggregated)
  end
end

group ADMISSION (BRC-COH-012..018; reuses 005..009)
  note over Governor
    In ADMISSION phase, Coherence also executes controls 005..009 before 012..018.
  end note

  alt CoherenceRequestEvent.phase == "ADMISSION"
  
    Governor -> Governor : BRC-COH-012 Validate DefinitionBundle
    Governor -> Observations : DefinitionBundleValidationReportEvent
    Observations -> Observations : Log Validation (DefinitionBundleValidationReport)

    Governor -> Governor : BRC-COH-012A Request Supervisor Admission Checks
    Governor -> Supervisor : SupervisorCheckRequestEvent (ADMISSION checkSet)
    
    Supervisor -> Supervisor : BRC-SUP-COH-013 Generate Coherence Report
    Supervisor --> Governor : CoherenceReportEvent

    Governor -> Governor : BRC-COH-013 Policy & Rule Static Analysis
    Governor -> Observations : PolicyAndRuleStaticAnalysisReportEvent
    Observations -> Observations : Log Static Analysis (PolicyAndRuleStaticAnalysisReport)

    Governor -> Governor : BRC-COH-014 Constraint Satisfiability Checking
    Governor -> Observations : ConstraintSatisfiabilityReportEvent
    Observations -> Observations : Log SAT Result (ConstraintSatisfiabilityReport)

    Governor -> Governor : BRC-COH-015 Execute Definition Test Suite
    Governor -> Observations : DefinitionTestSuiteReportEvent
    Observations -> Observations : Log Test Results (DefinitionTestSuiteReport)

    Governor -> Governor : BRC-COH-016 Admission Gate Decision
    Governor -> Supervisor : AdmissionGateDecisionEvent (trigger for Provisioning)
    Governor -> Observations : AdmissionGateDecisionEvent (Audit)
    Observations -> Observations : Audit Decision (AdmissionGateDecision)

    alt AdmissionGateDecisionEvent.outcome == "PASS"
      note over Governor
        Admission gate computed PASS.
      end note
    else AdmissionGateDecisionEvent.outcome == "FAIL"
      note over Governor
        Admission gate computed FAIL.
      end note
    else AdmissionGateDecisionEvent.outcome == "NEEDS_REVIEW"
      Governor -> DecisionOwner : DecisionRequestEvent (manual review; may be mediated by Event Bus)
      DecisionOwner --> Governor : DecisionResponseEvent (may be mediated by Event Bus)
    end

    Governor -> Governor : BRC-COH-017 Record Governance Decision
    Governor -> Observations : GovernanceDecisionRecordedEvent
    Observations -> Observations : Archive Decision Record (GovernanceDecisionRecorded)

    Governor -> Governor : BRC-COH-018 Controlled Activation Plan
    Governor -> Operator : ControlledActivationPlanEvent (instruction to Operator)
    Governor -> Operations : INT-GOV-INF-005 GrantAuthorization (ActivationPlan)
    note right: Payload: EA-GOV-INF-005 AuthorizationResponseEvent
    
    Operations -> Operations : Execute Activation Plan (ControlledActivationPlan)

    alt Activation Success
        Operations -> Governor : OperationFeedbackEvent (Status=SUCCESS)
    else Activation Failure
        Operations -> Governor : OperationFeedbackEvent (Status=FAILURE)
        Governor -> Governor : Handle Activation Failure
    end
  end
end

== 4) Emergence (Governor; BRC-EMG-001..007) ==
note over Governor
  Trigger: ObservationSignal (EmergenceTrigger) arrives.
end note

Governor -> Governor : BRC-EMG-001 Open Emergence Case
Governor -> Observations : EmergenceCaseOpenedEvent
Observations -> Observations : Open Tracking Case

alt EmergenceTriggerEvent.proposal.confidence >= 0.7
  Governor -> Governor : BRC-EMG-004 Auto-Approve High Confidence
  Governor -> Observations : EmergenceApprovedEvent
  Observations -> Observations : Log Approval

  Governor -> Governor : BRC-EMG-NEW Request Admission Check
  Governor -> Governor : CoherenceRequestEvent(phase=ADMISSION)
  
  alt AdmissionGateDecisionEvent.outcome == "PASS"
    Governor -> Governor : BRC-EMG-003 Publish New Definitions
    
    Governor -> Operator : DefinitionChangedEvent
    
    Governor -> Operations : INT-GOV-INF-001 AssignMechanism (Update Definitions)
    note right: Payload: EA-GOV-INF-001 (PROVISION/UPDATE)
    
    Operations -> Operations : Update Runtime Definitions (DefinitionChanged)

    alt Runtime Update Success
       Operations -> Governor : OperationFeedbackEvent (Status=SUCCESS)
    else Runtime Update Failure
       Operations -> Governor : OperationFeedbackEvent (Status=FAILURE)
       Governor -> Governor : Handle Update Failure
    end

    Governor -> Governor : BRC-EMG-006 Deprecate Before Create
    Governor -> Operations : INT-GOV-INF-001 AssignMechanism (Deprecate)
    
    Operations -> Operations : Manage Lifecycle (PrimitiveDeprecateAndCreate)
  else
    note over Governor
       Admission Check Failed (Block Publication)
    end
  end
else EmergenceTriggerEvent.proposal.confidence < 0.7
  loop while DecisionResponseEvent.received == false
    Governor -> Governor : BRC-EMG-002 Request Decision
    Governor -> DecisionOwner : DecisionRequestEvent (may be mediated by Event Bus)

    Governor -> Governor : BRC-EMG-005 Escalate Low Confidence
    Governor -> DecisionOwner : ApprovalRequiredEvent (may be mediated by Event Bus)

    DecisionOwner --> Governor : DecisionResponseEvent (may be mediated by Event Bus)
  end

  alt DecisionResponseEvent.outcome == "APPROVED"
    Governor -> Governor : BRC-EMG-003 Publish New Definitions
    
    Governor -> Operator : DefinitionChangedEvent
    Governor -> Operations : INT-GOV-INF-001 AssignMechanism (Update Definitions)
    Operations -> Operations : Update Runtime Definitions (DefinitionChanged)

    Governor -> Governor : BRC-EMG-006 Deprecate Before Create
    Governor -> Operations : INT-GOV-INF-001 AssignMechanism (Deprecate)
    Operations -> Operations : Manage Lifecycle (PrimitiveDeprecateAndCreate)
  else (not approved)
    note over Governor
      Decision did not approve; no definition publication.
    end note
  end
end

Governor -> Governor : BRC-EMG-007 Close Emergence Case
Governor -> Observations : EmergenceCaseClosedEvent
Observations -> Observations : Close Tracking Case

== 5) Close the loop ==
note over Observations, Operations
  Outcomes of Operations (Actuation) and Observations (Evidence) re-enter the Definition Plane
  as new triggers, completing the Systemic Governance Loop.
end note

@enduml