@startuml sie-adaptation-sequence-v1

' ============================================================
' VISUAL THEME
' ============================================================

skinparam shadowing false
skinparam roundcorner 12
skinparam ArrowColor #57606A
skinparam DefaultFontName "SansSerif"
skinparam backgroundColor #FFFFFF

skinparam sequence {
  ParticipantBackgroundColor #FFFFFF
  ParticipantBorderColor #57606A
  LifeLineBackgroundColor #F6F8FA
  LifeLineBorderColor #57606A
  ArrowColor #57606A
  DividerBackgroundColor #F6F8FA
}

skinparam noteBackgroundColor #FFF8C5
skinparam noteBorderColor #57606A

title SIE - Adaptation (instance-aligned BehavioralRule / Controls) - v1

autonumber

participant "Event Bus" as Bus
participant "SUP-ADP-001\nSupervisor (Adaptation)" as SUP_ADP_001

note over SUP_ADP_001
  This sequence is derived from:
  - governance-instances/sie-adaptation-governance-instances-v1.puml
  - BR-ADP-001.controlSequence = [BRC_ADP_001, BRC_ADP_002]

  Rendering rules (per your constraints):
  - No lifelines for receptors/effectors/events/state objects/BehavioralRule/controls.
  - Each BRC is a self-call on the owning controller lifeline.
end note

group Trigger
  Bus -> SUP_ADP_001 : deliver MismatchAssessmentEvent
end group

alt MismatchAssessmentEvent.diagnosisNeeded == true
  loop while MismatchAssessmentEvent.repeatDiagnosis == true
    SUP_ADP_001 -> SUP_ADP_001 : BRC-ADP-001 Diagnose Control Performance
    SUP_ADP_001 -> Bus : publish BehavioralRuleCandidateEvent
  end
else (no diagnosis)
  note over SUP_ADP_001
    BRC-ADP-001 not applicable.
  end note
end

alt MismatchAssessmentEvent.candidateRuleStatus == "PUBLISHED"
  loop while MismatchAssessmentEvent.waitingForRealization == true
    SUP_ADP_001 -> SUP_ADP_001 : BRC-ADP-002 Provision New Operator Definition
    SUP_ADP_001 -> Bus : publish OperatorProvisioningEvent
  end
else (candidate not published)
  note over SUP_ADP_001
    BRC-ADP-002 not applicable.
  end note
end

@enduml
