@startuml sie-emergence-sequence-v1

' ============================================================
' VISUAL THEME
' ============================================================

skinparam shadowing false
skinparam roundcorner 12
skinparam ArrowColor #57606A
skinparam DefaultFontName "SansSerif"
skinparam backgroundColor #FFFFFF

skinparam sequence {
  ParticipantBackgroundColor #FFFFFF
  ParticipantBorderColor #57606A
  LifeLineBackgroundColor #F6F8FA
  LifeLineBorderColor #57606A
  ArrowColor #57606A
  DividerBackgroundColor #F6F8FA
}

skinparam noteBackgroundColor #FFF8C5
skinparam noteBorderColor #57606A

title SIE - Emergence (instance-aligned BehavioralRule / Controls) - v1

autonumber

actor "Decision Owner" as DecisionOwner

participant "Event Bus" as Bus
participant "GOV-EMG-001\nGovernor (Emergence)" as GOV_EMG_001

note over GOV_EMG_001
  This sequence is derived from:
  - governance-instances/sie-emergence-governance-instances-v1.puml
  - BR-EMG-001.controlSequence = [BRC_EMG_001..BRC_EMG_007]

  `alt` / `loop` fragments correspond to the controls’ CSDSL:
  - high vs low confidence split at 0.7
  - decision request loops while DecisionResponseReceptor.received == false

  Rendering rules (per your constraints):
  - No lifelines for receptors/effectors/events/state objects/BehavioralRule/controls.
  - Each BRC is a self-call on the owning controller lifeline.
end note

group Trigger
  Bus -> GOV_EMG_001 : deliver EmergenceTriggerEvent
end group

GOV_EMG_001 -> GOV_EMG_001 : BRC-EMG-001 Open Emergence Case
GOV_EMG_001 -> Bus : publish EmergenceCaseOpenedEvent

alt EmergenceTriggerEvent.proposal.confidence >= 0.7
  GOV_EMG_001 -> GOV_EMG_001 : BRC-EMG-004 Auto-Approve High Confidence
  GOV_EMG_001 -> Bus : publish EmergenceApprovedEvent

  GOV_EMG_001 -> GOV_EMG_001 : BRC-EMG-003 Publish New Definitions
  GOV_EMG_001 -> Bus : publish DefinitionChangedEvent

  GOV_EMG_001 -> GOV_EMG_001 : BRC-EMG-006 Deprecate Before Create
  GOV_EMG_001 -> Bus : publish PrimitiveDeprecateAndCreateEvent
else EmergenceTriggerEvent.proposal.confidence < 0.7
  loop while DecisionResponseEvent.received == false
    GOV_EMG_001 -> GOV_EMG_001 : BRC-EMG-002 Request Decision
    GOV_EMG_001 -> Bus : publish DecisionRequestEvent
    Bus -> DecisionOwner : deliver DecisionRequestEvent

    GOV_EMG_001 -> GOV_EMG_001 : BRC-EMG-005 Escalate Low Confidence
    GOV_EMG_001 -> Bus : publish ApprovalRequiredEvent
    Bus -> DecisionOwner : deliver ApprovalRequiredEvent

    DecisionOwner -> Bus : publish DecisionResponseEvent
    Bus -> GOV_EMG_001 : deliver DecisionResponseEvent
  end

  alt DecisionResponseEvent.outcome == "APPROVED"
    GOV_EMG_001 -> GOV_EMG_001 : BRC-EMG-003 Publish New Definitions
    GOV_EMG_001 -> Bus : publish DefinitionChangedEvent

    GOV_EMG_001 -> GOV_EMG_001 : BRC-EMG-006 Deprecate Before Create
    GOV_EMG_001 -> Bus : publish PrimitiveDeprecateAndCreateEvent
  else (not approved)
    note over GOV_EMG_001
      Decision did not approve; no definition publication.
    end note
  end
end

GOV_EMG_001 -> GOV_EMG_001 : BRC-EMG-007 Close Emergence Case
GOV_EMG_001 -> Bus : publish EmergenceCaseClosedEvent

@enduml

