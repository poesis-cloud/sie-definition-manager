{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "sie://schemas/csdm/v1/ConstraintConflict.json",
  "title": "ConstraintConflict (CSDM v1)",
  "description": "Represents a detected coherence issue between constraints (conflict, drift, scope overlap, etc).",
  "type": "object",
  "required": ["id", "assessmentType", "involvedPrimitives", "severity", "description"],
  "properties": {
    "id": { "$ref": "sie://schemas/csdm/v1/common.json#/definitions/UUID" },
    "assessmentType": {
      "type": "string",
      "enum": ["conflict", "orphan", "cycle", "drift", "staleness", "semantic_drift", "scope_overlap"]
    },
    "involvedPrimitives": {
      "type": "array",
      "items": { "$ref": "sie://schemas/csdm/v1/common.json#/definitions/UUID" }
    },
    "severity": { "type": "string", "enum": ["info", "warning", "critical"] },
    "description": { "type": "string" },
    "proposedResolution": { "type": ["object", "null"] }
  }
}
