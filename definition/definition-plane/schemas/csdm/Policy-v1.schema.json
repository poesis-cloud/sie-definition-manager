{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "sie://schemas/csdm/v1/Policy.json",
  "title": "Policy (CSDM v1)",
  "description": "Measurable normative regulatory constraint over a system definition. Guard and constraint are CSDSL expressions.",
  "allOf": [
    { "$ref": "sie://schemas/csdm/v1/SystemicPrimitive.json" }
  ],
  "type": "object",
  "required": ["name", "status", "applicabilityConditions", "constraint"],
  "properties": {
    "name": { "$ref": "sie://schemas/csdm/v1/common.json#/definitions/Name80" },
    "status": { "$ref": "sie://schemas/csdm/v1/PolicyStatus.json" },
    "applicabilityConditions": { "$ref": "sie://schemas/csdsl/v1/Expression.json#/definitions/LogicalExpression" },
    "constraint": { "$ref": "sie://schemas/csdsl/v1/Expression.json#/definitions/ConstraintExpression" }
  }
}
