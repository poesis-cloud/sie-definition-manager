{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "sie://schemas/events/v1/DefinitionBundleValidationReportEvent.json",
  "title": "DefinitionBundleValidationReportEvent (Events v1)",
  "description": "Report produced by Coherence admission gates after validating a candidate definition bundle (integrity/schema/invariant checks).",
  "type": "object",
  "additionalProperties": false,
  "required": ["scope", "validationStatus", "validatedAt"],
  "properties": {
    "scope": {
      "description": "Opaque scope selector for governance workflows.",
      "type": "object",
      "additionalProperties": true
    },
    "validationStatus": {
      "type": "string",
      "enum": ["PASS", "FAIL"]
    },
    "issues": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["code", "message", "severity"],
        "properties": {
          "code": { "type": "string" },
          "message": { "type": "string" },
          "severity": { "type": "string", "enum": ["INFO", "WARN", "ERROR"] }
        }
      }
    },
    "validatedAt": { "$ref": "sie://schemas/csdm/v1/common.json#/definitions/DateTime" },
    "definitionBundleDigest": { "type": ["string", "null"] }
  }
}
