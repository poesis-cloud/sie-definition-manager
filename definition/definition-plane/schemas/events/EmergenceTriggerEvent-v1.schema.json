{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "sie://schemas/events/v1/EmergenceTriggerEvent.json",
  "title": "EmergenceTriggerEvent (Events v1)",
  "description": "Trigger to open an emergence case (new primitives/constraints).",
  "type": "object",
  "additionalProperties": false,
  "required": ["triggerType", "scope", "proposal", "evidencePointers"],
  "properties": {
    "triggerType": { "type": "string" },
    "scope": {
      "description": "Opaque scope selector for governance workflows.",
      "type": "object",
      "additionalProperties": true
    },
    "proposal": {
      "type": "object",
      "additionalProperties": true
    },
    "evidencePointers": {
      "description": "URI references.",
      "type": "array",
      "items": { "type": "string" }
    },
    "definitionBundle": {
      "type": ["object", "null"],
      "additionalProperties": true
    },
    "targetId": {
      "type": ["string", "null"],
      "format": "uuid"
    }
  }
}
