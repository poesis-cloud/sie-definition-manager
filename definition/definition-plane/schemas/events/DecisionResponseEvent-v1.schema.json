{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "sie://schemas/events/v1/DecisionResponseEvent.json",
  "title": "DecisionResponseEvent (Events v1)",
  "description": "Decision Owner response consumed by governance.",
  "type": "object",
  "additionalProperties": false,
  "required": ["decision", "respondedAt"],
  "properties": {
    "decision": {
      "type": "string",
      "enum": ["APPROVED", "REJECTED", "REQUEST_CHANGES"]
    },
    "rationale": {
      "type": ["string", "null"]
    },
    "respondedAt": { "$ref": "sie://schemas/csdm/v1/common.json#/definitions/DateTime" },
    "decisionPayload": {
      "type": ["object", "null"],
      "additionalProperties": true
    }
  }
}
