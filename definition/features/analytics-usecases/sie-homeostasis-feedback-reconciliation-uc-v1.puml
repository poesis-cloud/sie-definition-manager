@startuml sie-homeostasis-feedback-reconciliation-uc-v1

' ============================================================
' VISUAL THEME
' ============================================================

left to right direction
skinparam shadowing false
skinparam roundcorner 12
skinparam ArrowColor #57606A
skinparam DefaultFontName "SansSerif"
skinparam backgroundColor #FFFFFF

skinparam actorBackgroundColor #FFFFFF
skinparam actorBorderColor #57606A

skinparam usecaseBackgroundColor #F6F8FA
skinparam usecaseBorderColor #57606A

skinparam rectangleBackgroundColor #FFFFFF
skinparam rectangleBorderColor #57606A

skinparam noteBackgroundColor #FFF8C5
skinparam noteBorderColor #57606A

' ============================================================

title UC - Homeostasis: Feedback Reconciliation - v1

note as FeasibilityNote
  **SAFe mapping:** Epic E-6 Homeostasis (continuous drift control)
  Capability: Homeostasis Control
  Feature: Feedback Reconciliation

  **Definition-plane intent**
  Close the loop by consuming actuation outcomes and reconciling them into
  updated drift status and (when needed) Definition-plane adjustments.
end note

' ============================================================
' ACTORS
' ============================================================

actor "SRE Engineer" as SRE
actor "Incident Commander" as IncidentCmd

actor "Actuation Orchestrator" as Orchestrator <<system>>
actor "Evidence Store" as EvidenceStore <<system>>
actor "Decision Log" as DecisionLog <<system>>

' ============================================================
' USE CASES
' ============================================================

rectangle "Homeostasis Control" {
  usecase "Ingest Actuation\nFeedback" as UC_IngestFeedback
  usecase "Update Drift Status\n(Post-Actuation)" as UC_UpdateStatus
  usecase "Trigger Follow-up\nGovernance if Unresolved" as UC_Followup
  usecase "Record Feedback\nEvidence" as UC_RecordFeedback
}

' ============================================================
' RELATIONSHIPS
' ============================================================

SRE --> UC_IngestFeedback
SRE --> UC_UpdateStatus
IncidentCmd --> UC_Followup

UC_IngestFeedback --> Orchestrator
UC_RecordFeedback --> EvidenceStore
UC_RecordFeedback --> DecisionLog

@enduml
