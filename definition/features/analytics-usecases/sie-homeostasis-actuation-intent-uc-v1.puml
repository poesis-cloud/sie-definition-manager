@startuml sie-homeostasis-actuation-intent-uc-v1

' ============================================================
' VISUAL THEME
' ============================================================

left to right direction
skinparam shadowing false
skinparam roundcorner 12
skinparam ArrowColor #57606A
skinparam DefaultFontName "SansSerif"
skinparam backgroundColor #FFFFFF

skinparam actorBackgroundColor #FFFFFF
skinparam actorBorderColor #57606A

skinparam usecaseBackgroundColor #F6F8FA
skinparam usecaseBorderColor #57606A

skinparam rectangleBackgroundColor #FFFFFF
skinparam rectangleBorderColor #57606A

skinparam noteBackgroundColor #FFF8C5
skinparam noteBorderColor #57606A

' ============================================================

title UC - Homeostasis: Safe Actuation Intent - v1

note as FeasibilityNote
  **SAFe mapping:** Epic E-6 Homeostasis (continuous drift control)
  Capability: Homeostasis Control
  Feature: Actuation Intent (safe)

  **Definition-plane intent**
  Produce an actuation intent package (what should change, why, constraints)
  and route it through safety gates (eligibility + approvals) before
  remediation realization.
end note

' ============================================================
' ACTORS
' ============================================================

actor "SRE Engineer" as SRE
actor "Operations Manager" as OpsMgr
actor "Security Officer" as SecOfficer

actor "Approval Gate" as ApprovalGate <<system>>
actor "Actuation Orchestrator" as Orchestrator <<system>>
actor "Decision Log" as DecisionLog <<system>>

' ============================================================
' USE CASES
' ============================================================

rectangle "Homeostasis Control" {
  usecase "Draft Actuation\nIntent" as UC_DraftIntent
  usecase "Check Automation\nEligibility" as UC_Eligibility
  usecase "Request / Record\nApproval" as UC_Approval
  usecase "Publish Actuation\nIntent" as UC_PublishIntent
}

' ============================================================
' RELATIONSHIPS
' ============================================================

SRE --> UC_DraftIntent
SRE --> UC_PublishIntent
OpsMgr --> UC_Approval
SecOfficer --> UC_Eligibility

UC_Eligibility --> ApprovalGate
UC_Approval --> ApprovalGate
UC_DraftIntent --> DecisionLog
UC_PublishIntent --> Orchestrator

@enduml
