@startuml sie-assurance-safety-uc-v1

' ============================================================
' VISUAL THEME
' ============================================================

left to right direction
skinparam shadowing false
skinparam roundcorner 12
skinparam ArrowColor #57606A
skinparam DefaultFontName "SansSerif"
skinparam backgroundColor #FFFFFF

skinparam actorBackgroundColor #FFFFFF
skinparam actorBorderColor #57606A

skinparam usecaseBackgroundColor #F6F8FA
skinparam usecaseBorderColor #57606A

skinparam rectangleBackgroundColor #FFFFFF
skinparam rectangleBorderColor #57606A

skinparam noteBackgroundColor #FFF8C5
skinparam noteBorderColor #57606A

' ============================================================

title UC - SIE Assurance & Safety - v1

note as FeasibilityNote
  **SAFe mapping:** Epic E-4 Safe Remediation Automation
  Capability: Assurance & Safety
  Feature: Assurance & Safety (cross-cutting feature set)

  **Plane ownership:** Cross-cutting (all planes), anchored in Definition-plane gating.

  **Requires capabilities:** Provenance+Lineage, LLM Output Assurance,
  Formal Methods, Automation Guardrails, Security+Access.

  **Hard dependencies:** decision log, trace store, SMT, orchestrator.

  **Feasibility tier:** NOW
  as policy/contract definitions; enforcement expands as integrations mature.
end note

' ============================================================
' ACTORS
' ============================================================

actor "Governance Officer" as GovOfficer
actor "Security Officer" as SecOfficer
actor "Auditor" as Auditor
actor "SRE Engineer" as SRE
actor "Policy Author" as PolicyAuthor

actor "Decision Log" as DecisionLog <<system>>
actor "Trace Store" as TraceStore <<system>>
actor "SMT Solver" as SMT <<system>>
actor "LLM Service" as LLM <<system>>
actor "Actuation Orchestrator" as Orchestrator <<system>>

' ============================================================
' USE CASES
' ============================================================

rectangle "Assurance & Safety" {

  package "Provenance & Lineage" {
    usecase "Link Decision -> Constraint\nVersion -> Evidence" as UC_Lineage
    usecase "Enable Deterministic\nReplay" as UC_Replay
  }

  package "Uncertainty & Confidence" {
    usecase "Record Confidence\nfor Outputs" as UC_RecordConfidence
    usecase "Calibrate Automation\nThresholds" as UC_Calibrate
  }

  package "LLM Output Assurance" {
    usecase "Validate Generated\nCSDSL Against Types" as UC_TypeValidate
    usecase "Prove/Refute Constraint\nCoherence (SMT)" as UC_ProveCoherence
    usecase "Record Prompt + Retrieval\nProvenance" as UC_PromptProv
  }

  package "Automation Guardrails" {
    usecase "Gate Actuation by\nEligibility Policy" as UC_GateActuation
    usecase "Enforce Blast Radius\nLimits" as UC_BlastLimits
    usecase "Require Human Approval\nfor High Risk" as UC_HumanGate
    usecase "Rollback and\nPost-Action Verification" as UC_RollbackVerify
  }
}

' ============================================================
' RELATIONSHIPS - Actors
' ============================================================

GovOfficer --> UC_Calibrate
GovOfficer --> UC_GateActuation
PolicyAuthor --> UC_TypeValidate
PolicyAuthor --> UC_ProveCoherence

SecOfficer --> UC_HumanGate
SecOfficer --> UC_BlastLimits
SRE --> UC_RollbackVerify
Auditor --> UC_Lineage
Auditor --> UC_PromptProv

' ============================================================
' RELATIONSHIPS - Systems
' ============================================================

UC_Lineage --> DecisionLog
UC_Replay --> TraceStore
UC_RecordConfidence --> DecisionLog
UC_Calibrate --> DecisionLog

UC_TypeValidate --> LLM
UC_ProveCoherence --> SMT
UC_PromptProv --> DecisionLog

UC_GateActuation --> Orchestrator
UC_BlastLimits --> Orchestrator
UC_HumanGate --> Orchestrator
UC_RollbackVerify --> Orchestrator

' ============================================================
' NOTES
' ============================================================

note right of UC_GateActuation
  Ensures closed-loop coherence:
  analytics outputs are not “actions”
  until compiled into Definition-plane
  deliverables and validated.
end note

note right of UC_ProveCoherence
  If LLM proposes constraints,
  SMT verification is required to
  prevent silent incoherence.
end note

@enduml
