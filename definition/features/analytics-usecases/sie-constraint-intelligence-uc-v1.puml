@startuml sie-constraint-intelligence-uc-v1

' ============================================================
' VISUAL THEME
' ============================================================

left to right direction
skinparam shadowing false
skinparam roundcorner 12
skinparam ArrowColor #57606A
skinparam DefaultFontName "SansSerif"
skinparam backgroundColor #FFFFFF

skinparam actorBackgroundColor #FFFFFF
skinparam actorBorderColor #57606A

skinparam usecaseBackgroundColor #F6F8FA
skinparam usecaseBorderColor #57606A

skinparam rectangleBackgroundColor #FFFFFF
skinparam rectangleBorderColor #57606A

skinparam noteBackgroundColor #FFF8C5
skinparam noteBorderColor #57606A

' ============================================================

title UC - SIE Constraint Intelligence - v1

note as FeasibilityNote
  **SAFe mapping:** Epic E-3 Policy & Constraint Evolution (coherent definitions)
  Capability: Constraint Intelligence
  Feature: Constraint Intelligence

  **Plane ownership:** Definition plane (constraint/rule synthesis + coherence);
  consumes Description-plane evidence for gap/coverage.

  **Requires capabilities:** CSDSL Runtime, Formal Methods (SMT), Semantic Intelligence,
  Versioning+Provenance, Evidence+State substrate.

  **Hard dependencies:** SMT solver, LLM, CSDM repo.

  **Feasibility tier:** NEXT
  (formal verification + synthesis is the gating complexity).
end note

' ============================================================
' ACTORS
' ============================================================

actor "Policy Author" as PolicyAuthor
actor "System Architect" as Architect
actor "Governance Officer" as GovOfficer
actor "Security Officer" as SecOfficer
actor "Quality Engineer" as QE

actor "CSDSL Engine" as CsdslEngine <<system>>
actor "LLM Service" as LLM <<system>>
actor "SMT Solver" as SMT <<system>>
actor "CSDM Repository" as CsdmRepo <<system>>

' ============================================================
' USE CASES
' ============================================================

rectangle "Constraint Intelligence" {

  ' --- Constraint Synthesis ---
  package "Constraint Synthesis" {
    usecase "Translate NL Policy\nto CSDSL" as UC_NLToCsdsl
    usecase "Infer Constraints from\nGood Behavior" as UC_InferFromBehavior
    usecase "Generate Constraint\nVariants" as UC_GenerateVariants
    usecase "Propose Gap-Closing\nConstraints" as UC_ProposeClosing
  }

  ' --- Gap Analysis ---
  package "Gap Analysis" {
    usecase "Detect Unconstrained\nCritical Paths" as UC_UnconstrainedPaths
    usecase "Identify Missing\nQA Coverage" as UC_MissingQA
    usecase "Flag Orphan\nComponents" as UC_OrphanComponents
    usecase "Recommend Additional\nConstraints" as UC_RecommendConstraints
  }

  ' --- Conflict Detection ---
  package "Conflict Detection" {
    usecase "Detect Logical\nContradictions" as UC_LogicalConflicts
    usecase "Identify Resource\nCompetition" as UC_ResourceCompetition
    usecase "Flag Priority\nConflicts" as UC_PriorityConflicts
    usecase "Suggest Conflict\nResolution" as UC_ConflictResolution
  }

  ' --- Coherence Validation ---
  package "Coherence Validation" {
    usecase "Check Semantic\nConsistency" as UC_SemanticConsistency
    usecase "Validate Organizational\nAlignment" as UC_OrgAlignment
    usecase "Ensure Objective\nSupport" as UC_ObjectiveSupport
    usecase "Detect Misaligned\nEvolution" as UC_MisalignedEvolution
  }

  ' --- Coverage Analysis ---
  package "Coverage Analysis" {
    usecase "Calculate Component\nGovernance %" as UC_GovPercentage
    usecase "Measure QA Category\nCoverage" as UC_QACoverage
    usecase "Identify Coverage Gaps\nby Criticality" as UC_CriticalityGaps
    usecase "Track Coverage\nImprovement" as UC_CoverageTracking
  }
}

' ============================================================
' RELATIONSHIPS - Actors to Use Cases
' ============================================================

' Policy Author interactions
PolicyAuthor --> UC_NLToCsdsl
PolicyAuthor --> UC_GenerateVariants
PolicyAuthor --> UC_ConflictResolution
PolicyAuthor --> UC_RecommendConstraints

' Architect interactions
Architect --> UC_UnconstrainedPaths
Architect --> UC_InferFromBehavior
Architect --> UC_SemanticConsistency
Architect --> UC_MisalignedEvolution

' Governance Officer interactions
GovOfficer --> UC_OrgAlignment
GovOfficer --> UC_ObjectiveSupport
GovOfficer --> UC_GovPercentage
GovOfficer --> UC_CoverageTracking

' Security Officer interactions
SecOfficer --> UC_MissingQA
SecOfficer --> UC_OrphanComponents
SecOfficer --> UC_LogicalConflicts
SecOfficer --> UC_CriticalityGaps

' Quality Engineer interactions
QE --> UC_ProposeClosing
QE --> UC_QACoverage
QE --> UC_ResourceCompetition
QE --> UC_PriorityConflicts

' ============================================================
' RELATIONSHIPS - System Actors
' ============================================================

UC_NLToCsdsl --> LLM
UC_NLToCsdsl --> CsdslEngine
UC_InferFromBehavior --> LLM
UC_GenerateVariants --> LLM
UC_ProposeClosing --> LLM

UC_UnconstrainedPaths --> CsdmRepo
UC_MissingQA --> CsdmRepo
UC_OrphanComponents --> CsdmRepo
UC_RecommendConstraints --> LLM

UC_LogicalConflicts --> SMT
UC_ResourceCompetition --> CsdslEngine
UC_PriorityConflicts --> CsdmRepo
UC_ConflictResolution --> LLM

UC_SemanticConsistency --> LLM
UC_OrgAlignment --> CsdmRepo
UC_ObjectiveSupport --> CsdmRepo
UC_MisalignedEvolution --> CsdmRepo

UC_GovPercentage --> CsdmRepo
UC_QACoverage --> CsdmRepo
UC_CriticalityGaps --> CsdmRepo
UC_CoverageTracking --> CsdmRepo

' ============================================================
' RELATIONSHIPS - Include/Extend
' ============================================================

UC_NLToCsdsl ..> UC_LogicalConflicts : <<extend>>
UC_ProposeClosing ..> UC_UnconstrainedPaths : <<include>>
UC_ConflictResolution ..> UC_LogicalConflicts : <<include>>
UC_RecommendConstraints ..> UC_MissingQA : <<include>>
UC_CoverageTracking ..> UC_GovPercentage : <<include>>

' ============================================================
' NOTES
' ============================================================

note right of UC_NLToCsdsl
  **NL to CSDSL Example:**
  
  Input: "APIs must respond
  within 200ms for 99% of requests"
  
  Output:
  `threshold(latency.p99, "<", 200ms)`
  
  Validates syntax and semantics
end note

note right of UC_LogicalConflicts
  **Conflict Example:**
  
  Policy A: "All data must be encrypted"
  Policy B: "Debug logs must be readable"
  
  Conflict: Debug logs with sensitive
  data cannot satisfy both
  
  Uses SMT solver for formal verification
end note

note right of UC_GovPercentage
  **Coverage Metrics:**
  
  - Components governed: 87%
  - Security constraints: 94%
  - Performance constraints: 72%
  - Data constraints: 81%
  
  Target: 95% for tier-1 components
end note

note right of UC_InferFromBehavior
  Observes production behavior:
  - Response time patterns
  - Resource usage norms
  - Error rate baselines
  
  Proposes constraints that codify
  observed "good" behavior
end note

@enduml
