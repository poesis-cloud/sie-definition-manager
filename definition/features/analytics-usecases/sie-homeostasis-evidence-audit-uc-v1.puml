@startuml sie-homeostasis-evidence-audit-uc-v1

' ============================================================
' VISUAL THEME
' ============================================================

left to right direction
skinparam shadowing false
skinparam roundcorner 12
skinparam ArrowColor #57606A
skinparam DefaultFontName "SansSerif"
skinparam backgroundColor #FFFFFF

skinparam actorBackgroundColor #FFFFFF
skinparam actorBorderColor #57606A

skinparam usecaseBackgroundColor #F6F8FA
skinparam usecaseBorderColor #57606A

skinparam rectangleBackgroundColor #FFFFFF
skinparam rectangleBorderColor #57606A

skinparam noteBackgroundColor #FFF8C5
skinparam noteBorderColor #57606A

' ============================================================

title UC - Homeostasis: Evidence & Audit - v1

note as FeasibilityNote
  **SAFe mapping:** Epic E-6 Homeostasis (continuous drift control)
  Capability: Homeostasis Control
  Feature: Evidence & Audit (homeostasis)

  **Intent**
  Ensure homeostasis decisions are auditable and reproducible:
  evidence retention/minimization rules, replayable inputs, and trace.
end note

' ============================================================
' ACTORS
' ============================================================

actor "Compliance Officer" as CompOfficer
actor "Auditor" as Auditor
actor "SRE Engineer" as SRE

actor "Evidence Store" as EvidenceStore <<system>>
actor "Trace Store" as TraceStore <<system>>
actor "Decision Log" as DecisionLog <<system>>

' ============================================================
' USE CASES
' ============================================================

rectangle "Homeostasis Control" {
  usecase "Retain Evidence\nUnder Policy" as UC_Retention
  usecase "Minimize / Redact\nSensitive Fields" as UC_Minimize
  usecase "Replay Drift\nAssessment Inputs" as UC_Replay
  usecase "Produce Audit\nPackage" as UC_AuditPkg
}

' ============================================================
' RELATIONSHIPS
' ============================================================

CompOfficer --> UC_Retention
CompOfficer --> UC_Minimize
Auditor --> UC_AuditPkg
SRE --> UC_Replay

UC_Retention --> EvidenceStore
UC_Minimize --> EvidenceStore
UC_Replay --> TraceStore
UC_AuditPkg --> DecisionLog

@enduml
