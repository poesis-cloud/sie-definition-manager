@startuml sie-homeostasis-drift-assessment-uc-v1

' ============================================================
' VISUAL THEME
' ============================================================

left to right direction
skinparam shadowing false
skinparam roundcorner 12
skinparam ArrowColor #57606A
skinparam DefaultFontName "SansSerif"
skinparam backgroundColor #FFFFFF

skinparam actorBackgroundColor #FFFFFF
skinparam actorBorderColor #57606A

skinparam usecaseBackgroundColor #F6F8FA
skinparam usecaseBorderColor #57606A

skinparam rectangleBackgroundColor #FFFFFF
skinparam rectangleBorderColor #57606A

skinparam noteBackgroundColor #FFF8C5
skinparam noteBorderColor #57606A

' ============================================================

title UC - Homeostasis: Drift Assessment - v1

note as FeasibilityNote
  **SAFe mapping:** Epic E-6 Homeostasis (continuous drift control)
  Capability: Homeostasis Control
  Feature: Drift Assessment

  **Definition-plane intent**
  Assess deviation between the *desired definition* and the *observed state*,
  producing a typed drift assessment usable by Homeostasis controls.

  **Evidence requirement**
  Drift must be explainable and replayable (inputs + versions).
end note

' ============================================================
' ACTORS
' ============================================================

actor "Policy Author" as PolicyAuthor
actor "SRE Engineer" as SRE
actor "Compliance Officer" as CompOfficer

actor "Evidence Store" as EvidenceStore <<system>>
actor "Evaluation Engine" as EvalEngine <<system>>
actor "Decision Log" as DecisionLog <<system>>

' ============================================================
' USE CASES
' ============================================================

rectangle "Homeostasis Control" {
  usecase "Ingest Measured\nState Evidence" as UC_IngestEvidence
  usecase "Compare to Desired\nDefinition" as UC_Compare
  usecase "Compute Drift Severity\n+ Scope" as UC_ComputeDrift
  usecase "Record Drift Evidence\n+ Rationale" as UC_Record
}

' ============================================================
' RELATIONSHIPS
' ============================================================

SRE --> UC_IngestEvidence
SRE --> UC_ComputeDrift
PolicyAuthor --> UC_Compare
CompOfficer --> UC_Record

UC_IngestEvidence --> EvidenceStore
UC_Compare --> EvalEngine
UC_ComputeDrift --> EvalEngine
UC_Record --> DecisionLog

@enduml
