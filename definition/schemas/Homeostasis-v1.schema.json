{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "sie://schemas/csdm/v1/Homeostasis.json",
  "title": "Homeostasis (CSDM v1)",
  "description": "First-order regulation process: enforces constraint envelope through rule execution and actuation.",
  "allOf": [
    { "$ref": "sie://schemas/csdm/v1/SystemicPrimitive.json" }
  ],
  "type": "object",
  "required": ["id", "name", "owner"],
  "properties": {
    "id": { "$ref": "sie://schemas/csdm/v1/common.json#/definitions/UUID" },
    "name": { "$ref": "sie://schemas/csdm/v1/common.json#/definitions/Name80" },
    "operationalRules": { "type": "array", "items": { "$ref": "sie://schemas/csdm/v1/common.json#/definitions/UUID" } },
    "triggerEventArchetypes": { "type": "array", "items": { "$ref": "sie://schemas/csdm/v1/common.json#/definitions/UUID" } },
    "owner": { "$ref": "sie://schemas/csdm/v1/common.json#/definitions/UUID", "description": "Reference to Operator owning this process." }
  }
}
