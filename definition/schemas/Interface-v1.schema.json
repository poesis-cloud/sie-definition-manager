{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "sie://schemas/gsm/v1/Interface.json",
  "title": "Interface (GSM v1)",
  "description": "Interaction surface of a system or component.",
  "allOf": [
    { "$ref": "sie://schemas/gsm/v1/SystemicPrimitive.json" }
  ],
  "type": "object",
  "required": ["name"],
  "properties": {
    "name": { "$ref": "sie://schemas/gsm/v1/common.json#/definitions/Name80" },
    "receptors": { "type": "array", "items": { "$ref": "sie://schemas/gsm/v1/common.json#/definitions/UUID" } },
    "effectors": { "type": "array", "items": { "$ref": "sie://schemas/gsm/v1/common.json#/definitions/UUID" } },
    "channels": { "type": "array", "items": { "$ref": "sie://schemas/gsm/v1/common.json#/definitions/UUID" } }
  }
}
