{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "sie://schemas/gsm/v1/Receptor.json",
  "title": "Receptor (GSM v1)",
  "description": "Mechanism capability to receive events of one EventArchetype.",
  "allOf": [
    { "$ref": "sie://schemas/gsm/v1/SystemicPrimitiveDefinition.json" }
  ],
  "type": "object",
  "required": ["name", "receivedEventArchetype"],
  "properties": {
    "name": { "$ref": "sie://schemas/gsm/v1/common.json#/definitions/Name80" },
    "receivedEventArchetype": {
      "$ref": "sie://schemas/gsm/v1/common.json#/definitions/UUID",
      "description": "Reference to EventArchetype primitive received by this receptor."
    }
  }
}
