{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "sie://schemas/gsm/v1/Component.json",
  "title": "Component (GSM v1)",
  "description": "Structural substrate of a system: a functional, logical, coherent agglomerate of interacting and interfaceable mechanisms. Defines the Infrastructure layer.",
  "allOf": [
    { "$ref": "sie://schemas/gsm/v1/SystemicPrimitive.json" }
  ],
  "type": "object",
  "required": ["name"],
  "properties": {
    "name": { "$ref": "sie://schemas/gsm/v1/common.json#/definitions/Name80" },
    "mechanisms": { "type": "array", "items": { "$ref": "sie://schemas/gsm/v1/common.json#/definitions/UUID" }, "description": "Mechanisms belonging to the component." },
    "receptors": { "type": "array", "items": { "$ref": "sie://schemas/gsm/v1/common.json#/definitions/UUID" }, "description": "Receptors of the component's mechanisms." },
    "effectors": { "type": "array", "items": { "$ref": "sie://schemas/gsm/v1/common.json#/definitions/UUID" }, "description": "Effectors of the component's mechanisms." },
    "interactions": { "type": "array", "items": { "$ref": "sie://schemas/gsm/v1/common.json#/definitions/UUID" }, "description": "Interactions between mechanisms." },
    "channels": { "type": "array", "items": { "$ref": "sie://schemas/gsm/v1/common.json#/definitions/UUID" }, "description": "Channels carrying interactions through interfaces." },
    "interfaces": { "type": "array", "items": { "$ref": "sie://schemas/gsm/v1/common.json#/definitions/UUID" }, "description": "Interaction surfaces of the component." }
  }
}
