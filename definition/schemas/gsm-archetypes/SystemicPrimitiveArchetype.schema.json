{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "sie://schemas/gsm/v1/SystemicPrimitiveArchetype.json",
  "title": "SystemicPrimitiveArchetype (GSM v1)",
  "description": "Defines the structure and semantics of a systemic primitive subtype.",
  "type": "object",
  "required": ["id", "name", "schema"],
  "properties": {
    "id": { "$ref": "sie://schemas/gsm/v1/common.json#/definitions/UUID" },
    "name": { "$ref": "sie://schemas/gsm/v1/common.json#/definitions/Name80" },
    "schema": { "$ref": "sie://schemas/gsm/v1/ArchetypeSchema.json" },
    "qualifierArchetypes": {
      "type": "array",
      "items": { "$ref": "sie://schemas/gsm/v1/SystemicPrimitiveArchetypeQualifierArchetype.json" }
    }
  }
}
