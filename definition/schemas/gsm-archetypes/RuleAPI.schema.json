{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "sie://schemas/gsm/v1/RuleAPI.json",
    "title": "SIE Rule API v2 — Language-Neutral Contract",
    "description": "Machine-readable API surface for Rule sandbox environments. Language bindings (Starlark, etc.) implement this contract. Normative spec: sie://specs/rule-api/v2.",
    "type": "object",
    "properties": {
        "apiVersion": {
            "const": "sie://specs/rule-api/v2",
            "description": "Stable URI identifying the API contract version."
        },
        "globals": {
            "type": "object",
            "description": "All globals available to Rule authors in the sandbox.",
            "properties": {
                "sys": {
                    "$ref": "#/definitions/SystemContext"
                },
                "injectedFunctions": {
                    "$ref": "#/definitions/InjectedFunctions"
                }
            },
            "required": [
                "sys",
                "injectedFunctions"
            ],
            "additionalProperties": false
        }
    },
    "required": [
        "apiVersion",
        "globals"
    ],
    "additionalProperties": false,
    "definitions": {
        "SystemContext": {
            "type": "object",
            "description": "State I/O interface. The only stateful object in the sandbox.",
            "properties": {
                "id": {
                    "type": "string",
                    "readOnly": true,
                    "description": "System ID this Rule belongs to."
                }
            },
            "required": [
                "id"
            ],
            "methods": {
                "emit": {
                    "description": "Produce an event. Optionally wait for a response event.",
                    "params": [
                        {
                            "name": "archetype",
                            "type": "string",
                            "required": true,
                            "description": "EventArchetype name (string literal)."
                        },
                        {
                            "name": "data",
                            "type": "object",
                            "required": true,
                            "description": "Payload dict conforming to archetype schema."
                        },
                        {
                            "name": "response",
                            "type": "string",
                            "required": false,
                            "default": null,
                            "description": "EventArchetype name of expected response. Null = fire-and-forget."
                        }
                    ],
                    "returns": {
                        "description": "null when response is null; dict (response event payload) when response is set.",
                        "oneOf": [
                            {
                                "type": "null"
                            },
                            {
                                "type": "object"
                            }
                        ]
                    },
                    "derivation": {
                        "response=null": [
                            "Effector(archetype)"
                        ],
                        "response=X": [
                            "Effector(archetype)",
                            "Receptor(X)"
                        ]
                    }
                },
                "create": {
                    "description": "Create a new state object instance.",
                    "params": [
                        {
                            "name": "archetype",
                            "type": "string",
                            "required": true,
                            "description": "StateObjectArchetype name (string literal)."
                        },
                        {
                            "name": "data",
                            "type": "object",
                            "required": true,
                            "description": "Initial state dict conforming to archetype schema."
                        }
                    ],
                    "returns": {
                        "type": "object",
                        "description": "Created instance with server-assigned fields."
                    },
                    "derivation": [
                        "Effector",
                        "Receptor",
                        "Actuation(CREATION)",
                        "Actuator",
                        "Sensing",
                        "Sensor"
                    ]
                },
                "modify": {
                    "description": "Partial update on matching state objects (merge semantics).",
                    "params": [
                        {
                            "name": "archetype",
                            "type": "string",
                            "required": true,
                            "description": "StateObjectArchetype name (string literal)."
                        },
                        {
                            "name": "match",
                            "type": "Match",
                            "required": true,
                            "description": "dict (equality) or callable (predicate)."
                        },
                        {
                            "name": "data",
                            "type": "object",
                            "required": true,
                            "description": "Fields to merge into matching instances."
                        }
                    ],
                    "returns": {
                        "type": "array",
                        "items": {
                            "type": "object"
                        },
                        "description": "Updated instances (post-merge state)."
                    },
                    "derivation": [
                        "Effector",
                        "Receptor",
                        "Actuation(MODIFICATION)",
                        "Actuator",
                        "Sensing",
                        "Sensor"
                    ]
                },
                "delete": {
                    "description": "Delete matching state objects.",
                    "params": [
                        {
                            "name": "archetype",
                            "type": "string",
                            "required": true,
                            "description": "StateObjectArchetype name (string literal)."
                        },
                        {
                            "name": "match",
                            "type": "Match",
                            "required": true,
                            "description": "dict (equality) or callable (predicate)."
                        }
                    ],
                    "returns": {
                        "type": "integer",
                        "description": "Number of deleted instances."
                    },
                    "derivation": [
                        "Effector",
                        "Receptor",
                        "Actuation(DELETION)",
                        "Actuator",
                        "Sensing",
                        "Sensor"
                    ]
                },
                "acquire": {
                    "description": "Read state objects into governance perimeter (acquisition actuation).",
                    "params": [
                        {
                            "name": "archetype",
                            "type": "string",
                            "required": true,
                            "description": "StateObjectArchetype name (string literal)."
                        },
                        {
                            "name": "match",
                            "type": "Match",
                            "required": true,
                            "description": "dict (equality) or callable (predicate)."
                        }
                    ],
                    "returns": {
                        "type": "array",
                        "items": {
                            "type": "object"
                        },
                        "description": "Matching instances (empty if none)."
                    },
                    "derivation": [
                        "Effector",
                        "Receptor",
                        "Actuation(ACQUISITION)",
                        "Actuator",
                        "Sensing",
                        "Sensor"
                    ]
                }
            }
        },
        "InjectedFunctions": {
            "type": "object",
            "description": "Host-provided functions injected into sandbox. Not on sys — these are standalone globals.",
            "methods": {
                "on": {
                    "description": "Declare triggering EventArchetype and return its payload. MUST be first executable statement, called exactly once.",
                    "params": [
                        {
                            "name": "event_archetype",
                            "type": "string",
                            "required": true,
                            "description": "EventArchetype name (string literal)."
                        }
                    ],
                    "returns": {
                        "type": "object",
                        "description": "Triggering event payload conforming to archetype schema."
                    },
                    "derivation": [
                        "Receptor(event_archetype)",
                        "Rule.triggeredBy(derived)"
                    ],
                    "constraints": {
                        "position": "first executable statement",
                        "cardinality": "exactly once",
                        "argumentForm": "string literal"
                    }
                },
                "now": {
                    "description": "Current UTC datetime as formatted string.",
                    "params": [
                        {
                            "name": "fmt",
                            "type": "string",
                            "required": false,
                            "default": null,
                            "description": "strftime format. Null = ISO8601."
                        }
                    ],
                    "returns": {
                        "type": "string",
                        "description": "Formatted datetime string."
                    },
                    "deterministic": false
                },
                "uuid4": {
                    "description": "RFC 4122 v4 random UUID.",
                    "params": [],
                    "returns": {
                        "type": "string",
                        "description": "UUID string."
                    },
                    "deterministic": false
                },
                "fullmatch": {
                    "description": "Test if entire string matches RE2 regex.",
                    "params": [
                        {
                            "name": "pattern",
                            "type": "string",
                            "required": true
                        },
                        {
                            "name": "string",
                            "type": "string",
                            "required": true
                        }
                    ],
                    "returns": {
                        "type": "boolean"
                    },
                    "deterministic": true
                },
                "search": {
                    "description": "First capture group from RE2 regex search. Null if no match.",
                    "params": [
                        {
                            "name": "pattern",
                            "type": "string",
                            "required": true
                        },
                        {
                            "name": "string",
                            "type": "string",
                            "required": true
                        }
                    ],
                    "returns": {
                        "oneOf": [
                            {
                                "type": "string"
                            },
                            {
                                "type": "null"
                            }
                        ]
                    },
                    "deterministic": true
                }
            }
        },
        "Match": {
            "description": "Instance selection parameter. Two forms: dict (equality shorthand) or callable (arbitrary predicate).",
            "oneOf": [
                {
                    "type": "object",
                    "description": "Equality shorthand: every key-value pair must match the target instance."
                },
                {
                    "type": "string",
                    "description": "Callable/lambda expression (language-specific syntax)."
                }
            ]
        }
    }
}