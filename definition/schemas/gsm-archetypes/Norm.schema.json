{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "sie://schemas/gsm/v1/Norm.schema.json",
    "title": "Norm",
    "description": "Governance DNA archetype for Norm - measurable constraint predicates (DNA 'N'). Standalone first-class GSM class with independent lifecycle, typed by NormArchetype. Fields: structure, guard, predicate, toleranceMode, temporalWindow, temporalAggregation, sustainedThreshold.",
    "$gsm:sealed": true,
    "$gsm:gsmClass": "Norm",
    "allOf": [
        {
            "if": {
                "properties": {
                    "toleranceMode": {
                        "const": "INSTANTANEOUS"
                    }
                }
            },
            "then": {
                "properties": {
                    "temporalWindow": false,
                    "temporalAggregation": false,
                    "sustainedThreshold": false
                }
            }
        },
        {
            "if": {
                "properties": {
                    "toleranceMode": {
                        "const": "AGGREGATED"
                    }
                }
            },
            "then": {
                "required": [
                    "temporalWindow",
                    "temporalAggregation"
                ],
                "properties": {
                    "sustainedThreshold": false
                }
            }
        },
        {
            "if": {
                "properties": {
                    "toleranceMode": {
                        "const": "SUSTAINED"
                    }
                }
            },
            "then": {
                "required": [
                    "temporalWindow",
                    "temporalAggregation",
                    "sustainedThreshold"
                ]
            }
        }
    ],
    "type": "object",
    "required": [
        "structure",
        "predicate",
        "toleranceMode"
    ],
    "examples": [
        {
            "structure": "019cc49a-dc59-7fef-9b0c-b3f100044603",
            "guard": "DeploymentProperties.environment == \"production\"",
            "predicate": "PerformanceProperties.p99Latency < 500",
            "toleranceMode": "AGGREGATED",
            "temporalWindow": "PT5M",
            "temporalAggregation": "P99"
        },
        {
            "structure": "019cc49a-dc59-7fef-9b0c-b3f100044603",
            "predicate": "SecurityProperties.tlsEnabled == true",
            "toleranceMode": "INSTANTANEOUS"
        }
    ],
    "properties": {
        "structure": {
            "type": "string",
            "minLength": 1,
            "description": "Reference to the authoring Structure. May differ from the Directive's authoring Structure."
        },
        "guard": {
            "type": "string",
            "default": "true",
            "description": "CEL expression conforming to the applicability-guard CEL profile - activation condition. Predicate is only evaluated when guard evaluates to true. Default: 'true' (unconditional activation)."
        },
        "predicate": {
            "type": "string",
            "minLength": 1,
            "description": "CEL expression conforming to the property-assertion CEL profile, returning boolean. The constraint. References exactly one Archetype by name as root identifier, then navigates its JSON Schema fields. Example: SecurityProperties.encryptionLevel >= 'AES-128'."
        },
        "toleranceMode": {
            "type": "string",
            "enum": [
                "INSTANTANEOUS",
                "AGGREGATED",
                "SUSTAINED"
            ],
            "description": "How violations are measured over time."
        },
        "temporalWindow": {
            "type": "string",
            "pattern": "^P",
            "description": "ISO 8601 duration for time-based tolerance modes. Required when toleranceMode is time-based (AGGREGATED, SUSTAINED)."
        },
        "temporalAggregation": {
            "type": "string",
            "enum": [
                "SUM",
                "AVG",
                "MIN",
                "MAX",
                "COUNT",
                "P50",
                "P90",
                "P95",
                "P99"
            ],
            "description": "Aggregation function applied to values within the temporalWindow."
        },
        "sustainedThreshold": {
            "type": "number",
            "minimum": 0,
            "maximum": 1,
            "description": "Ratio [0,1] - fraction of temporalWindow the predicate must hold. Required when toleranceMode = SUSTAINED."
        }
    },
    "additionalProperties": false
}
