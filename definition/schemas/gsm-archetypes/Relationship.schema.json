{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "sie://schemas/gsm/v1/Relationship.json",
  "title": "Relationship (GSM v1)",
  "description": "Positional link between two Systems, encoding role pairs and governance postures.",
  "allOf": [
    { "$ref": "sie://schemas/gsm/v1/SystemicPrimitive.json" }
  ],
  "type": "object",
  "required": ["name", "definingSystem", "counterpartySystem", "definingSystemRole", "counterpartyRole"],
  "properties": {
    "name": {
      "$ref": "sie://schemas/gsm/v1/common.json#/definitions/Name80"
    },
    "definingSystem": {
      "$ref": "sie://schemas/gsm/v1/common.json#/definitions/UUID",
      "description": "System that defines this relationship (owner)."
    },
    "counterpartySystem": {
      "$ref": "sie://schemas/gsm/v1/common.json#/definitions/UUID",
      "description": "The other endpoint system."
    },
    "definingSystemRole": {
      "$ref": "sie://schemas/gsm/v1/common.json#/definitions/UUID",
      "description": "Role assigned by the defining system for itself."
    },
    "counterpartyRole": {
      "$ref": "sie://schemas/gsm/v1/common.json#/definitions/UUID",
      "description": "Role assigned by the defining system for the counterparty."
    }
  }
}
