{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "sie://schemas/gsm/v1/SystemicPrimitive.json",
  "title": "SystemicPrimitive (GSM v1)",
  "description": "Base type for all systemic primitives. Extension should be done via Qualifiers and/or via allOf in downstream adapters (e.g., ITIP).",
  "type": "object",
  "required": [
    "id",
    "archetype",
    "definitionStatus"
  ],
  "properties": {
    "id": {
      "$ref": "sie://schemas/gsm/v1/common.json#/definitions/UUID"
    },
    "archetype": {
      "$ref": "sie://schemas/gsm/v1/SystemicPrimitiveArchetype.json"
    },
    "definitionStatus": {
      "$ref": "sie://schemas/gsm/v1/SystemicPrimitiveDefinitionStatus.json"
    },
    "qualifierArchetypes": {
      "type": "array",
      "items": {
        "$ref": "sie://schemas/gsm/v1/SystemicPrimitiveQualifierArchetype.json"
      }
    },
    "qualifiers": {
      "type": "array",
      "items": {
        "$ref": "sie://schemas/gsm/v1/SystemicPrimitiveQualifier.json"
      }
    }
  }
}