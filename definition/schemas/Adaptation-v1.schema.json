{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "sie://schemas/csdm/v1/Adaptation.json",
  "title": "Adaptation (CSDM v1)",
  "description": "Second-order regulation within the current definition envelope (updates Rules without changing Policies).",
  "allOf": [
    { "$ref": "sie://schemas/csdm/v1/SystemicPrimitive.json" }
  ],
  "type": "object",
  "required": ["id", "name", "owner"],
  "properties": {
    "id": { "$ref": "sie://schemas/csdm/v1/common.json#/definitions/UUID" },
    "name": { "$ref": "sie://schemas/csdm/v1/common.json#/definitions/Name80" },
    "inputPolicies": { "type": "array", "items": { "$ref": "sie://schemas/csdm/v1/common.json#/definitions/UUID" } },
    "updatedRules": { "type": "array", "items": { "$ref": "sie://schemas/csdm/v1/common.json#/definitions/UUID" } },
    "triggerEventArchetypes": { "type": "array", "items": { "$ref": "sie://schemas/csdm/v1/common.json#/definitions/UUID" } },
    "owner": { "$ref": "sie://schemas/csdm/v1/common.json#/definitions/UUID", "description": "Reference to Supervisor owning this process." }
  }
}
