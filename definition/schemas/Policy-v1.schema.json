{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "sie://schemas/gsm/v1/Policy.json",
  "title": "Policy (GSM v1)",
  "description": "Measurable normative regulatory constraint over a system definition. Guard and constraint are GSM-DSL expressions.",
  "allOf": [
    { "$ref": "sie://schemas/gsm/v1/SystemicPrimitive.json" }
  ],
  "type": "object",
  "required": ["name", "status", "applicabilityConditions", "constraint", "principles"],
  "properties": {
    "name": { "$ref": "sie://schemas/gsm/v1/common.json#/definitions/Name80" },
    "status": { "$ref": "sie://schemas/gsm/v1/PolicyStatus.json" },
    "applicabilityConditions": { "$ref": "sie://schemas/gsm-dsl/v1/Expression.json#/definitions/LogicalExpression" },
    "constraint": { "$ref": "sie://schemas/gsm-dsl/v1/Expression.json#/definitions/ConstraintExpression" },
    "principles": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "sie://schemas/gsm/v1/common.json#/definitions/UUID" },
      "description": "References to Principle primitives this policy operationalizes."
    }
  }
}
