{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "sie://schemas/gsm/v1/Sensing.json",
  "title": "Sensing (GSM v1)",
  "description": "Links actuation execution to feedback reception, enabling homeostatic loops on actuations.",
  "allOf": [
    { "$ref": "sie://schemas/gsm/v1/SystemicPrimitive.json" }
  ],
  "type": "object",
  "required": ["name", "actuation", "sensorMechanism", "actuationEventArchetype", "feedbackEventArchetype"],
  "properties": {
    "name": { "$ref": "sie://schemas/gsm/v1/common.json#/definitions/Name80" },
    "actuation": { "$ref": "sie://schemas/gsm/v1/common.json#/definitions/UUID", "description": "Reference to Actuation observed." },
    "sensorMechanism": { "$ref": "sie://schemas/gsm/v1/common.json#/definitions/UUID", "description": "Reference to SensorMechanism composed by this sensing." },
    "actuationEventArchetype": { "$ref": "sie://schemas/gsm/v1/common.json#/definitions/UUID" },
    "feedbackEventArchetype": { "$ref": "sie://schemas/gsm/v1/common.json#/definitions/UUID" },
    "controlFeedbackReceptor": {
      "anyOf": [
        { "$ref": "sie://schemas/gsm/v1/common.json#/definitions/UUID" },
        { "type": "null" }
      ],
      "description": "Optional reference to the receptor receiving feedback."
    }
  }
}
