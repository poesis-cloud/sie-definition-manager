{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "sie://schemas/gsm/v1/common.json",
  "title": "GSM Common Types (v1)",
  "description": "Shared primitives for GSM schemas. Draft-07. Updated 2026-02-07.",
  "definitions": {
    "UUID": { "type": "string", "format": "uuid" },
    "URI": { "type": "string", "format": "uri" },
    "DateTime": { "type": "string", "format": "date-time" },

    "Name80": {
      "type": "string",
      "maxLength": 80,
      "description": "Human-readable semantic identifier. Max 80 characters."
    },

    "JsonString": {
      "type": "string",
      "description": "A JSON-encoded value (string-serialized JSON)."
    }
  }
}
