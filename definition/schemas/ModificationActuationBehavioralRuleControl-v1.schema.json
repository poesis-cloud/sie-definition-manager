{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "sie://schemas/gsm/v1/ModificationActuationControl.json",
  "title": "ModificationActuationControl (GSM v1)",
  "description": "Control that defines new state for a StateObjectArchetype using a selector.",
  "allOf": [
    {
      "$ref": "sie://schemas/gsm/v1/Control.json"
    }
  ],
  "type": "object",
  "required": [
    "stateObjectArchetype",
    "stateObjectSourceMapping",
    "stateObjectSelector"
  ],
  "properties": {
    "stateObjectArchetype": {
      "$ref": "sie://schemas/gsm/v1/common.json#/definitions/UUID"
    },
    "stateObjectSourceMapping": {
      "$ref": "sie://schemas/sie-dsl/v1/Expression.json#/definitions/SourceMappingExpression"
    },
    "stateObjectSelector": {
      "$ref": "sie://schemas/sie-dsl/v1/Expression.json#/definitions/SelectorExpression"
    }
  }
}