{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "sie://schemas/events/v1/ResolutionProposedEvent.json",
  "title": "ResolutionProposedEvent (Events v1)",
  "description": "Resolution proposed for detected incoherence.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "incoherenceId",
    "resolutionStrategy",
    "resolutionType",
    "scope",
    "proposedChanges",
    "proposedAt",
    "proposedBy",
    "confidence",
    "requiresApproval"
  ],
  "properties": {
    "incoherenceId": { "$ref": "sie://schemas/csdm/v1/common.json#/definitions/UUID" },
    "resolutionStrategy": {
      "type": "string",
      "enum": [
        "create_constraint",
        "deprecate_constraint",
        "modify_scope",
        "priority_override"
      ]
    },
    "resolutionType": {
      "type": "string",
      "enum": [
        "create_constraint",
        "deprecate_constraint",
        "modify_scope",
        "priority_override"
      ]
    },
    "scope": {
      "description": "Opaque scope selector for governance workflows.",
      "type": "object",
      "additionalProperties": true
    },
    "proposedChanges": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "proposedAt": { "$ref": "sie://schemas/csdm/v1/common.json#/definitions/DateTime" },
    "proposedBy": {
      "type": "string",
      "enum": ["user", "llm", "automated"]
    },
    "confidence": {
      "description": "Number (0-1).",
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "requiresApproval": { "type": "boolean" }
  }
}
