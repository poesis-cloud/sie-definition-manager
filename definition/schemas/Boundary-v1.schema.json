{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "sie://schemas/gsm/v1/Boundary.json",
  "title": "Boundary (GSM v1)",
  "description": "System boundary: internal/external interfaces and subsystem relations.",
  "allOf": [
    { "$ref": "sie://schemas/gsm/v1/SystemicPrimitive.json" }
  ],
  "type": "object",
  "properties": {
    "externalInterfaces": {
      "type": "array",
      "items": { "$ref": "sie://schemas/gsm/v1/common.json#/definitions/UUID" },
      "description": "References to external Interface primitives."
    },
    "internalInterfaces": {
      "type": "array",
      "items": { "$ref": "sie://schemas/gsm/v1/common.json#/definitions/UUID" },
      "description": "References to internal Interface primitives."
    },
    "subsystems": {
      "type": "array",
      "items": { "$ref": "sie://schemas/gsm/v1/common.json#/definitions/UUID" },
      "description": "References to System primitives considered subsystems under this boundary."
    }
  }
}
