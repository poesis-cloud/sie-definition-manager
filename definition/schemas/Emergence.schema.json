{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "sie://schemas/gsm/v1/Emergence.json",
  "title": "Emergence (GSM v1)",
  "description": "Second-order definitional change process: creates/revises Principles and triggers new operationalizations.",
  "allOf": [
    {
      "$ref": "sie://schemas/gsm/v1/SystemicPrimitive.json"
    }
  ],
  "type": "object",
  "required": [
    "id",
    "name",
    "owner"
  ],
  "properties": {
    "id": {
      "$ref": "sie://schemas/gsm/v1/common.json#/definitions/UUID"
    },
    "name": {
      "$ref": "sie://schemas/gsm/v1/common.json#/definitions/Name80"
    },
    "triggerEventArchetypes": {
      "type": "array",
      "items": {
        "$ref": "sie://schemas/gsm/v1/common.json#/definitions/UUID"
      }
    },
    "producedPrinciples": {
      "type": "array",
      "items": {
        "$ref": "sie://schemas/gsm/v1/common.json#/definitions/UUID"
      }
    },
    "owner": {
      "$ref": "sie://schemas/gsm/v1/common.json#/definitions/UUID",
      "description": "Reference to the governance plane process instance owning this process."
    }
  }
}