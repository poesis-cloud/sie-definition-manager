{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "sie://schemas/gsm/v1/Purpose.json",
  "title": "Purpose (GSM v1)",
  "description": "System purpose: why the system exists.",
  "allOf": [
    { "$ref": "sie://schemas/gsm/v1/SystemicPrimitive.json" }
  ],
  "type": "object",
  "required": ["description"],
  "properties": {
    "description": { "type": "string" },
    "functions": {
      "type": "array",
      "items": { "$ref": "sie://schemas/gsm/v1/common.json#/definitions/UUID" },
      "description": "References to Function primitives serving this purpose."
    }
  }
}
