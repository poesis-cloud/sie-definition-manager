{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "sie://schemas/gsm/v1/Governor.json",
  "title": "Governor (GSM v1)",
  "description": "Mechanism owning principles (identity-level constraints).",
  "allOf": [
    { "$ref": "sie://schemas/gsm/v1/Mechanism.json" }
  ],
  "type": "object",
  "required": ["ownedPrinciples"],
  "properties": {
    "ownedPrinciples": {
      "type": "array",
      "items": { "$ref": "sie://schemas/gsm/v1/common.json#/definitions/UUID" },
      "minItems": 1,
      "description": "References to Principle primitives owned by this governor."
    }
  }
}
