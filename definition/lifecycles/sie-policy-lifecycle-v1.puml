@startuml sie-constraint-lifecycle-v1

' ============================================================
' VISUAL THEME
' ============================================================

skinparam shadowing false
skinparam roundcorner 12
skinparam ArrowColor #57606A
skinparam DefaultFontName "SansSerif"
skinparam backgroundColor #FFFFFF

skinparam state {
  BackgroundColor #FFFFFF
  BorderColor #57606A
  FontColor #24292F
  StartColor #24292F
  EndColor #24292F
}

skinparam noteBackgroundColor #FFF8C5
skinparam noteBorderColor #57606A

title SIE - Constraint (Policy / Rule) Lifecycle State Machine - v1

' ============================================================
' POLICY LIFECYCLE STATE MACHINE
' ============================================================

state "Policy Lifecycle" as PolicyLifecycle {

  [*] --> DRAFT : create

  state DRAFT {
  }
  note right of DRAFT
    Initial state.
    Policy is being authored.
    Not visible to mechanisms.
    Can be freely edited.
  end note

  DRAFT --> PROPOSED : propose
  DRAFT --> [*] : delete

  state PROPOSED {
  }
  note right of PROPOSED
    Under review.
    Pre-publish coherence check triggered.
    Awaiting approval.
    No edits allowed (immutable).
  end note

  PROPOSED --> APPROVED : approve
  PROPOSED --> REJECTED : reject
  PROPOSED --> DRAFT : withdraw

  state APPROVED {
  }
  note right of APPROVED
    Approved by designated approver(s).
    Coherence check passed.
    Ready for feasibility assessment.
  end note

  APPROVED --> FEASIBILITY_ASSESSMENT : requestFeasibility
  APPROVED --> DRAFT : revise

  state FEASIBILITY_ASSESSMENT {
  }
  note right of FEASIBILITY_ASSESSMENT
    **Pre-Integration Viability Check**
    Supervisor (for Policy and Rule)
    assesses whether they CAN
    operationalize/implement the constraint.

    Not "will it succeed?" but
    "is it technically feasible?"

    Multiple assessors may contribute.
    Collects blocking issues and
    proposed adjustments if any.
  end note

  FEASIBILITY_ASSESSMENT --> FEASIBLE : assessFeasible
  FEASIBILITY_ASSESSMENT --> NOT_FEASIBLE : assessNotFeasible
  FEASIBILITY_ASSESSMENT --> FEASIBLE_WITH_ADJUSTMENTS : assessConditional

  state FEASIBLE {
  }
  note right of FEASIBLE
    All assessors confirm feasibility.
    No blocking issues identified.
    Ready for publication.
  end note

  FEASIBLE --> PUBLISHED : publish
  FEASIBLE --> DRAFT : revise

  state NOT_FEASIBLE {
  }
  note right of NOT_FEASIBLE
    At least one assessor reports
    blocking issues that cannot
    be resolved.
    Must revise or abandon.
  end note

  NOT_FEASIBLE --> DRAFT : revise
  NOT_FEASIBLE --> [*] : abandon

  state FEASIBLE_WITH_ADJUSTMENTS {
  }
  note right of FEASIBLE_WITH_ADJUSTMENTS
    Feasible but requires adjustments:
    - Scope narrowing
    - Threshold relaxation
    - Dependency additions
    Can accept adjustments or revise.
  end note

  FEASIBLE_WITH_ADJUSTMENTS --> PUBLISHED : acceptAdjustments
  FEASIBLE_WITH_ADJUSTMENTS --> DRAFT : revise

  state REJECTED {
  }
  note right of REJECTED
    Approval denied.
    Reasons documented.
    Can be revised and re-proposed.
  end note

  REJECTED --> DRAFT : revise
  REJECTED --> [*] : abandon

  state PUBLISHED {
  }
  note right of PUBLISHED
    Visible to Supervisors.
    Awaiting operationalization
    into Rules.
    Triggers supervision feedback.
  end note

  PUBLISHED --> INTEGRATED : integrationSuccess
  PUBLISHED --> SUSPENDED : integrationFailure
  PUBLISHED --> SUSPENDED : suspend

  state INTEGRATED {
  }
  note right of INTEGRATED
    Successfully operationalized.
    At least one Rule
    implements this policy.
    Actively governing the system.
  end note

  INTEGRATED --> SUSPENDED : suspend
  INTEGRATED --> DEPRECATED : deprecate

  state SUSPENDED {
  }
  note right of SUSPENDED
    Temporarily inactive.
    Mechanisms ignore this policy.
    Can be reinstated or deprecated.
    Used for:
    - Integration failures
    - Temporary exceptions
    - Investigation periods
  end note

  SUSPENDED --> PUBLISHED : reinstate
  SUSPENDED --> DEPRECATED : deprecate

  state DEPRECATED {
  }
  note right of DEPRECATED
    Marked for removal.
    Grace period before deletion.
    Dependents should migrate.
    Historical record preserved.
  end note

  DEPRECATED --> [*] : archive

}

' ============================================================
' STATE TRANSITION EVENTS
' ============================================================

note as PolicyTransitions
  **Policy State Transitions:**

  | Transition | Trigger | Conditions |
  |------------|---------|------------|
  | create | User/LLM | None |
  | propose | User | All required fields valid |
  | approve | Approver | Coherence check passed |
  | reject | Approver | Issues identified |
  | withdraw | Author | Re-work needed |
  | **requestFeasibility** | Auto | After approval |
  | **assessFeasible** | Supervisor/Operator | No blocking issues |
  | **assessNotFeasible** | Supervisor/Operator | Blocking issues found |
  | **assessConditional** | Supervisor/Operator | Feasible with changes |
  | publish | Author/Auto | After feasibility confirmed |
  | **acceptAdjustments** | Author | Accepts proposed changes |
  | integrationSuccess | SupervisorFeedback | Rule created successfully |
  | integrationFailure | SupervisorFeedback | Cannot operationalize |
  | suspend | User/Auto | Issue detected or requested |
  | reinstate | User | Issue resolved |
  | deprecate | User | No longer needed |
  | archive | System | After grace period |
  | delete | User | Only from DRAFT |
  | abandon | User | From REJECTED/NOT_FEASIBLE |
  | revise | User | Returns to DRAFT with copy |

  **Feasibility Assessment Roles:**
  - **Policy → Supervisor** assesses "Can I OPERATIONALIZE this?"
  - **Rule → Supervisor** assesses "Can this rule be realized safely?"
    (Operators provide operational feedback evidence, but do not gate feasibility.)

  **Governance Hierarchy:**
  - Governor OWNS Policy
  - Supervisor OPERATIONALIZES Policy → Rule (owns result)
  - Operator REALIZES Rule (is defined by it)

  **Immutability Rule:**
  Once a Policy leaves DRAFT, it cannot be modified.
  "Revision" creates a new Policy version (new UUID).
end note

@enduml
