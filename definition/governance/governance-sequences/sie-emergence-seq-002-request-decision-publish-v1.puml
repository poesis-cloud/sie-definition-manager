@startuml sie-emergence-seq-002-request-decision-publish-v1

' ============================================================
' VISUAL THEME
' ============================================================

skinparam shadowing false
skinparam linetype ortho
skinparam roundcorner 12
skinparam ArrowColor #57606A
skinparam DefaultFontName "SansSerif"
skinparam backgroundColor #FFFFFF

skinparam noteBackgroundColor #FFF8C5
skinparam noteBorderColor #57606A

title SIE Governance Sequence - Emergence - Request Decision + Publish - v1

autonumber

actor "Decision Owner" as DecisionOwner

participant "Event Bus" as Bus
participant "Definition Plane - GOV-EMG-001" as GOV_EMG_001

Bus -> GOV_EMG_001 : [INT-EMG-TRG-001] deliver EmergenceTriggerEvent
note over GOV_EMG_001
  Executes BR-EMG-001 controlSequence
  - BRC-EMG-001 Open Emergence Case
end note
GOV_EMG_001 -> GOV_EMG_001 : BRC-EMG-001 Open Emergence Case
GOV_EMG_001 -> Bus : [INT-EMG-001] publish EmergenceCaseOpenedEvent

note over GOV_EMG_001
  - BRC-EMG-002 Request Decision
end note
GOV_EMG_001 -> GOV_EMG_001 : BRC-EMG-002 Request Decision
GOV_EMG_001 -> Bus : [INT-EMG-002] publish DecisionRequestEvent
Bus -> DecisionOwner : deliver DecisionRequestEvent

DecisionOwner -> Bus : [INT-EMG-003] publish DecisionResponseEvent
Bus -> GOV_EMG_001 : deliver DecisionResponseEvent

note over GOV_EMG_001
  - BRC-EMG-003 Publish New Definitions
end note
GOV_EMG_001 -> GOV_EMG_001 : BRC-EMG-003 Publish New Definitions
GOV_EMG_001 -> Bus : [INT-EMG-004] publish MechanismAssignment(UPDATE_DEFINITION)

@enduml
