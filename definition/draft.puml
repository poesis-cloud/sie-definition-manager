@startuml CSDM-Systemic-Governance-Grammar

skinparam linetype ortho
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #57606A
skinparam defaultTextAlignment center

title
  Canonical Systemic Governance Grammar
  (Normative, Cybernetic, Viability, Requirements)
end title

' ============================================================
' CORE NORMATIVE STRUCTURES
' ============================================================

class Modality {
  +MUST
  +MUST_NOT
  +SHOULD
  +SHOULD_NOT
  +MAY
}

note right of Modality
  Source: RFC 2119 (normative requirement levels)
  Used by: Principle, Policy, Rule, Control
end note

class Direction {
  +MAXIMIZE
  +MINIMIZE
  +PRESERVE
  +BALANCE
}

note right of Direction
  Sources:
  - Viability Theory (Aubin)
  - Cybernetics (Ashby, Beer)
  - Control Theory (minimize error, maintain invariants)
end note

class Scope {
  +contexts : Set<String>
  +actors : Set<String>
  +timeWindow : Duration?
  +systemBoundary : BoundaryRef?
}

note right of Scope
  Sources:
  - Systems Theory (boundary, environment)
  - ISO/IEC 42010 (concern/viewpoint scope)
  - SIE DSL applicabilityConditions/selectors
end note

class Priority {
  +level : int
}

note right of Priority
  Sources:
  - Multi-criteria decision theory
  - Safety engineering (severity)
  - Governance precedence rules
end note

class ObjectTarget {
  +object : String
  +target : String
}

note right of ObjectTarget
  Sources:
  - Requirements Engineering (IEEE 29148)
  - OCL/UML constraint context
  - Cybernetics (regulated variable + regulated system)
end note

class ConstraintType {
  +ThresholdPolicyConstraint
  +InvariantPolicyConstraint
  +DependencyPolicyConstraint
  +CardinalityPolicyConstraint
}

note right of ConstraintType
  Source: SIE DSL constraint taxonomy
end note

@enduml

@startuml CSDM-Primitive-Structural-Mapping

skinparam linetype ortho
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #57606A
skinparam defaultTextAlignment left

title
  Mapping Canonical Governance Grammar
  → CSDM SystemicPrimitive Subtypes
end title

' ============================================================
' CONSTITUTIVE PRIMITIVES
' ============================================================

class Principle {
  +object : String
  +target : String
  +modality : Modality
  +direction : Direction
  +scope : Scope
  +priority : Priority
  +description : String
}

class Purpose {
  +goalObjects : Set<String>
  +scope : Scope
  +priority : Priority
}

class Capacity {
  +object : String
  +scope : Scope
}

class Boundary {
  +spatial : String?
  +organizational : String?
  +temporal : String?
}

class System {
  +boundary : Boundary
  +purposes : Purpose[]
  +capacities : Capacity[]
  +principles : Principle[]
}

class Subsystem {
  +parentSystemId : UUID
  +boundary : Boundary
}

class Dependency {
  +sourceSystemId : UUID
  +targetSystemId : UUID
  +type : String
  +criticality : Priority
}

' ============================================================
' GOVERNANCE ARTIFACTS (PPRC)
' ============================================================

class Policy {
  +object : String
  +target : String
  +modality : Modality
  +direction : Direction
  +scope : Scope
  +constraint : ConstraintType
  +applicabilityConditions : LogicalExpression
  +linkedPrincipleIds : Set<UUID>
  +priority : Priority
}

class FunctionalPolicy
class StructuralPolicy
class ViabilityPolicy

Policy <|-- FunctionalPolicy
Policy <|-- StructuralPolicy
Policy <|-- ViabilityPolicy

class Rule {
  +applicabilityConditions : LogicalExpression
  +iterationConditions : LogicalExpression
  +linkedPolicyIds : Set<UUID>
  +priority : Priority
}

class Control {
  +applicabilityConditions : LogicalExpression
  +iterationConditions : LogicalExpression
  +effectorMapping : SourceMappingExpression
  +linkedRuleIds : Set<UUID>
}

' ============================================================
' ORGANIZATIONAL PRIMITIVES (GRS&CO)
' ============================================================

class Governor {
  +principles : Principle[]
}

class Regulator {
  +policies : Policy[]
}

class Supervisor {
  +rules : Rule[]
}

class Coordinator {
  +interactionPatterns : InteractionPattern[]
}

class Operator {
  +controls : Control[]
}

' ============================================================
' STRUCTURAL / FUNCTIONAL PRIMITIVES
' ============================================================

class Function {
  +object : String
  +scope : Scope
}

class Mechanism {
  +role : String  <<Governor/Regulator/Supervisor/Coordinator/Operator>>
  +boundFunctions : Function[]
}

class Interface {
  +contract : String
  +scope : Scope
}

class StateObject {
  +schema : ArchetypeSchema
}

class EventArchetype {
  +schema : ArchetypeSchema
}

class StateObjectArchetype {
  +schema : ArchetypeSchema
}

' ============================================================
' CYBERNETIC PRIMITIVES
' ============================================================

class FeedbackLoop {
  +regulatedObject : String
  +direction : Direction
  +scope : Scope
}

class ViabilityEnvelope {
  +stateConstraints : ConstraintType[]
  +scope : Scope
  +priority : Priority
}

class InteractionPattern {
  +participants : Mechanism[]
  +protocol : String
  +scope : Scope
}

@enduml