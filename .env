# Default environment variables for dev deployment
NAMESPACE=sie
DEPLOY_ENV=preprod
RELEASE_EVENT_BUS=sie-definition-manager-eventbus
RELEASE_DEF_DB=definitiondatabase
RELEASE_SCHEMA_REG=schemaregistry

DM_CHART=./ops/helm
PORT_FORWARD_PID_FILE=.dev-port-forwards.pids

DB_URL=jdbc:postgresql://localhost:5432/sie_definition
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_ENABLE_IDEMPOTENCE=true
KAFKA_TX_ID_PREFIX=dm-tx-
SCHEMA_REGISTRY_URL=http://localhost:8081
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OIDC_ISSUER_URI=http://localhost:9000/realms/sie
DM_RELIABILITY_MODE=alo-idempotent
DM_OAUTH2_LOGIN_ENABLED=false