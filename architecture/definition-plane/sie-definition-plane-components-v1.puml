@startuml sie-definition-plane-components-v1

' ============================================================
' VISUAL THEME
' ============================================================

skinparam shadowing false
skinparam ArrowColor #57606A
skinparam DefaultFontName "SansSerif"
skinparam backgroundColor #FFFFFF

skinparam component {
  BackgroundColor #F6F8FA
  BorderColor #57606A
  FontStyle bold
}

skinparam interface {
  BackgroundColor #D4EDDA
  BorderColor #57606A
}

skinparam database {
  BackgroundColor #F6F8FA
  BorderColor #57606A
}

skinparam note {
  BackgroundColor #FFF8C5
  BorderColor #57606A
}

skinparam componentStyle uml2

title CD - SIE Definition Plane - Components - v1

' ============================================================
' EXTERNAL COMPONENTS
' ============================================================

component "LLM Service" as LLM <<external>>
component "Z3 SMT Solver" as Z3 <<external>>
component "Description Plane" as DescPlane <<external>>
component "Remediation Plane" as RemPlane <<external>>

' ============================================================
' COMPONENTS (Definition Plane)
' ============================================================

component "Systemic Definition Manager (SDM)" as SDM
component "Emergence Engine" as Emergence
component "Homeostasis Engine" as Homeostasis

component "Evaluation Engine (state vs definitions)" as EvalEngine

component "CSDSL Compiler" as CSDSLCompiler
component "CEL Transpiler" as CELTranspiler
component "Conflict / Incoherence Detector" as IncoherenceDet

component "Versioning & Publishing" as Versioning
component "Definition Persistence" as DefPersistence

database "Definition Store" as DefStore

' ============================================================
' INTERFACES (dependencies are interface-based)
' ============================================================

' Plane APIs (provided)
() "Policy API" as IPolicyAPI
() "Constraint API" as IConstraintAPI
() "Rule API" as IRuleAPI
() "Schema API" as ISchemaAPI

() "Compliance API" as IComplianceAPI

' Plane outputs (provided)
() "Compiled CEL" as ICompiledCEL
() "Schemas" as ISchemas
() "Behavioral Rules" as IRules

() "Violations / Drift" as IViolations

' Governance outputs (provided)
() "Incoherence Report" as IIncoherence
() "Resolution Proposals" as IResolutions

' Events (provided)
() "Definition Change Events" as IDefChangeEvents
() "Rule Change Events" as IRuleChangeEvents

' External capabilities (required)
() "LLM Proposals" as ILLMProposals
() "SMT Solving" as ISMT

() "State Objects" as IStateObjects

' Internal service interfaces
() "CSDSL Parsing" as ICSDSLParse
() "CEL Generation" as ICELGen
() "Incoherence Checking" as ICheck
() "Definition Persistence" as IDefPersist

' ============================================================
' CONNECTORS (provided: solid -, required: dashed ..>)
' ============================================================

' SDM plane APIs
SDM - IPolicyAPI
SDM - IConstraintAPI
SDM - IRuleAPI
SDM - ISchemaAPI

EvalEngine - IComplianceAPI
EvalEngine - IViolations

' Emergence + homeostasis are owned by Definition Plane
Emergence ..> ILLMProposals
Homeostasis ..> ISMT

Emergence - IResolutions
Homeostasis - IIncoherence
Homeostasis - IResolutions

' SDM consumes homeostasis/emergence results
SDM ..> IIncoherence
SDM ..> IResolutions

' Compilation pipeline
CSDSLCompiler - ICSDSLParse
CSDSLCompiler ..> ICELGen
CSDSLCompiler ..> ICheck

CELTranspiler - ICELGen
IncoherenceDet - ICheck
IncoherenceDet ..> ISMT

' External services provide capabilities
LLM - ILLMProposals
Z3 - ISMT

' Description Plane provides state objects for evaluation
DescPlane - IStateObjects

' Publishing of artifacts
Versioning - ICompiledCEL
Versioning - ISchemas
Versioning - IRules
Versioning - IDefChangeEvents
Versioning - IRuleChangeEvents

' Persistence
DefPersistence - IDefPersist
DefPersistence ..> DefStore

' Downstream consumption in other planes
DescPlane ..> ISchemas
DescPlane ..> IDefChangeEvents

EvalEngine ..> ICompiledCEL
EvalEngine ..> ISchemas
EvalEngine ..> IStateObjects

RemPlane ..> IRules
RemPlane ..> IRuleChangeEvents
RemPlane ..> IIncoherence
RemPlane ..> IViolations

hide stereotype

note right of SDM
  **Definition Plane (SoC)**
  Owns emergence + homeostasis
  applied to definitions:

  - systemic primitives definition
  - incoherence detection + resolution
  - publishing versioned artifacts
end note

@enduml
