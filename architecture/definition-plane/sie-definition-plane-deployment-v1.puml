@startuml sie-definition-plane-deployment-v1

' ============================================================
' VISUAL THEME
' ============================================================

skinparam shadowing false
skinparam roundcorner 8
skinparam ArrowColor #57606A
skinparam DefaultFontName "SansSerif"
skinparam backgroundColor #FFFFFF

skinparam nodeBackgroundColor #F6F8FA
skinparam nodeBorderColor #57606A

skinparam componentBackgroundColor #FFFFFF
skinparam componentBorderColor #57606A

skinparam databaseBackgroundColor #F6F8FA
skinparam databaseBorderColor #57606A

skinparam artifactBackgroundColor #E8F4E8
skinparam artifactBorderColor #57606A

skinparam noteBackgroundColor #FFF8C5
skinparam noteBorderColor #57606A

title Definition Plane - Deployment View - v1

' ============================================================
' DEFINITION PLANE DEPLOYMENT
' ============================================================

node "Definition Plane" as DefPlaneNode #E8F4E8 {
  
  node "SDM Service" as SDMService {
    component [Policy Manager] as PolicyMgr
    component [Constraint Manager] as ConstraintMgr
    component [Rule Manager] as RuleMgr
    component [Schema Manager] as SchemaMgr
    component [Version Controller] as VersionCtrl
  }
  
  node "CSDSL Service" as CSDSLService {
    component [CSDSL Parser] as Parser
    component [CSDSL Validator] as Validator
    component [Type Checker] as TypeChecker
  }
  
  node "CEL Transpiler Service" as CELService {
    component [AST Transformer] as ASTTransform
    component [Macro Expander] as MacroExpand
    component [CEL Optimizer] as Optimizer
    artifact "Compilation Cache" as CompCache
  }
  
  node "Conflict Detection Service" as ConflictService {
    component [SMT Encoder] as SMTEncoder
    component [Conflict Resolver] as ConflictRes
  }
  
  database "Definition Store" as DefStore {
    artifact [Policies]
    artifact [Constraints]
    artifact [Rules]
    artifact [Schemas]
    artifact [Versions]
  }
}

' ============================================================
' SHARED SERVICES (External)
' ============================================================

cloud "Shared Services" as SharedSvc #F5F5F5 {
  node "Z3 SMT Solver" as Z3
  node "LLM Service" as LLM
}

' ============================================================
' PLANE INTERFACES (Provided)
' ============================================================

interface "Definition API" as DefAPI
interface "Policy API" as PolicyAPI
interface "Constraint API" as ConstraintAPI
interface "Rule API" as RuleAPI

SDMService -up- DefAPI
SDMService -up- PolicyAPI
SDMService -up- ConstraintAPI
SDMService -up- RuleAPI

' ============================================================
' PLANE INTERFACES (Required)
' ============================================================

interface "Description Plane" as DescPlaneIF <<required>>
interface "Remediation Plane" as RemPlaneIF <<required>>

' ============================================================
' DEPLOYMENT RELATIONSHIPS
' ============================================================

' Internal flow
PolicyMgr --> VersionCtrl
ConstraintMgr --> CSDSLService : parse
CSDSLService --> CELService : transpile
CSDSLService --> ConflictService : check
ConflictService --> Z3 : solve
Parser ..> LLM : synthesis\n(optional)

' Persistence
VersionCtrl --> DefStore
CompCache --> DefStore

' Notify other planes
VersionCtrl ..> DescPlaneIF : invalidate cache
VersionCtrl ..> RemPlaneIF : rule changes

' ============================================================
' NOTES
' ============================================================

note right of DefPlaneNode
  **Definition Plane**
  "What we want"
  
  **Stateless services:**
  - SDM Service
  - CSDSL Service
  - CEL Transpiler
  - Conflict Detection
  
  **Stateful:**
  - Definition Store (PostgreSQL)
  
  **Scaling:**
  - Horizontal for services
  - Single-leader for store
end note

note bottom of SharedSvc
  **Shared Services**
  
  Stateless, no customer data.
  Multi-tenant safe.
end note

@enduml
