@startuml sie-definition-plane-v1

' ============================================================
' VISUAL THEME
' ============================================================

skinparam shadowing false
skinparam ArrowColor #57606A
skinparam DefaultFontName "SansSerif"
skinparam backgroundColor #FFFFFF

skinparam component {
  BackgroundColor #F6F8FA
  BorderColor #57606A
  FontStyle bold
}

skinparam interface {
  BackgroundColor #D4EDDA
  BorderColor #57606A
}

skinparam database {
  BackgroundColor #F6F8FA
  BorderColor #57606A
}

skinparam note {
  BackgroundColor #FFF8C5
  BorderColor #57606A
}

' Use UML2 component style with icon
skinparam componentStyle uml2

title CD - SIE Definition Plane - v1

' ============================================================
' PROVIDED INTERFACES (lollipops)
' ============================================================

() "Policy API" as IPolicyAPI
() "Constraint API" as IConstraintAPI
() "Rule API" as IRuleAPI
() "Schema API" as ISchemaAPI
() "Compiled CEL" as ICompiledCEL

' ============================================================
' COMPONENTS
' ============================================================

component "SDM" as SDM <<Systemic Definition Manager>> {
  component "Policy Manager" as PolicyMgr
  component "Constraint Manager" as ConstraintMgr
  component "Rule Manager" as RuleMgr
  component "Schema Manager" as SchemaMgr
  component "Version Controller" as VersionCtrl
}

component "CSDSL Processor" as CSDSLProc {
  component "Parser" as Parser
  component "Validator" as Validator
  component "Type Checker" as TypeChecker
}

component "CEL Transpiler" as CELTransp {
  component "AST Transformer" as ASTTransform
  component "Macro Expander" as MacroExpand
  component "Optimizer" as Optimizer
}

component "Conflict Detector" as ConflictDet {
  component "SMT Encoder" as SMTEncoder
  component "Conflict Resolver" as ConflictRes
}

component "Compilation Cache" as Cache

database "Definition Store" as DefStore

' ============================================================
' EXTERNAL COMPONENTS
' ============================================================

component "Z3 SMT Solver" as Z3 <<external>>
component "LLM Service" as LLM <<external>>
component "Description Plane" as DescPlane <<external>>
component "Remediation Plane" as RemPlane <<external>>

' ============================================================
' REQUIRED INTERFACES (what we need from external)
' ============================================================

() "SMT Solving" as ISMT
() "LLM Synthesis" as ILLM

' Internal plane service interfaces
() "CSDSL Processing" as ICSDSLProcessing
() "CEL Transpilation" as ICELTranspile
() "Conflict Checking" as IConflictCheck
() "Cache Write" as ICacheWrite
() "Definition Persistence" as IDefPersistence
() "Definition Change Events" as IDefChangeEvents
() "Rule Change Events" as IRuleChangeEvents

' ============================================================
' ASSEMBLY CONNECTORS (provided --o interface o-- required)
' ============================================================

' APIs provided by SDM
SDM - IPolicyAPI
SDM - IConstraintAPI
SDM - IRuleAPI
SDM - ISchemaAPI

' SDM consumes internal services
SDM ..> ICSDSLProcessing
SDM ..> IDefPersistence

' CSDSL processing provided by CSDSL Processor
CSDSLProc - ICSDSLProcessing
CSDSLProc ..> ICELTranspile
CSDSLProc ..> IConflictCheck

' Compiled CEL provided by Cache, required by Description Plane
Cache - ICompiledCEL
DescPlane ..> ICompiledCEL

' CEL transpilation provided by CEL Transpiler
CELTransp - ICELTranspile
CELTransp ..> ICacheWrite

' Conflict checking provided by Conflict Detector
ConflictDet - IConflictCheck

' SMT solving: Z3 provides, ConflictDet requires
Z3 - ISMT
SMTEncoder ..> ISMT

' LLM synthesis: LLM provides, CSDSLProc requires
LLM - ILLM
CSDSLProc ..> ILLM

' Cache write interface provided by Cache
Cache - ICacheWrite

' Persistence interface provided by Definition Store
DefStore - IDefPersistence
VersionCtrl ..> IDefPersistence
Cache ..> IDefPersistence

' Change events provided by Version Controller
VersionCtrl - IDefChangeEvents
VersionCtrl - IRuleChangeEvents
DescPlane ..> IDefChangeEvents
RemPlane ..> IRuleChangeEvents

hide stereotype

' ============================================================
' NOTES
' ============================================================

note right of SDM
  **Definition Plane**
  "What we want"
  
  Owns:
  • Policies
  • Constraints (CSDSL)
  • Behavioral Rules
  • Schemas
end note

note bottom of ICompiledCEL
  Description Plane consumes
  compiled CEL expressions
  for policy evaluation
end note

@enduml
