@startuml sie-plane-overview-v1

' ============================================================
' VISUAL THEME
' ============================================================

skinparam shadowing false
skinparam roundcorner 12
skinparam ArrowColor #57606A
skinparam DefaultFontName "SansSerif"
skinparam backgroundColor #FFFFFF

skinparam componentStyle rectangle
skinparam componentBackgroundColor #F6F8FA
skinparam componentBorderColor #57606A

skinparam packageBackgroundColor #FFFFFF
skinparam packageBorderColor #57606A

skinparam noteBackgroundColor #FFF8C5
skinparam noteBorderColor #57606A

title SIE (Systemic Intelligence Engine) - Three Planes Architecture - v1

' ============================================================
' DOMAIN APPLICATIONS
' ============================================================

package "Domain Applications" as DomainApps {
  
  package "ITIP (IT Intelligence Platform)" as ITIP #D4EDDA {
    [ITIP UI] as ITIPUI
    [ITIP Backend\n(stateless)] as ITIPBackend
    
    note as ITIPNote
      IT Domain translation of CSDM:
      - Services, APIs, Infrastructure
      - IT Risks & Pain Points
      - Quality Attributes
    end note
  }
  
  package "Future Domain Apps" as FutureApps #F0F0F0 {
    [Security Domain App] as SecApp
    [FinOps Domain App] as FinOpsApp
    [Compliance Domain App] as CompApp
  }
}

' ============================================================
' SIE CORE - THREE PLANES
' ============================================================

package "SIE Core" as SIECore {
  
  ' --- Definition Plane ---
  package "Definition Plane" as DefPlane #E8F4E8 {
    [SDM\n(Systemic Definition Mgr)] as SDM
    [CSDSL Processing] as CSDSL
    [Conflict Detection] as ConflictDet
    [CEL Transpilation] as CELTransp
    
    note as DefPlaneNote
      **"What we want"**
      Policies, Constraints,
      Rules, Schemas
    end note
  }
  
  ' --- Description Plane ---
  package "Description Plane" as DescPlane #E8F0FA {
    [State Ingestion] as StateIngest
    [CSDM Runtime] as CSDMRuntime
    [Evaluation Engine] as EvalEngine
    [Analytics Engine] as AnalyticsEng
    
    note as DescPlaneNote
      **"How things are"**
      State Objects, Evaluations,
      Relationships, History
    end note
  }
  
  ' --- Remediation Plane ---
  package "Remediation Plane" as RemPlane #FFE0E0 {
    [Behavioral Rules] as BehavRules
    [Remediation Planning] as RemPlan
    [Auto-Healing] as AutoHeal
    [Escalation Mgmt] as Escalation
    
    note as RemPlaneNote
      **"What to do about it"**
      Actions, Playbooks,
      Healing, Escalations
    end note
  }
}

' ============================================================
' EXTERNAL SYSTEMS
' ============================================================

package "Managed Environment" as ManagedEnv {
  [Kubernetes / Cloud] as K8sCloud
  [CI/CD Pipelines] as CICD
  [Observability] as Observability
}

package "External Services" as ExtSvc {
  [LLM Service] as LLM
  [SMT Solver (Z3)] as Z3
}

package "Communication" as Comm {
  [Ticketing / Chat] as Ticketing
}

actor "Users" as Users

' ============================================================
' DOMAIN APP → SIE RELATIONSHIPS
' ============================================================

Users --> ITIPUI
ITIPUI --> ITIPBackend

' ITIP to all three planes
ITIPBackend --> SDM : manage IT policies
ITIPBackend --> StateIngest : IT state events
ITIPBackend --> EvalEngine : IT compliance
ITIPBackend --> Escalation : IT incidents

' Future apps same pattern
SecApp --> SDM
SecApp --> EvalEngine
FinOpsApp --> SDM
FinOpsApp --> AnalyticsEng
CompApp --> SDM
CompApp --> EvalEngine

' ============================================================
' INTER-PLANE RELATIONSHIPS
' ============================================================

' Definition → Description
SDM --> CSDMRuntime : schemas
CELTransp --> EvalEngine : compiled CEL
ConflictDet --> AnalyticsEng : conflict data

' Description → Remediation
EvalEngine --> BehavRules : violations
AnalyticsEng --> RemPlan : impact/context

' Definition → Remediation
SDM --> BehavRules : behavioral rules

' ============================================================
' EXTERNAL RELATIONSHIPS
' ============================================================

' Managed environment
K8sCloud --> StateIngest : state
CICD --> StateIngest : events
Observability --> StateIngest : metrics
AutoHeal --> K8sCloud : remediation
AutoHeal --> CICD : gates

' External services
LLM --> CSDSL : synthesis
LLM --> AnalyticsEng : explanations
Z3 --> ConflictDet : SAT solving

' Communication
Escalation --> Ticketing

' ============================================================
' LEGEND
' ============================================================

legend bottom
  |= Color |= Plane / Layer |
  |<#E8F4E8> | Definition Plane (what we want) |
  |<#E8F0FA> | Description Plane (how things are) |
  |<#FFE0E0> | Remediation Plane (what to do) |
  |<#D4EDDA> | Domain Application (e.g., ITIP) |
endlegend

@enduml
