@startuml sie-remediation-plane-deployment-v1

' ============================================================
' VISUAL THEME
' ============================================================

skinparam shadowing false
skinparam roundcorner 8
skinparam ArrowColor #57606A
skinparam DefaultFontName "SansSerif"
skinparam backgroundColor #FFFFFF

skinparam nodeBackgroundColor #F6F8FA
skinparam nodeBorderColor #57606A

skinparam componentBackgroundColor #FFFFFF
skinparam componentBorderColor #57606A

skinparam databaseBackgroundColor #F6F8FA
skinparam databaseBorderColor #57606A

skinparam artifactBackgroundColor #FFE0E0
skinparam artifactBorderColor #57606A

skinparam noteBackgroundColor #FFF8C5
skinparam noteBorderColor #57606A

skinparam queueBackgroundColor #F6F8FA
skinparam queueBorderColor #57606A

title Remediation Plane - Deployment View - v1

' ============================================================
' REMEDIATION PLANE DEPLOYMENT
' ============================================================

node "Remediation Plane" as RemPlaneNode #FFE0E0 {
  
  queue "Violation Queue" as ViolationQueue
  
  node "Rule Engine Service" as RuleEngineSvc {
    component [Rule Executor] as RuleExec
    component [Condition Evaluator] as CondEval
    component [Action Selector] as ActionSelect
    component [Pre-condition Checker] as PreCondCheck
  }
  
  node "Remediation Planner Service" as PlannerSvc {
    component [Remediation Planner] as RemPlanner
    component [Risk Assessor] as RiskAssessor
    component [Rollback Planner] as RollbackPlanner
    component [Playbook Matcher] as PlaybookMatch
  }
  
  node "Auto-Healing Service" as AutoHealSvc {
    component [Auto Healer] as AutoHealer
    component [Safe Mode Controller] as SafeMode
    component [Dry Run Executor] as DryRun
    component [Healing Validator] as HealValidator
  }
  
  node "Escalation Service" as EscalationSvc {
    component [Escalation Manager] as EscalationMgr
    component [Approval Workflow] as ApprovalWF
    component [Notification Router] as NotifRouter
    component [SLA Monitor] as SLAMonitor
  }
  
  node "Feedback Service" as FeedbackSvc {
    component [Outcome Tracker] as OutcomeTracker
    component [Success Analyzer] as SuccessAnalyzer
    component [Pattern Learner] as PatternLearner
  }
  
  database "Remediation Store" as RemStore {
    artifact [Action History]
    artifact [Outcomes]
    artifact [Feedback]
  }
  
  database "Playbook Store" as PlaybookStore {
    artifact [Playbooks]
    artifact [Recipes]
    artifact [Rollback Scripts]
  }
}

' ============================================================
' STATE PLANE (External - Customer Systems)
' ============================================================

rectangle "State Plane" as StatePlane #F0F8FF {
  node "Kubernetes Clusters" as K8s
  node "Cloud Resources" as Cloud
  node "CI/CD Pipelines" as CICD
  node "Config Management" as ConfigMgmt
}

' ============================================================
' COMMUNICATION CHANNELS (External)
' ============================================================

rectangle "Communication Channels" as CommChannels #F5F5F5 {
  node "Ticketing\n(Jira, ServiceNow)" as Ticketing
  node "Chat\n(Slack, Teams)" as Chat
  node "Paging\n(PagerDuty, OpsGenie)" as Paging
}

' ============================================================
' SHARED SERVICES (External)
' ============================================================

cloud "Shared Services" as SharedSvc #F5F5F5 {
  node "LLM Service" as LLM
}

' ============================================================
' PLANE INTERFACES (Provided)
' ============================================================

interface "Action API" as ActionAPI
interface "Approval API" as ApprovalAPI
interface "Playbook API" as PlaybookAPI
interface "Feedback API" as FeedbackAPI

RuleEngineSvc -up- ActionAPI
EscalationSvc -up- ApprovalAPI
PlannerSvc -up- PlaybookAPI
FeedbackSvc -up- FeedbackAPI

' ============================================================
' PLANE INTERFACES (Required)
' ============================================================

interface "Definition Plane" as DefPlaneIF <<required>>

component "Operators" as Operators

' ============================================================
' DEPLOYMENT RELATIONSHIPS
' ============================================================

' Violations/drift from Definition Plane evaluation
DefPlaneIF --> ViolationQueue : violations/drift

' Rules from Definition Plane
DefPlaneIF --> RuleExec : behavioral rules

' Rule engine flow
ViolationQueue --> RuleExec
RuleExec --> CondEval
CondEval --> ActionSelect
ActionSelect --> PreCondCheck

' Planning flow
PreCondCheck --> PlannerSvc
PlaybookMatch --> PlaybookStore
RiskAssessor ..> LLM : risk analysis

' Auto-healing flow
PlannerSvc --> AutoHealSvc
DryRun --> SafeMode
AutoHealer --> HealValidator

' Remediation to State Plane
AutoHealer --> K8s : apply
AutoHealer --> Cloud : apply
AutoHealer --> CICD : gate
AutoHealer --> ConfigMgmt : apply

' Escalation flow
PlannerSvc --> EscalationSvc : requires approval
EscalationSvc --> Ticketing : create ticket
EscalationSvc --> Chat : notify
EscalationSvc --> Paging : page
Operators ..> ApprovalWF : approve/reject

' Feedback
AutoHealSvc --> FeedbackSvc : outcomes
EscalationSvc --> FeedbackSvc : resolutions
OutcomeTracker --> RemStore
PatternLearner ..> LLM : learn patterns

' ============================================================
' NOTES
' ============================================================

note right of RemPlaneNode
  **Remediation Plane**
  "What to do about it"
  
  **Stateless services:**
  - Rule Engine Service
  - Remediation Planner
  - Auto-Healing Service
  - Escalation Service
  - Feedback Service
  
  **Stateful:**
  - Remediation Store (PostgreSQL)
  - Playbook Store (PostgreSQL)
  
  **Scaling:**
  - Horizontal for services
  - Queue for backpressure
  - Safe mode for blast radius
end note

note bottom of StatePlane
  **State Plane**
  
  Customer's systems that:
  - Source state to Description Plane
  - **Are operated by Remediation Plane**
  
  Remediation applies changes here.
end note

@enduml
