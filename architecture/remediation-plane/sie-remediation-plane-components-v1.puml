@startuml sie-remediation-plane-components-v1

' ============================================================
' VISUAL THEME
' ============================================================

skinparam shadowing false
skinparam ArrowColor #57606A
skinparam DefaultFontName "SansSerif"
skinparam backgroundColor #FFFFFF

skinparam component {
  BackgroundColor #F6F8FA
  BorderColor #57606A
  FontStyle bold
}

skinparam interface {
  BackgroundColor #D4EDDA
  BorderColor #57606A
}

skinparam database {
  BackgroundColor #F6F8FA
  BorderColor #57606A
}

skinparam note {
  BackgroundColor #FFF8C5
  BorderColor #57606A
}

skinparam componentStyle uml2

title CD - SIE Remediation Plane - Components - v1

' ============================================================
' EXTERNAL COMPONENTS
' ============================================================

component "Definition Plane" as DefPlane <<external>>
component "Description Plane" as DescPlane <<external>>
component "State Plane" as StatePlane <<external>>
component "LLM Service" as LLM <<external>>

component "Communication Channels" as Comm <<external>> {
  component "Ticketing" as Ticketing
  component "Chat" as Chat
  component "Paging" as Paging
}

component "Operators" as Operators <<external>>

' ============================================================
' COMPONENTS (Remediation Plane)
' ============================================================

package "SIE General (portable)" as General {
  component "Behavioral Rule Execution" as RuleExec
  component "Remediation Decisioning" as Decisioning
  component "Planner" as Planner
  component "Feedback" as Feedback
}

package "Tenant-specific (adapted)" as Tenant {
  component "Guardrails & Safety" as Guardrails
  component "Tenant Actuation Adapters" as ActAdapters
  component "Approval / Escalation" as Escalation
}

package "AIOps Transversal Layer" as AIOps #FFF8C5 {
  component "Adapter Runtime" as AdapterRuntime
  component "Tenant/Domain Connector SDK" as SDK
}

' Persistence
component "Remediation Persistence" as RemPersistence
component "Playbook Persistence" as PlaybookPersistence

database "Remediation Store" as RemStore

database "Playbook Store" as PlaybookStore

' ============================================================
' INTERFACES
' ============================================================

' Plane APIs (provided)
() "Action API" as IActionAPI
() "Approval API" as IApprovalAPI
() "Playbook API" as IPlaybookAPI
() "Feedback API" as IFeedbackAPI

' Required inputs
() "Policies + Behavioral Rules" as IPoliciesRules
() "Violations / Drift" as IViolations
() "State Objects" as IStateObjects
() "State Capabilities" as IStateCaps
() "LLM Suggestions" as ILLMSuggest

' Internal service interfaces
() "Remediation Plans" as IPlans
() "Execution Commands" as IExec
() "Outcomes" as IOutcomes
() "Approval Decisions" as IApprovalDecisions

() "Remediation Persistence" as IRemPersist
() "Playbook Persistence" as IPlaybookPersist

() "Ticketing" as ITicketing
() "Chat Notifications" as IChat
() "Paging" as IPaging

' Tenant actuation interfaces
() "State Actions" as IStateActions

' ============================================================
' CONNECTORS
' ============================================================

' Provided APIs
Decisioning - IActionAPI
Escalation - IApprovalAPI
Planner - IPlaybookAPI
Feedback - IFeedbackAPI

Operators ..> IApprovalAPI : approve/reject
Operators ..> IFeedbackAPI : feedback

' Inputs from other planes
DefPlane - IPoliciesRules
Decisioning ..> IPoliciesRules
RuleExec ..> IPoliciesRules

DefPlane - IViolations
Decisioning ..> IViolations

DescPlane - IStateObjects
Decisioning ..> IStateObjects

StatePlane - IStateCaps
Guardrails ..> IStateCaps

LLM - ILLMSuggest
Decisioning ..> ILLMSuggest
Planner ..> ILLMSuggest

' Decisioning flow
Decisioning - IPlans
Planner ..> IPlans

Planner - IExec
Guardrails ..> IExec

Guardrails - IStateActions
ActAdapters ..> IStateActions

RuleExec - IOutcomes
Feedback ..> IOutcomes

Escalation - IApprovalDecisions
Decisioning ..> IApprovalDecisions

' AIOps bridges tenant-specific actuation
SDK --> AdapterRuntime
AdapterRuntime ..> IStateActions
ActAdapters ..> IStateActions
AdapterRuntime ..> StatePlane

' Channels provide integrations
Ticketing - ITicketing
Chat - IChat
Paging - IPaging

Escalation ..> ITicketing
Escalation ..> IChat
Escalation ..> IPaging

' Persistence
RemPersistence - IRemPersist
PlaybookPersistence - IPlaybookPersist
Feedback ..> IRemPersist
Planner ..> IPlaybookPersist

RemPersistence ..> RemStore
PlaybookPersistence ..> PlaybookStore

hide stereotype

note right of Decisioning
  **Remediation Plane (SoC)**

  Aligns State Plane with Definition Plane.

  Tenant-specific because:
  - available state APIs/providers differ
  - constraints/guardrails differ
  - approval/escalation differs

  Triggers include:
  - violations/drift from Definition evaluation
  - risk/priority from Definition Plane policies
end note

@enduml
