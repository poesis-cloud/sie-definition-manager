@startuml sie-description-plane-deployment-v1

' ============================================================
' VISUAL THEME
' ============================================================

skinparam shadowing false
skinparam roundcorner 8
skinparam ArrowColor #57606A
skinparam DefaultFontName "SansSerif"
skinparam backgroundColor #FFFFFF

skinparam nodeBackgroundColor #F6F8FA
skinparam nodeBorderColor #57606A

skinparam componentBackgroundColor #FFFFFF
skinparam componentBorderColor #57606A

skinparam databaseBackgroundColor #F6F8FA
skinparam databaseBorderColor #57606A

skinparam artifactBackgroundColor #E8F0FA
skinparam artifactBorderColor #57606A

skinparam noteBackgroundColor #FFF8C5
skinparam noteBorderColor #57606A

skinparam queueBackgroundColor #F6F8FA
skinparam queueBorderColor #57606A

title Description Plane - Deployment View - v1

' ============================================================
' DESCRIPTION PLANE DEPLOYMENT
' ============================================================

node "Description Plane" as DescPlaneNode #E8F0FA {
  
  node "Ingestion Service" as IngestionSvc {
    component [Event Receiver] as EventRcv
    component [State Collector] as StateCollector
    component [State Normalizer] as Normalizer
    component [Context Enricher] as Enricher
  }
  
  queue "Event Queue" as EventQueue
  
  node "CSDM Runtime Service" as CSDMService {
    component [State Object Manager] as StateObjMgr
    component [Entity Registry] as EntityReg
    component [Relationship Manager] as RelMgr
    component [Schema Enforcer] as SchemaEnf
  }
  
  database "State Store" as StateStore {
    artifact [Current State]
    artifact [State History]
  }
  
  database "Graph DB" as GraphDB {
    artifact [Dependencies]
    artifact [Relationships]
  }
  
  database "Time Series DB" as TSDB {
    artifact [Metrics]
    artifact [Trends]
  }
}

' ============================================================
' STATE PLANE (External - Customer Systems)
' ============================================================

rectangle "State Plane" as StatePlane #F0F8FF {
  node "Kubernetes Clusters" as K8s
  node "Cloud Resources" as Cloud
  node "Applications" as Apps
  node "Observability Stack" as Observability
  node "CI/CD Pipelines" as CICD
}

' ============================================================
' PLANE INTERFACES (Provided)
' ============================================================

interface "State API" as StateAPI
interface "Event API" as EventAPI
interface "Graph API" as GraphAPI

IngestionSvc -up- EventAPI
CSDMService -up- StateAPI
CSDMService -up- GraphAPI

' ============================================================
' PLANE INTERFACES (Required)
' ============================================================

interface "Definition Plane" as DefPlaneIF <<required>>

' ============================================================
' DEPLOYMENT RELATIONSHIPS
' ============================================================

' State Plane → Ingestion
K8s --> EventRcv : events
Cloud --> EventRcv : events
Apps --> StateCollector : state
Observability --> StateCollector : metrics
CICD --> EventRcv : events

' Ingestion flow
EventRcv --> EventQueue
EventQueue --> Normalizer
Normalizer --> Enricher
Enricher --> CSDMService

' CSDM to stores
StateObjMgr --> StateStore
RelMgr --> GraphDB

' Definition-provided schemas
DefPlaneIF --> SchemaEnf : schemas

' ============================================================
' NOTES
' ============================================================

note right of DescPlaneNode
  **Description Plane**
  "How things are"
  
  **Stateless services:**
  - Ingestion Service
  - CSDM Runtime
  
  **Stateful:**
  - State Store (PostgreSQL)
  - Graph DB (Neo4j/PostgreSQL)
  - Time Series DB (TimescaleDB)
  
  **Scaling:**
  - Horizontal for services
  - Event queue for backpressure
end note

note bottom of StatePlane
  **State Plane**
  
  Customer's systems that:
  - Source state to Description Plane
  - Are operated by Remediation Plane
  
  Not managed by SIE, only observed.
end note

@enduml
