@startuml sie-knowledge-management-uc-v1

' ============================================================
' VISUAL THEME
' ============================================================

left to right direction
skinparam shadowing false
skinparam roundcorner 12
skinparam ArrowColor #57606A
skinparam DefaultFontName "SansSerif"
skinparam backgroundColor #FFFFFF

skinparam actorBackgroundColor #FFFFFF
skinparam actorBorderColor #57606A

skinparam usecaseBackgroundColor #F6F8FA
skinparam usecaseBorderColor #57606A

skinparam rectangleBackgroundColor #FFFFFF
skinparam rectangleBorderColor #57606A

skinparam noteBackgroundColor #FFF8C5
skinparam noteBorderColor #57606A

' ============================================================

title UC - SIE Knowledge Management - v1

' ============================================================
' ACTORS
' ============================================================

actor "Policy Author" as PolicyAuthor
actor "System Architect" as Architect
actor "Domain Expert" as DomainExpert
actor "New Team Member" as NewMember
actor "Governance Officer" as GovOfficer

actor "Knowledge Base" as KB <<system>>
actor "LLM Service" as LLM <<system>>
actor "Pattern Repository" as PatternRepo <<system>>
actor "Decision Log" as DecisionLog <<system>>

' ============================================================
' USE CASES
' ============================================================

rectangle "Knowledge Management" {

  ' --- Constraint Pattern Library ---
  package "Constraint Pattern Library" {
    usecase "Catalog Proven\nConstraint Templates" as UC_CatalogTemplates
    usecase "Provide Domain-Specific\nPattern Packs" as UC_DomainPacks
    usecase "Support Custom\nOrganizational Patterns" as UC_CustomPatterns
    usecase "Enable Pattern-Based\nConstraint Authoring" as UC_PatternAuthoring
  }

  ' --- Rationale Capture ---
  package "Rationale Capture" {
    usecase "Record Constraint\nDesign Rationale" as UC_RecordRationale
    usecase "Link Constraints to\nBusiness Justifications" as UC_LinkJustifications
    usecase "Preserve Decision-Making\nContext" as UC_PreserveContext
    usecase "Support Rationale-Based\nSearch" as UC_RationaleSearch
  }

  ' --- Expertise Encoding ---
  package "Expertise Encoding" {
    usecase "Capture Expert\nHeuristics as Constraints" as UC_CaptureHeuristics
    usecase "Document Tribal\nKnowledge Formally" as UC_DocumentTribal
    usecase "Support Knowledge\nTransfer Workflows" as UC_KnowledgeTransfer
    usecase "Enable Expertise-Based\nRecommendations" as UC_ExpertiseRecommend
  }

  ' --- Learning From Decisions ---
  package "Learning From Decisions" {
    usecase "Track Decision\nEffectiveness" as UC_TrackEffectiveness
    usecase "Identify Successful\nConstraint Patterns" as UC_IdentifySuccessful
    usecase "Learn from Remediation\nOutcomes" as UC_LearnRemediation
    usecase "Refine Recommendations\nvia Feedback" as UC_RefineRecommend
  }
}

' ============================================================
' RELATIONSHIPS - Actors to Use Cases
' ============================================================

' Policy Author interactions
PolicyAuthor --> UC_CatalogTemplates
PolicyAuthor --> UC_PatternAuthoring
PolicyAuthor --> UC_RecordRationale
PolicyAuthor --> UC_RationaleSearch

' Architect interactions
Architect --> UC_DomainPacks
Architect --> UC_CustomPatterns
Architect --> UC_LinkJustifications
Architect --> UC_IdentifySuccessful

' Domain Expert interactions
DomainExpert --> UC_CaptureHeuristics
DomainExpert --> UC_DocumentTribal
DomainExpert --> UC_PreserveContext
DomainExpert --> UC_ExpertiseRecommend

' New Team Member interactions
NewMember --> UC_PatternAuthoring
NewMember --> UC_RationaleSearch
NewMember --> UC_KnowledgeTransfer
NewMember --> UC_ExpertiseRecommend

' Governance Officer interactions
GovOfficer --> UC_TrackEffectiveness
GovOfficer --> UC_LearnRemediation
GovOfficer --> UC_RefineRecommend
GovOfficer --> UC_CustomPatterns

' ============================================================
' RELATIONSHIPS - System Actors
' ============================================================

UC_CatalogTemplates --> PatternRepo
UC_DomainPacks --> PatternRepo
UC_CustomPatterns --> PatternRepo
UC_PatternAuthoring --> PatternRepo

UC_RecordRationale --> KB
UC_LinkJustifications --> KB
UC_PreserveContext --> KB
UC_RationaleSearch --> LLM

UC_CaptureHeuristics --> LLM
UC_DocumentTribal --> KB
UC_KnowledgeTransfer --> KB
UC_ExpertiseRecommend --> LLM

UC_TrackEffectiveness --> DecisionLog
UC_IdentifySuccessful --> DecisionLog
UC_LearnRemediation --> DecisionLog
UC_RefineRecommend --> LLM

' ============================================================
' RELATIONSHIPS - Include/Extend
' ============================================================

UC_PatternAuthoring ..> UC_CatalogTemplates : <<include>>
UC_RationaleSearch ..> UC_RecordRationale : <<include>>
UC_KnowledgeTransfer ..> UC_DocumentTribal : <<include>>
UC_RefineRecommend ..> UC_TrackEffectiveness : <<include>>
UC_ExpertiseRecommend ..> UC_CaptureHeuristics : <<include>>

' ============================================================
' NOTES
' ============================================================

note right of UC_CatalogTemplates
  **Pattern Library Example:**
  
  Pattern: API Rate Limiting
  Category: Resilience
  Domain: Web Services
  
  Template:
  threshold(api.requests_per_minute,
            "<", {{max_rpm}})
  
  Usage: 47 implementations
  Success Rate: 98%
end note

note right of UC_RecordRationale
  **Rationale Capture:**
  
  Constraint: TLS 1.3 minimum
  
  Rationale:
  - Security: TLS 1.2 vulnerabilities
  - Compliance: PCI-DSS 4.0 requirement
  - Performance: TLS 1.3 is faster
  - Decision Date: 2024-01-15
  - Approved By: Security Council
end note

note right of UC_CaptureHeuristics
  **Expert Heuristic Example:**
  
  Expert says: "Database connection
  pools should be sized at
  2x expected concurrent queries"
  
  Encoded as:
  threshold(db.pool_size, ">=",
            metrics.concurrent_queries * 2)
end note

note right of UC_TrackEffectiveness
  **Decision Effectiveness:**
  
  Constraint: auto-scale on CPU > 70%
  
  Decisions made: 1,247
  Successful outcomes: 1,198
  False positives: 32
  Missed events: 17
  
  Effectiveness: 96%
  Recommendation: Adjust to 75%
end note

@enduml
