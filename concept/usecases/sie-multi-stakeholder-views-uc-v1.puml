@startuml sie-multi-stakeholder-views-uc-v1

' ============================================================
' VISUAL THEME
' ============================================================

left to right direction
skinparam shadowing false
skinparam roundcorner 12
skinparam ArrowColor #57606A
skinparam DefaultFontName "SansSerif"
skinparam backgroundColor #FFFFFF

skinparam actorBackgroundColor #FFFFFF
skinparam actorBorderColor #57606A

skinparam usecaseBackgroundColor #F6F8FA
skinparam usecaseBorderColor #57606A

skinparam rectangleBackgroundColor #FFFFFF
skinparam rectangleBorderColor #57606A

skinparam noteBackgroundColor #FFF8C5
skinparam noteBorderColor #57606A

' ============================================================

title UC - SIE Multi-Stakeholder Views - v1

' ============================================================
' ACTORS
' ============================================================

actor "Developer" as Developer
actor "System Architect" as Architect
actor "Executive" as Executive
actor "Auditor" as Auditor
actor "Governance Officer" as GovOfficer

actor "View Renderer" as ViewRenderer <<system>>
actor "CSDM Repository" as CsdmRepo <<system>>
actor "LLM Service" as LLM <<system>>
actor "Dashboard API" as DashboardAPI <<system>>

' ============================================================
' USE CASES
' ============================================================

rectangle "Multi-Stakeholder Views" {

  ' --- Developer View ---
  package "Developer View" {
    usecase "Show Constraint Violations\nwith Code Locations" as UC_ViolationsCode
    usecase "Provide Quick-Fix\nSuggestions" as UC_QuickFix
    usecase "Display Integration\nPatterns" as UC_IntegrationPatterns
    usecase "Offer Local Testing\nTools" as UC_LocalTesting
  }

  ' --- Architect View ---
  package "Architect View" {
    usecase "Show Cross-System\nAlignment" as UC_CrossSystemAlign
    usecase "Display Architecture\nDebt Indicators" as UC_ArchDebt
    usecase "Render Pattern\nCompliance Dashboard" as UC_PatternCompliance
    usecase "Show Evolution\nRoadmap Impacts" as UC_RoadmapImpacts
  }

  ' --- Executive View ---
  package "Executive View" {
    usecase "Display Aggregated\nCompliance Scores" as UC_ComplianceScores
    usecase "Show Business\nRisk Indicators" as UC_BusinessRisk
    usecase "Provide Trend\nSummaries" as UC_TrendSummaries
    usecase "Offer Investment\nPrioritization" as UC_InvestmentPriority
  }

  ' --- Auditor View ---
  package "Auditor View" {
    usecase "Provide Audit\nTrails" as UC_AuditTrails
    usecase "Generate Compliance\nEvidence" as UC_ComplianceEvidence
    usecase "Show Policy\nAttestation Records" as UC_AttestationRecords
    usecase "Create Regulatory\nMapping Reports" as UC_RegulatoryMapping
  }

  ' --- Governance View ---
  package "Governance View" {
    usecase "Display Policy\nEffectiveness Metrics" as UC_PolicyEffectiveness
    usecase "Track Exception\nManagement" as UC_ExceptionManagement
    usecase "Show Constraint\nEvolution History" as UC_EvolutionHistory
    usecase "Monitor Governance\nProcess Compliance" as UC_ProcessCompliance
  }
}

' ============================================================
' RELATIONSHIPS - Actors to Use Cases
' ============================================================

' Developer interactions
Developer --> UC_ViolationsCode
Developer --> UC_QuickFix
Developer --> UC_IntegrationPatterns
Developer --> UC_LocalTesting

' Architect interactions
Architect --> UC_CrossSystemAlign
Architect --> UC_ArchDebt
Architect --> UC_PatternCompliance
Architect --> UC_RoadmapImpacts

' Executive interactions
Executive --> UC_ComplianceScores
Executive --> UC_BusinessRisk
Executive --> UC_TrendSummaries
Executive --> UC_InvestmentPriority

' Auditor interactions
Auditor --> UC_AuditTrails
Auditor --> UC_ComplianceEvidence
Auditor --> UC_AttestationRecords
Auditor --> UC_RegulatoryMapping

' Governance Officer interactions
GovOfficer --> UC_PolicyEffectiveness
GovOfficer --> UC_ExceptionManagement
GovOfficer --> UC_EvolutionHistory
GovOfficer --> UC_ProcessCompliance

' ============================================================
' RELATIONSHIPS - System Actors
' ============================================================

UC_ViolationsCode --> CsdmRepo
UC_QuickFix --> LLM
UC_IntegrationPatterns --> CsdmRepo
UC_LocalTesting --> ViewRenderer

UC_CrossSystemAlign --> CsdmRepo
UC_ArchDebt --> CsdmRepo
UC_PatternCompliance --> DashboardAPI
UC_RoadmapImpacts --> CsdmRepo

UC_ComplianceScores --> DashboardAPI
UC_BusinessRisk --> CsdmRepo
UC_TrendSummaries --> DashboardAPI
UC_InvestmentPriority --> LLM

UC_AuditTrails --> CsdmRepo
UC_ComplianceEvidence --> CsdmRepo
UC_AttestationRecords --> CsdmRepo
UC_RegulatoryMapping --> CsdmRepo

UC_PolicyEffectiveness --> CsdmRepo
UC_ExceptionManagement --> CsdmRepo
UC_EvolutionHistory --> CsdmRepo
UC_ProcessCompliance --> CsdmRepo

' ============================================================
' RELATIONSHIPS - Include/Extend
' ============================================================

UC_ViolationsCode ..> UC_QuickFix : <<extend>>
UC_ArchDebt ..> UC_PatternCompliance : <<include>>
UC_ComplianceScores ..> UC_TrendSummaries : <<include>>
UC_AuditTrails ..> UC_ComplianceEvidence : <<include>>
UC_PolicyEffectiveness ..> UC_EvolutionHistory : <<include>>

' ============================================================
' NOTES
' ============================================================

note right of UC_ViolationsCode
  **Developer View Example:**
  
  ❌ Violation in order-service
  File: src/api/orders.ts:47
  Rule: SQL injection prevention
  
  Quick Fix: Use parameterized query
  [Apply Fix] [Show Pattern]
end note

note right of UC_ComplianceScores
  **Executive Dashboard:**
  
  Overall Compliance: 94.2%
  ▲ +2.1% from last quarter
  
  Risk Areas:
  • Data Residency: 87%
  • API Security: 91%
  
  Investment Needed: $240K
end note

note right of UC_AuditTrails
  **Audit Trail Entry:**
  
  2024-03-15T14:32:07Z
  Policy: Data-Encryption-At-Rest
  Decision: COMPLIANT
  Evidence: encryption.enabled=true
  Attestor: system-scanner-v2.1
end note

note right of UC_RoadmapImpacts
  **Roadmap Impact Analysis:**
  
  Planned: Migrate to K8s
  
  Affected Policies: 12
  Affected Rules: 47
  Migration Effort: 3 sprints
  
  New Constraints Needed: 8
end note

@enduml
