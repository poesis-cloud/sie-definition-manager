@startuml sie-temporal-analytics-uc-v1

' ============================================================
' VISUAL THEME
' ============================================================

left to right direction
skinparam shadowing false
skinparam roundcorner 12
skinparam ArrowColor #57606A
skinparam DefaultFontName "SansSerif"
skinparam backgroundColor #FFFFFF

skinparam actorBackgroundColor #FFFFFF
skinparam actorBorderColor #57606A

skinparam usecaseBackgroundColor #F6F8FA
skinparam usecaseBorderColor #57606A

skinparam rectangleBackgroundColor #FFFFFF
skinparam rectangleBorderColor #57606A

skinparam noteBackgroundColor #FFF8C5
skinparam noteBorderColor #57606A

' ============================================================

title UC - SIE Temporal Analytics - v1

' ============================================================
' ACTORS
' ============================================================

actor "SRE Engineer" as SRE
actor "Capacity Planner" as CapPlanner
actor "Compliance Officer" as CompOfficer
actor "System Architect" as Architect
actor "Operations Manager" as OpsMgr

actor "Time Series DB" as TSDB <<system>>
actor "Alert System" as Alerts <<system>>
actor "ML Service" as ML <<system>>

' ============================================================
' USE CASES
' ============================================================

rectangle "Temporal Analytics" {

  ' --- Trend Detection ---
  package "Trend Detection" {
    usecase "Detect Quality\nTrends" as UC_QualityTrends
    usecase "Identify Seasonal\nPatterns" as UC_SeasonalPatterns
    usecase "Flag Accelerating\nDeviation" as UC_AcceleratingDev
    usecase "Correlate Related\nMetric Trends" as UC_CorrelateMetrics
  }

  ' --- Historical Correlation ---
  package "Historical Correlation" {
    usecase "Link Violations to\nPast Root Causes" as UC_PastRootCauses
    usecase "Identify Recurring\nFailure Patterns" as UC_RecurringFailures
    usecase "Suggest Fixes from\nHistorical Resolutions" as UC_HistoricalFixes
    usecase "Build Institutional\nMemory" as UC_InstitutionalMemory
  }

  ' --- Forecasting ---
  package "Forecasting" {
    usecase "Project Threshold\nBreach Timing" as UC_BreachTiming
    usecase "Estimate Time to\nViolation" as UC_TimeToViolation
    usecase "Forecast Resource\nExhaustion" as UC_ResourceExhaustion
    usecase "Predict Compliance\nDrift" as UC_ComplianceDrift
  }

  ' --- Drift Detection ---
  package "Drift Detection" {
    usecase "Detect Configuration\nDrift" as UC_ConfigDrift
    usecase "Identify Behavioral\nDrift" as UC_BehavioralDrift
    usecase "Flag Semantic\nDrift" as UC_SemanticDrift
    usecase "Monitor Policy\nErosion" as UC_PolicyErosion
  }

  ' --- Anomaly Detection ---
  package "Anomaly Detection" {
    usecase "Detect Evaluation\nOutliers" as UC_EvalOutliers
    usecase "Flag Unexpected\nInteraction Patterns" as UC_UnexpectedPatterns
    usecase "Identify Sudden\nBehavior Changes" as UC_SuddenChanges
    usecase "Distinguish Noise\nfrom Anomalies" as UC_NoiseVsAnomaly
  }
}

' ============================================================
' RELATIONSHIPS - Actors to Use Cases
' ============================================================

' SRE interactions
SRE --> UC_QualityTrends
SRE --> UC_AcceleratingDev
SRE --> UC_RecurringFailures
SRE --> UC_EvalOutliers
SRE --> UC_SuddenChanges

' Capacity Planner interactions
CapPlanner --> UC_SeasonalPatterns
CapPlanner --> UC_BreachTiming
CapPlanner --> UC_ResourceExhaustion
CapPlanner --> UC_CorrelateMetrics

' Compliance Officer interactions
CompOfficer --> UC_ComplianceDrift
CompOfficer --> UC_PolicyErosion
CompOfficer --> UC_SemanticDrift
CompOfficer --> UC_InstitutionalMemory

' Architect interactions
Architect --> UC_BehavioralDrift
Architect --> UC_PastRootCauses
Architect --> UC_HistoricalFixes

' Operations Manager interactions
OpsMgr --> UC_TimeToViolation
OpsMgr --> UC_ConfigDrift
OpsMgr --> UC_UnexpectedPatterns
OpsMgr --> UC_NoiseVsAnomaly

' ============================================================
' RELATIONSHIPS - System Actors
' ============================================================

UC_QualityTrends --> TSDB
UC_SeasonalPatterns --> TSDB
UC_AcceleratingDev --> TSDB
UC_CorrelateMetrics --> TSDB

UC_PastRootCauses --> TSDB
UC_RecurringFailures --> TSDB
UC_HistoricalFixes --> TSDB
UC_InstitutionalMemory --> TSDB

UC_BreachTiming --> ML
UC_TimeToViolation --> ML
UC_ResourceExhaustion --> ML
UC_ComplianceDrift --> ML

UC_ConfigDrift --> TSDB
UC_BehavioralDrift --> TSDB
UC_SemanticDrift --> TSDB
UC_PolicyErosion --> TSDB

UC_EvalOutliers --> ML
UC_UnexpectedPatterns --> ML
UC_SuddenChanges --> Alerts
UC_NoiseVsAnomaly --> ML

' ============================================================
' RELATIONSHIPS - Include/Extend
' ============================================================

UC_AcceleratingDev ..> UC_QualityTrends : <<include>>
UC_TimeToViolation ..> UC_AcceleratingDev : <<include>>
UC_RecurringFailures ..> UC_PastRootCauses : <<extend>>
UC_SuddenChanges ..> UC_NoiseVsAnomaly : <<include>>

' ============================================================
' NOTES
' ============================================================

note right of UC_BreachTiming
  **Forecast Example:**
  Database connection pool usage:
  - Current: 72%
  - Trend: +2.3%/week
  - Projected breach: 12 days
  
  Recommendation: Scale before breach
end note

note right of UC_ConfigDrift
  Compares current state against:
  - Last known good configuration
  - Desired state specification
  - Baseline from last deployment
  
  Triggers reconciliation if drift > threshold
end note

note right of UC_RecurringFailures
  Pattern matching across incidents:
  - Memory leak after deployment
  - Connection timeout during peak
  - Certificate expiry monthly
  
  Proactively prevents known failures
end note

note right of UC_NoiseVsAnomaly
  Uses statistical methods:
  - Standard deviation analysis
  - Isolation forests
  - Seasonal decomposition
  
  Reduces alert fatigue
end note

@enduml
