@startuml sie-decision-intelligence-uc-v1

' ============================================================
' VISUAL THEME
' ============================================================

left to right direction
skinparam shadowing false
skinparam roundcorner 12
skinparam ArrowColor #57606A
skinparam DefaultFontName "SansSerif"
skinparam backgroundColor #FFFFFF

skinparam actorBackgroundColor #FFFFFF
skinparam actorBorderColor #57606A

skinparam usecaseBackgroundColor #F6F8FA
skinparam usecaseBorderColor #57606A

skinparam rectangleBackgroundColor #FFFFFF
skinparam rectangleBorderColor #57606A

skinparam noteBackgroundColor #FFF8C5
skinparam noteBorderColor #57606A

' ============================================================

title UC - SIE Decision Intelligence - v1

' ============================================================
' ACTORS
' ============================================================

actor "Auditor" as Auditor
actor "Compliance Officer" as CompOfficer
actor "Legal Counsel" as Legal
actor "Security Analyst" as SecAnalyst
actor "Governance Officer" as GovOfficer

actor "Decision Log Store" as DecisionLog <<system>>
actor "Audit Archive" as AuditArchive <<system>>
actor "Reporting Engine" as ReportEngine <<system>>
actor "Evidence Vault" as EvidenceVault <<system>>

' ============================================================
' USE CASES
' ============================================================

rectangle "Decision Intelligence" {

  ' --- Decision Logging ---
  package "Decision Logging" {
    usecase "Record Decision Context\nInputs and Outputs" as UC_RecordDecision
    usecase "Preserve Constraint\nVersions Used" as UC_PreserveVersions
    usecase "Link Decisions to\nTriggering Events" as UC_LinkToEvents
    usecase "Support Decision\nReplay" as UC_DecisionReplay
  }

  ' --- Audit Trail ---
  package "Audit Trail" {
    usecase "Maintain Tamper-Evident\nRecords" as UC_TamperEvident
    usecase "Support Time-Based\nQueries" as UC_TimeBasedQueries
    usecase "Preserve Chain\nof Custody" as UC_ChainOfCustody
    usecase "Enable Forensic\nAnalysis" as UC_ForensicAnalysis
  }

  ' --- Compliance Reporting ---
  package "Compliance Reporting" {
    usecase "Generate Regulatory\nAttestations" as UC_RegulatoryAttestations
    usecase "Produce Periodic\nCompliance Summaries" as UC_PeriodicSummaries
    usecase "Create Audit\nEvidence Packages" as UC_EvidencePackages
    usecase "Map Decisions to\nCompliance Frameworks" as UC_FrameworkMapping
  }

  ' --- Evidence Preservation ---
  package "Evidence Preservation" {
    usecase "Archive Decision\nArtifacts" as UC_ArchiveArtifacts
    usecase "Maintain Legally\nDefensible Records" as UC_LegalRecords
    usecase "Support E-Discovery\nRequirements" as UC_EDiscovery
    usecase "Manage Retention\nPolicies" as UC_RetentionPolicies
  }
}

' ============================================================
' RELATIONSHIPS - Actors to Use Cases
' ============================================================

' Auditor interactions
Auditor --> UC_TimeBasedQueries
Auditor --> UC_TamperEvident
Auditor --> UC_EvidencePackages
Auditor --> UC_ForensicAnalysis
Auditor --> UC_DecisionReplay

' Compliance Officer interactions
CompOfficer --> UC_RegulatoryAttestations
CompOfficer --> UC_PeriodicSummaries
CompOfficer --> UC_FrameworkMapping
CompOfficer --> UC_ChainOfCustody

' Legal Counsel interactions
Legal --> UC_LegalRecords
Legal --> UC_EDiscovery
Legal --> UC_RetentionPolicies
Legal --> UC_ChainOfCustody

' Security Analyst interactions
SecAnalyst --> UC_RecordDecision
SecAnalyst --> UC_LinkToEvents
SecAnalyst --> UC_ForensicAnalysis
SecAnalyst --> UC_TimeBasedQueries

' Governance Officer interactions
GovOfficer --> UC_PreserveVersions
GovOfficer --> UC_ArchiveArtifacts
GovOfficer --> UC_RetentionPolicies
GovOfficer --> UC_PeriodicSummaries

' ============================================================
' RELATIONSHIPS - System Actors
' ============================================================

UC_RecordDecision --> DecisionLog
UC_PreserveVersions --> DecisionLog
UC_LinkToEvents --> DecisionLog
UC_DecisionReplay --> DecisionLog

UC_TamperEvident --> AuditArchive
UC_TimeBasedQueries --> AuditArchive
UC_ChainOfCustody --> AuditArchive
UC_ForensicAnalysis --> AuditArchive

UC_RegulatoryAttestations --> ReportEngine
UC_PeriodicSummaries --> ReportEngine
UC_EvidencePackages --> ReportEngine
UC_FrameworkMapping --> ReportEngine

UC_ArchiveArtifacts --> EvidenceVault
UC_LegalRecords --> EvidenceVault
UC_EDiscovery --> EvidenceVault
UC_RetentionPolicies --> EvidenceVault

' ============================================================
' RELATIONSHIPS - Include/Extend
' ============================================================

UC_RecordDecision ..> UC_PreserveVersions : <<include>>
UC_RecordDecision ..> UC_LinkToEvents : <<include>>
UC_EvidencePackages ..> UC_TamperEvident : <<include>>
UC_ForensicAnalysis ..> UC_TimeBasedQueries : <<include>>
UC_LegalRecords ..> UC_ChainOfCustody : <<include>>

' ============================================================
' NOTES
' ============================================================

note right of UC_RecordDecision
  **Decision Log Entry:**
  
  ID: dec-2024-03-15-14327
  Timestamp: 2024-03-15T14:32:07Z
  Policy: network-segmentation-v3
  Input: {service: "payments", zone: "dmz"}
  Output: DENY
  Reason: "PCI services cannot reside in DMZ"
end note

note right of UC_TamperEvident
  **Tamper Evidence:**
  
  - Cryptographic hashing (SHA-256)
  - Merkle tree for batch verification
  - Blockchain-style chaining
  - Digital signatures on entries
  
  Detects any modification attempt
end note

note right of UC_FrameworkMapping
  **Framework Mapping:**
  
  Decision → Framework Controls:
  • SOC 2 CC6.1 (Access Control)
  • ISO 27001 A.9.1.2 (Networks)
  • PCI-DSS 1.2 (Segmentation)
  
  Auto-generates compliance evidence
end note

note right of UC_EDiscovery
  **E-Discovery Support:**
  
  Query: All decisions affecting
  "customer-data" service between
  Jan 1 - Mar 31, 2024
  
  Results: 12,847 decisions
  Export: JSON, CSV, PDF
  Chain of custody: Preserved
end note

@enduml
