@startuml sie-homeostasis-v1

' ============================================================
' VISUAL THEME
' ============================================================

skinparam shadowing false
skinparam roundcorner 12
skinparam ArrowColor #57606A
skinparam DefaultFontName "SansSerif"
skinparam backgroundColor #FFFFFF

skinparam rectangle {
  BackgroundColor #FFFFFF
  BorderColor #57606A
  FontColor #24292F
}

skinparam component {
  BackgroundColor #F6F8FA
  BorderColor #57606A
}

skinparam noteBackgroundColor #FFF8C5
skinparam noteBorderColor #57606A

skinparam package {
  BackgroundColor #F6F8FA
  BorderColor #57606A
}

title SIE - Homeostatic Feedback Loop Topology - v1

' ============================================================
' FOUR-PLANE ARCHITECTURE
' ============================================================

rectangle "**DEFINITION PLANE** (What SHOULD be)" as DefPlane #E8F4E8 {
  
  package "Governance Hierarchy" as GovHierarchy {
    
    rectangle "Governor\nController" as Governor #FFFFFF {
      component "Owns:\nPolicy" as GovPolicy
      component "Receptor:\nFeedbackEvent" as GovReceptor
      component "Effector:\nPolicyEvent" as GovEffector
    }
    
    rectangle "Supervisor\nController" as Supervisor #FFFFFF {
      component "Owns:\nBehavioralRule" as SupRule
      component "Receptor:\nPolicyEvent" as SupReceptor
      component "Effector:\nRuleEvent" as SupEffector
    }
    
    rectangle "Operator\nController" as Operator #FFFFFF {
      component "Realizes:\nBehavioralRule" as OpRule
      component "Receptor:\nRuleEvent" as OpReceptor
      component "Effector:\nActuationControlEvent" as OpEffector
    }
  }
  
  package "Observation Mechanisms" as ObsMechs {
    rectangle "Sensor\nMechanism" as Sensor #FFFFFF {
      component "Receptor:\nActuationFeedbackEvent" as SensorReceptor
      component "Effector:\nMeasurementEvent" as SensorEffector
    }
  }
}

rectangle "**DESCRIPTION PLANE** (What IS KNOWN)" as DescPlane #E8E8F4 {
  component "Observations\n(Use cases, Risks,\nIncidents, Metrics)" as Observations
  component "LLM Interpretation\n(Intent extraction)" as LLMInterp
}

rectangle "**REGULATION PLANE** (What ACTS)" as RegPlane #F4E8E8 {
  rectangle "Actuator\nMechanism" as Actuator #FFFFFF {
    component "Receptor:\nActuationControlEvent" as ActReceptor
    component "Effector:\nActuationEvent" as ActEffector
  }
  
  component "Control Executors\n(IaC, API, Pipelines)" as Executors
}

rectangle "**STATE PLANE** (What IS)" as StatePlane #F4F4E8 {
  component "External Systems\n(Logs, Metrics, Configs,\nCMDB, Runtime)" as ExtSystems
}

' ============================================================
' VERTICAL HOMEOSTATIC LOOP (Primary)
' ============================================================

' Governor → Supervisor (Policy propagation)
GovEffector -[#2E7D32,bold]-> SupReceptor : "1. Policy\npublished"

' Supervisor → Operator (Rule propagation)
SupEffector -[#2E7D32,bold]-> OpReceptor : "2. BehavioralRule\noperationalized"

' Operator → Actuator (Control command)
OpEffector -[#2E7D32,bold]-> ActReceptor : "3. Actuation\ncontrol"

' Actuator → External Systems (Action)
ActEffector -[#D32F2F,bold]-> ExtSystems : "4. Execute\naction"

' External Systems → Sensor (State observation)
ExtSystems -[#1565C0,bold]-> SensorReceptor : "5. State\nobserved"

' Sensor → Governor (Feedback)
SensorEffector -[#1565C0,bold]-> GovReceptor : "6. Measurement\nfeedback"

' ============================================================
' HORIZONTAL HOMEOSTATIC LOOP (Inter-Governor)
' ============================================================

rectangle "Governor B\n(Other Domain)" as GovernorB #E8F4E8 {
}

GovEffector .[#9C27B0,dashed].> GovernorB : "H1. Cross-domain\ncoherence"
GovernorB .[#9C27B0,dashed].> GovReceptor : "H2. Inter-governor\nfeedback"

' ============================================================
' DESCRIPTION PLANE INTEGRATION
' ============================================================

ExtSystems -[#FF9800]-> Observations : "Sense"
Observations -[#FF9800]-> LLMInterp : "Interpret"
LLMInterp -[#FF9800]-> GovReceptor : "Inform\nemergence"

' ============================================================
' REGULATION PLANE EXECUTION
' ============================================================

Actuator -[#D32F2F]-> Executors : "Delegate"
Executors -[#D32F2F]-> ExtSystems : "Modify\nstate"

' ============================================================
' LEGEND
' ============================================================

legend bottom
  |= Color |= Meaning |
  | <#2E7D32> | Constraint propagation (Definition → Regulation) |
  | <#D32F2F> | Regulation execution (Regulation → State) |
  | <#1565C0> | Feedback observation (State → Definition) |
  | <#9C27B0> | Horizontal coherence (Governor ↔ Governor) |
  | <#FF9800> | Description integration (State → Definition via Observation) |
  
  **Homeostasis**: The continuous cycle maintaining alignment between
  Definition (SHOULD), Regulation (DOES), and State (IS).
  
  **Ashby's Ultrastability**: Multi-level feedback where:
  - Level 1: Operator adjusts behavior based on Rule
  - Level 2: Supervisor adjusts Rule based on Policy
  - Level 3: Governor adjusts Policy based on Measurement
  - Level H: Governors coordinate across domains
endlegend

' ============================================================
' ANNOTATIONS
' ============================================================

note right of Governor
  **Governor owns Policy**
  Defines high-level constraints.
  Receives feedback from Sensors.
  Adjusts Policy based on deviation.
end note

note right of Supervisor
  **Supervisor operationalizes Policy**
  Derives BehavioralRules from Policies.
  Provides feasibility assessment.
end note

note right of Operator
  **Operator realizes BehavioralRule**
  IS DEFINED BY the rule.
  Existential relationship.
end note

note right of Actuator
  **Actuator executes on State**
  Translates ActuationControlEvents
  into actual state changes.
  Part of Regulation Plane.
end note

note right of Sensor
  **Sensor auto-defined from Policy**
  When Policy has evaluationCriteria,
  Sensor SHOULD be auto-created.
  Closes the homeostatic loop.
end note

note bottom of DescPlane
  **Description Plane**
  Captures observations that inform
  emergence (new primitives) and
  coherence (deviation detection).
  
  Decoupled storage (Document DB).
  URI-referenced, LLM-interpreted.
end note

@enduml
