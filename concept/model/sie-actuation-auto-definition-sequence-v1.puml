@startuml sie-actuation-auto-definition-sequence-v1

' ============================================================
' VISUAL THEME
' ============================================================

skinparam shadowing false
skinparam roundcorner 12
skinparam ArrowColor #57606A
skinparam DefaultFontName "SansSerif"
skinparam backgroundColor #FFFFFF

skinparam sequence {
  ParticipantBackgroundColor #FFFFFF
  ParticipantBorderColor #57606A
  LifeLineBackgroundColor #F6F8FA
  LifeLineBorderColor #57606A
  ArrowColor #57606A
  DividerBackgroundColor #F6F8FA
}

skinparam noteBackgroundColor #FFF8C5
skinparam noteBorderColor #57606A

title SIE - Actuation Auto-Definition Rule - v1

' ============================================================
' PARTICIPANTS
' ============================================================

actor "User" as User
participant "Modeling UI" as UI
participant "CSDM Engine" as Csdm
participant "BehavioralRuleControl" as BRC
participant "Actuation" as Actuation
participant "ActuatorMechanism" as Actuator
participant "Sensing" as Sensing
participant "SensorMechanism" as Sensor

' ============================================================
' ACTUATION DECLARATION FLOW
' ============================================================

== Declare Actuation ==

User -> UI : defineBehavioralRuleControl(..., declaredActuation)
UI -> Csdm : validateActuationDeclaration()

note right of Csdm
  Validation:
  - Control effector event is ActuationControlEvent
  - Target StateObjectArchetype belongs to
    same System or shared subsystem
end note

alt Validation OK
  Csdm -> BRC : persist(declaredActuation)
  Csdm -> Actuation : create(declaredBy=BRC)
  Csdm -> Actuator : create(composedBy=Actuation)
  Csdm -> Actuator : bindReceptor(controlEffectorEvent)
  Csdm -> Csdm : autoDefine(ActuationEventArchetype)
  Csdm -> Actuator : bindEffector(actuationEvent)

  alt Feedback receptor defined on control
    Csdm -> Sensing : create(observes=Actuation)
    Csdm -> Sensor : create(composedBy=Sensing)
    Csdm -> Sensor : bindReceptor(actuationEvent)
    Csdm -> Sensor : bindEffector(feedbackEvent)
  else No feedback receptor
    note right of Csdm
      No SensorMechanism is defined
      when no control feedback receptor exists.
    end note
  end

else Validation Failed
  Csdm -> UI : rejectActuation(incoherence)
end

@enduml
