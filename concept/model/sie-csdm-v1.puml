  ' ============================================================

  System "1" *--> "1" Boundary : has
  System "1" *--> "0..*" Component : has
  System "1" *--> "0..*" Capacity : has
  System "1" *--> "0..*" StateObjectArchetype : has

  System "0..*" o--> "0..*" System : hasSuper
  System "0..*" *--> "0..*" System : hasSub
  System "1" *--> "0..*" Interface : has

  System "1" *--> "0..*" Modality : has

  System "1" *--> "0..*" Mechanism : implements
  System "1" *--> "0..*" Interaction : participatesIn
  System "1" o--> "0..*" EventArchetype : handles

  Interface "1" *--> "0..*" Receptor : has
  Interface "1" *--> "0..*" Effector : has
  Interface "1" *--> "0..*" Channel : has
