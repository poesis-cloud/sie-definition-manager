@startuml itip-schema-abstraction-v1

' ============================================================================
' CD - Schema Management Model - v1
' ============================================================================
' This diagram defines an abstraction layer for property schema definitions,
' enabling support for multiple schema technologies (JSON Schema, RDF+OWL,
' XML Schema, Avro, etc.) without impacting consuming models like CSDM.
'
' Design Patterns:
'   - Dependency Inversion Principle (DIP)
'   - Strategy Pattern
'   - Adapter Pattern (for implementations and value conversion)
'
' External Model References:
'   - JSONSchema:: → concept/model/json-schema/itip-json-schema-v1.puml
'   - RDFOWL::     → concept/model/rdf-owl/itip-rdf-owl-v1.puml (future)
'   - XSD::        → concept/model/xml-schema/itip-xsd-v1.puml (future)
'   - Avro::       → concept/model/avro/itip-avro-v1.puml (future)
'
' Consumer Model References:
'   - CSDM::Value → concept/model/systemics-layer/aggregates/
'                   itip-model-systemic-definition-v1.puml
' ============================================================================

skinparam linetype ortho
skinparam classAttributeIconSize 0
skinparam packageStyle rectangle
hide empty members

' Color definitions
skinparam package {
    BackgroundColor<<abstraction>> #FFFFF0
    BackgroundColor<<canonical>> #F0FFF0
    BackgroundColor<<implementation>> #F0F0FF
    BackgroundColor<<validation>> #FFF0F0
    BackgroundColor<<adapter>> #FFE6F0
}

skinparam class {
    BackgroundColor<<interface>> #FFFFCC
    BackgroundColor<<enum>> #E6E6FF
}

frame "CD - Schema Management Model - v1" {

    ' ========================================================================
    ' VALUE ADAPTER (CONVERTS CONSUMER VALUES TO SCHEMA-SPECIFIC FORMAT)
    ' ========================================================================

    package "Value Adapter" <<adapter>> {

        abstract class ValueAdapter <<interface>> {
            +getSchemaType(): SchemaType
            +convert(value: Any): Any
            +convertBack(schemaValue: Any): Any
        }

        note top of ValueAdapter
            **ValueAdapter** decouples consumer value types
            (e.g., CSDM::Value) from schema-specific formats.
            
            Each schema implementation provides its own adapter:
            - JSONValueAdapter: Value → JSONValue
            - RDFValueAdapter: Value → RDF Literal/Resource
            - XMLValueAdapter: Value → XML DOM Node
            
            **This allows CSDM::Value to remain schema-agnostic.**
        end note

        class JSONValueAdapter {
            +convert(value: Any): JSONSchema::JSONValue
            +convertBack(jsonValue: JSONSchema::JSONValue): Any
        }

        note bottom of JSONValueAdapter
            **Value → JSON Mapping:**
            | Input Type   | JSON Output    |
            |--------------|----------------|
            | String       | JSONString     |
            | Number       | JSONNumber     |
            | Boolean      | JSONBoolean    |
            | null         | JSONNull       |
            | List         | JSONArray      |
            | Map          | JSONObject     |
            | DateTime     | JSONString*    |
            
            *DateTime → ISO 8601 string
        end note

        class RDFValueAdapter {
            +convert(value: Any): RDFNode
            +convertBack(rdfNode: RDFNode): Any
            +getDatatype(value: Any): IRI
        }

        note bottom of RDFValueAdapter
            **Value → RDF Mapping:**
            | Input Type   | RDF Output           |
            |--------------|----------------------|
            | String       | xsd:string Literal   |
            | Number       | xsd:decimal Literal  |
            | Boolean      | xsd:boolean Literal  |
            | DateTime     | xsd:dateTime Literal |
            | Reference    | IRI / Blank Node     |
        end note

        class XMLValueAdapter {
            +convert(value: Any): XMLNode
            +convertBack(xmlNode: XMLNode): Any
        }

        class AvroValueAdapter {
            +convert(value: Any): GenericRecord
            +convertBack(record: GenericRecord): Any
        }

    }

    ' ========================================================================
    ' SCHEMA DEFINITION ABSTRACTION
    ' ========================================================================

    package "Schema Definition (Abstraction)" <<abstraction>> {

        abstract class SchemaDefinition <<interface>> {
            +getId(): UUID
            +getSchemaType(): SchemaType
            +getSourceURI(): URI
            +getValueAdapter(): ValueAdapter
            +validate(instance: Any): ValidationResult
            +toCanonicalForm(): CanonicalSchemaRepresentation
            +getMetadata(): SchemaMetadata
        }

        note top of SchemaDefinition
            **SchemaDefinition** is the core abstraction
            that isolates consumers from specific schema
            technologies.
            
            **Design Principles:**
            - Dependency Inversion: Consumers depend on
              this abstraction, not concrete schemas
            - Open/Closed: Add new schemas without
              modifying consumers
            - Strategy Pattern: Swap implementations
            
            **Contract:**
            - getValueAdapter(): Get adapter for value conversion
            - validate(): Check an instance against schema
            - toCanonicalForm(): Convert to neutral form
              for cross-schema interoperability
        end note

        enum SchemaType <<enum>> {
            JSON_SCHEMA
            RDF_OWL
            SHACL
            XML_SCHEMA
            AVRO
            PROTOBUF
            THRIFT
            CUSTOM
        }

        class SchemaMetadata {
            +getTitle(): String
            +getDescription(): String
            +getVersion(): String
            +getAuthors(): String[]
            +getLicense(): String
            +getKeywords(): String[]
            +getDeprecated(): Boolean
            +getSeeAlso(): URI[]
        }

        note right of SchemaMetadata
            Common metadata across all
            schema technologies.
            Maps to:
            - JSON Schema: title, description
            - OWL: rdfs:label, rdfs:comment
            - XSD: xs:documentation
        end note

    }

    ' ========================================================================
    ' CANONICAL REPRESENTATION
    ' ========================================================================

    package "Canonical Representation" <<canonical>> {

        class CanonicalSchemaRepresentation {
            +getId(): UUID
            +getDataType(): CanonicalDataType
            +getConstraints(): CanonicalConstraint[]
            +getStructure(): CanonicalStructure
            +getMetadata(): SchemaMetadata
            +isNullable(): Boolean
        }

        note top of CanonicalSchemaRepresentation
            **Canonical Form** serves as a
            "lingua franca" between different
            schema languages.
            
            **Enables:**
            - Schema comparison across technologies
            - Schema migration/conversion
            - Unified constraint extraction
            - Cross-schema validation
            
            **Mapping examples:**
            | Canonical    | JSON Schema | OWL/RDF        | XSD           |
            |--------------|-------------|----------------|---------------|
            | STRING       | "string"    | xsd:string     | xs:string     |
            | INTEGER      | "integer"   | xsd:integer    | xs:integer    |
            | OBJECT       | "object"    | owl:Class      | xs:complexType|
            | ARRAY        | "array"     | rdf:List       | xs:sequence   |
        end note

        enum CanonicalDataType <<enum>> {
            .. Primitives ..
            STRING
            INTEGER
            DECIMAL
            BOOLEAN
            .. Temporal ..
            DATE
            DATETIME
            TIME
            DURATION
            .. Identifiers ..
            URI
            IRI
            UUID
            .. Binary ..
            BINARY
            BASE64
            .. Structures ..
            ARRAY
            OBJECT
            MAP
            .. References ..
            REFERENCE
            .. Special ..
            ENUM
            UNION
            ANY
            NONE
        }

        ' ====================================================================
        ' CANONICAL CONSTRAINTS
        ' ====================================================================

        abstract class CanonicalConstraint {
            +getConstraintType(): ConstraintType
            +getErrorMessage(): String
        }

        enum ConstraintType <<enum>> {
            RANGE
            LENGTH
            PATTERN
            ENUMERATION
            CARDINALITY
            UNIQUENESS
            FORMAT
            CUSTOM
        }

        class RangeConstraint {
            +getMinimum(): Number
            +getMaximum(): Number
            +isMinExclusive(): Boolean
            +isMaxExclusive(): Boolean
        }

        note right of RangeConstraint
            Maps to:
            - JSON Schema: minimum, maximum,
              exclusiveMinimum, exclusiveMaximum
            - OWL: xsd:minInclusive, xsd:maxInclusive
            - XSD: minInclusive, maxInclusive
        end note

        class LengthConstraint {
            +getMinLength(): Integer
            +getMaxLength(): Integer
        }

        class PatternConstraint {
            +getPattern(): String
            +getPatternSyntax(): PatternSyntax
            +getFlags(): String
        }

        enum PatternSyntax <<enum>> {
            ECMASCRIPT_REGEX
            POSIX_REGEX
            PCRE
            XPATH_REGEX
            SPARQL_REGEX
            GLOB
        }

        class EnumerationConstraint {
            +getAllowedValues(): Any[]
            +isCaseSensitive(): Boolean
        }

        class CardinalityConstraint {
            +getMinOccurs(): Integer
            +getMaxOccurs(): Integer
            +isUnbounded(): Boolean
        }

        note right of CardinalityConstraint
            Maps to:
            - JSON Schema: minItems, maxItems,
              minProperties, maxProperties
            - OWL: owl:minCardinality,
              owl:maxCardinality
            - XSD: minOccurs, maxOccurs
        end note

        class UniquenessConstraint {
            +isUnique(): Boolean
            +getUniqueKeys(): String[]
        }

        class FormatConstraint {
            +getFormat(): String
            +getFormatURI(): URI
        }

        note right of FormatConstraint
            Standard formats:
            - date-time, date, time, duration
            - email, hostname, uri, uuid
            - ipv4, ipv6
            - json-pointer, regex
        end note

        class CustomConstraint {
            +getConstraintName(): String
            +getParameters(): Map<String, Any>
            +getValidatorURI(): URI
        }

        ' ====================================================================
        ' CANONICAL STRUCTURE
        ' ====================================================================

        class CanonicalStructure {
            +getProperties(): Map<String, CanonicalProperty>
            +getRequiredProperties(): String[]
            +getAllowAdditionalProperties(): Boolean
            +getAdditionalPropertiesSchema(): SchemaDefinition
            +getItemSchema(): SchemaDefinition
            +getPrefixItemSchemas(): SchemaDefinition[]
        }

        class CanonicalProperty {
            +getName(): String
            +getSchema(): SchemaDefinition
            +isRequired(): Boolean
            +isReadOnly(): Boolean
            +isWriteOnly(): Boolean
            +getDefaultValue(): Any
        }

    }

    ' ========================================================================
    ' VALIDATION
    ' ========================================================================

    package "Validation" <<validation>> {

        class ValidationResult {
            +isValid(): Boolean
            +getErrors(): ValidationError[]
            +getWarnings(): ValidationWarning[]
            +getAnnotations(): Map<String, Any>
            +getEvaluationPath(): String
        }

        class ValidationError {
            +getInstancePath(): String
            +getSchemaPath(): String
            +getKeyword(): String
            +getMessage(): String
            +getDetails(): Map<String, Any>
        }

        class ValidationWarning {
            +getInstancePath(): String
            +getMessage(): String
            +getSeverity(): WarningSeverity
        }

        enum WarningSeverity <<enum>> {
            INFO
            DEPRECATED
            PERFORMANCE
            COMPATIBILITY
        }

    }

    ' ========================================================================
    ' SCHEMA IMPLEMENTATIONS
    ' ========================================================================

    package "Schema Implementations" <<implementation>> {

        ' ====================================================================
        ' JSON SCHEMA
        ' ====================================================================

        class JSONSchemaDefinition {
            +getSchemaValue(): JSONSchema::SchemaValue
            +getDialect(): JSONSchema::Dialect
            +get$id(): URI
            +get$schema(): URI
        }

        note bottom of JSONSchemaDefinition
            **JSON Schema (Draft 2020-12)**
            
            External model reference:
            concept/model/json-schema/
            itip-json-schema-v1.puml
            
            Namespace: JSONSchema::
        end note

        ' ====================================================================
        ' RDF + OWL
        ' ====================================================================

        class RDFOWLSchemaDefinition {
            +getOntologyIRI(): IRI
            +getClassIRI(): IRI
            +getPropertyRestrictions(): OWLRestriction[]
            +getInferenceLevel(): InferenceLevel
        }

        enum InferenceLevel <<enum>> {
            NONE
            RDFS
            OWL_LITE
            OWL_DL
            OWL_FULL
        }

        note bottom of RDFOWLSchemaDefinition
            **RDF + OWL Schema**
            
            Uses OWL class definitions and
            property restrictions for validation.
            
            Future: concept/model/rdf-owl/
            itip-rdf-owl-v1.puml
        end note

        ' ====================================================================
        ' SHACL
        ' ====================================================================

        class SHACLSchemaDefinition {
            +getShapesGraphIRI(): IRI
            +getTargetClass(): IRI
            +getNodeShape(): SHACLNodeShape
            +getPropertyShapes(): SHACLPropertyShape[]
        }

        note bottom of SHACLSchemaDefinition
            **SHACL (Shapes Constraint Language)**
            
            W3C standard for RDF validation.
            Complements OWL with concrete
            validation constraints.
            
            Future: concept/model/shacl/
            itip-shacl-v1.puml
        end note

        ' ====================================================================
        ' XML SCHEMA
        ' ====================================================================

        class XMLSchemaDefinition {
            +getTargetNamespace(): URI
            +getTypeName(): QName
            +getElementDeclaration(): XSDElement
            +getTypeDefinition(): XSDTypeDefinition
        }

        note bottom of XMLSchemaDefinition
            **XML Schema (XSD 1.1)**
            
            W3C XML Schema Definition.
            
            Future: concept/model/xml-schema/
            itip-xsd-v1.puml
        end note

        ' ====================================================================
        ' AVRO
        ' ====================================================================

        class AvroSchemaDefinition {
            +getAvroSchema(): AvroSchema
            +getNamespace(): String
            +getRecordName(): String
            +getFingerprint(): Long
        }

        note bottom of AvroSchemaDefinition
            **Apache Avro Schema**
            
            Efficient binary serialization
            with schema evolution support.
            
            Future: concept/model/avro/
            itip-avro-v1.puml
        end note

        ' ====================================================================
        ' PROTOBUF
        ' ====================================================================

        class ProtobufSchemaDefinition {
            +getProtoFile(): String
            +getMessageType(): String
            +getPackage(): String
            +getSyntaxVersion(): ProtobufSyntax
        }

        enum ProtobufSyntax <<enum>> {
            PROTO2
            PROTO3
        }

        note bottom of ProtobufSchemaDefinition
            **Protocol Buffers**
            
            Google's language-neutral
            serialization format.
            
            Future: concept/model/protobuf/
            itip-protobuf-v1.puml
        end note

    }

    ' ========================================================================
    ' SCHEMA REGISTRY (OPTIONAL)
    ' ========================================================================

    package "Schema Registry" {

        class SchemaRegistry {
            +register(schema: SchemaDefinition): URI
            +resolve(fqdn: URI): SchemaDefinition
            +listSchemas(): SchemaDefinition[]
            +findByType(type: SchemaType): SchemaDefinition[]
            +getCompatibleVersions(uri: URI): SchemaDefinition[]
            +registerResolver(scheme: String, resolver: SchemaResolver): void
        }

        note right of SchemaRegistry
            **Universal schema resolution** via FQDN URI.
            
            **Resolution Process:**
            1. Parse scheme from fqdn (e.g., "jsonschema:")
            2. Delegate to registered SchemaResolver
            3. Return resolved SchemaDefinition
            
            **Registered Resolvers:**
            | Scheme       | Resolver               |
            |--------------|------------------------|
            | jsonschema:  | JSONSchemaResolver     |
            | rdf:         | RDFResolver            |
            | owl:         | OWLResolver            |
            | shacl:       | SHACLResolver          |
            | xsd:         | XSDResolver            |
            | avro:        | AvroResolver           |
            | protobuf:    | ProtobufResolver       |
            
            **External integrations:**
            - Confluent Schema Registry
            - AWS Glue Schema Registry
            - Azure Schema Registry
        end note

        abstract class SchemaResolver <<interface>> {
            +getScheme(): String
            +resolve(schemaSpecificPart: String): SchemaDefinition
            +canResolve(fqdn: URI): Boolean
        }

        note bottom of SchemaResolver
            **SchemaResolver** handles resolution
            for a specific schema technology.
            
            **Examples:**
            
            **JSONSchemaResolver:**
            fqdn: `jsonschema:https://example.com/schemas/customer.json#/properties/name`
            → Fetches JSON Schema, navigates via JSON Pointer
            
            **OWLResolver:**
            fqdn: `owl:http://example.org/ontology#Customer`
            → Resolves OWL class IRI from ontology
            
            **AvroResolver:**
            fqdn: `avro:com.example.Customer`
            → Looks up Avro schema by fully qualified name
        end note

        class JSONSchemaResolver {
            +resolve(schemaSpecificPart: String): JSONSchemaDefinition
        }

        class RDFOWLResolver {
            +resolve(schemaSpecificPart: String): RDFOWLSchemaDefinition
        }

        class AvroResolver {
            +resolve(schemaSpecificPart: String): AvroSchemaDefinition
        }

        class SchemaCompatibility {
            +checkCompatibility(old: SchemaDefinition, new: SchemaDefinition): CompatibilityResult
            +getCompatibilityMode(): CompatibilityMode
        }

        enum CompatibilityMode <<enum>> {
            NONE
            BACKWARD
            FORWARD
            FULL
            BACKWARD_TRANSITIVE
            FORWARD_TRANSITIVE
            FULL_TRANSITIVE
        }

        class CompatibilityResult {
            +isCompatible(): Boolean
            +getBreakingChanges(): BreakingChange[]
        }

        class BreakingChange {
            +getChangeType(): ChangeType
            +getPath(): String
            +getDescription(): String
        }

        enum ChangeType <<enum>> {
            FIELD_REMOVED
            FIELD_TYPE_CHANGED
            FIELD_MADE_REQUIRED
            ENUM_VALUE_REMOVED
            DEFAULT_REMOVED
        }

    }

    ' ========================================================================
    ' RELATIONSHIPS
    ' ========================================================================

    ' Value Adapter relationships
    ValueAdapter <|-- JSONValueAdapter : implements
    ValueAdapter <|-- RDFValueAdapter : implements
    ValueAdapter <|-- XMLValueAdapter : implements
    ValueAdapter <|-- AvroValueAdapter : implements
    ValueAdapter "1" --> "1" SchemaType : forSchemaType

    ' Core abstraction relationships
    SchemaDefinition "1" --> "1" SchemaType : hasType
    SchemaDefinition "1" --> "1" ValueAdapter : hasValueAdapter
    SchemaDefinition "1" --> "0..1" SchemaMetadata : hasMetadata
    SchemaDefinition "1" ..> "1" CanonicalSchemaRepresentation : toCanonicalForm
    SchemaDefinition "1" ..> "*" ValidationResult : produces

    ' Canonical representation structure
    CanonicalSchemaRepresentation "1" --> "1" CanonicalDataType : hasDataType
    CanonicalSchemaRepresentation "1" *--> "0..*" CanonicalConstraint : hasConstraints
    CanonicalSchemaRepresentation "1" *--> "0..1" CanonicalStructure : hasStructure
    CanonicalSchemaRepresentation "1" --> "0..1" SchemaMetadata : hasMetadata

    ' Canonical constraints hierarchy
    CanonicalConstraint <|-- RangeConstraint : is
    CanonicalConstraint <|-- LengthConstraint : is
    CanonicalConstraint <|-- PatternConstraint : is
    CanonicalConstraint <|-- EnumerationConstraint : is
    CanonicalConstraint <|-- CardinalityConstraint : is
    CanonicalConstraint <|-- UniquenessConstraint : is
    CanonicalConstraint <|-- FormatConstraint : is
    CanonicalConstraint <|-- CustomConstraint : is
    CanonicalConstraint "1" --> "1" ConstraintType : hasType
    PatternConstraint "1" --> "1" PatternSyntax : usesSyntax

    ' Canonical structure relationships
    CanonicalStructure "1" *--> "0..*" CanonicalProperty : hasProperties
    CanonicalStructure "1" o--> "0..1" SchemaDefinition : additionalPropertiesSchema
    CanonicalStructure "1" o--> "0..1" SchemaDefinition : itemSchema
    CanonicalStructure "1" o--> "0..*" SchemaDefinition : prefixItemSchemas
    CanonicalProperty "1" o--> "1" SchemaDefinition : hasSchema

    ' Validation relationships
    ValidationResult "1" *--> "0..*" ValidationError : hasErrors
    ValidationResult "1" *--> "0..*" ValidationWarning : hasWarnings
    ValidationWarning "1" --> "1" WarningSeverity : hasSeverity

    ' Implementation hierarchy
    SchemaDefinition <|-- JSONSchemaDefinition : implements
    SchemaDefinition <|-- RDFOWLSchemaDefinition : implements
    SchemaDefinition <|-- SHACLSchemaDefinition : implements
    SchemaDefinition <|-- XMLSchemaDefinition : implements
    SchemaDefinition <|-- AvroSchemaDefinition : implements
    SchemaDefinition <|-- ProtobufSchemaDefinition : implements

    ' Implementation to adapter bindings
    JSONSchemaDefinition "1" --> "1" JSONValueAdapter : uses
    RDFOWLSchemaDefinition "1" --> "1" RDFValueAdapter : uses
    SHACLSchemaDefinition "1" --> "1" RDFValueAdapter : uses
    XMLSchemaDefinition "1" --> "1" XMLValueAdapter : uses
    AvroSchemaDefinition "1" --> "1" AvroValueAdapter : uses

    ' Implementation-specific relationships
    RDFOWLSchemaDefinition "1" --> "1" InferenceLevel : usesInference
    ProtobufSchemaDefinition "1" --> "1" ProtobufSyntax : usesSyntax

    ' External model references (JSON Schema)
    JSONSchemaDefinition "1" o--> "1" JSONSchema::SchemaValue : wraps
    JSONValueAdapter "1" ..> "*" JSONSchema::JSONValue : produces

    ' Schema Registry relationships
    SchemaRegistry "1" o--> "0..*" SchemaDefinition : manages
    SchemaRegistry "1" *--> "1..*" SchemaResolver : hasResolvers
    SchemaRegistry "1" ..> "*" SchemaCompatibility : uses

    ' Schema Resolver hierarchy
    SchemaResolver <|-- JSONSchemaResolver : implements
    SchemaResolver <|-- RDFOWLResolver : implements
    SchemaResolver <|-- AvroResolver : implements
    JSONSchemaResolver "1" ..> "*" JSONSchemaDefinition : resolves
    RDFOWLResolver "1" ..> "*" RDFOWLSchemaDefinition : resolves
    AvroResolver "1" ..> "*" AvroSchemaDefinition : resolves

    SchemaCompatibility "1" --> "1" CompatibilityMode : usesMode
    SchemaCompatibility "1" ..> "*" CompatibilityResult : produces
    CompatibilityResult "1" *--> "0..*" BreakingChange : contains
    BreakingChange "1" --> "1" ChangeType : hasType

}

legend right
    |= Layer |= Purpose |
    | <#FFFFF0> Abstraction | Core interface (SchemaDefinition) |
    | <#FFE6F0> Adapter | Value conversion (ValueAdapter) |
    | <#F0FFF0> Canonical | Cross-schema interoperability |
    | <#FFF0F0> Validation | Unified validation results |
    | <#F0F0FF> Implementation | Concrete schema adapters |
    |= Design Pattern |= Application |
    | Dependency Inversion | Consumers → Abstraction ← Implementations |
    | Strategy | Swap schema implementations |
    | Adapter | Convert values to schema-specific formats |
endlegend

@enduml
