@startuml sie-emergence-sequence-v1

' ============================================================
' VISUAL THEME
' ============================================================

skinparam shadowing false
skinparam roundcorner 12
skinparam ArrowColor #57606A
skinparam DefaultFontName "SansSerif"
skinparam backgroundColor #FFFFFF

skinparam sequence {
  ParticipantBackgroundColor #FFFFFF
  ParticipantBorderColor #57606A
  LifeLineBackgroundColor #F6F8FA
  LifeLineBorderColor #57606A
  ArrowColor #57606A
  DividerBackgroundColor #F6F8FA
}

skinparam noteBackgroundColor #FFF8C5
skinparam noteBorderColor #57606A

title SIE - Emergence Process Sequence - v1

' ============================================================
' PARTICIPANTS
' ============================================================

participant "User/External\nSystem" as User
participant "Event Bus\n(Kafka)" as Kafka
participant "Emergence\nProcess Engine" as EmergenceEngine
participant "LLM\nOrchestrator" as LLM
participant "Graph DB\n(Neo4j)" as Neo4j
participant "Main DB\n(PostgreSQL)" as Postgres
participant "Coherence\nChecker" as Coherence
participant "Approval\nService" as Approval

' ============================================================
' TRIGGER PHASE
' ============================================================

== Trigger Phase ==

alt Observation Received (e.g., Risk Analysis Document)
  User -> Kafka : publish(ObservationReceivedEvent)
  note right
    Observation payload:
    - sourceUri: "confluence://risk-123"
    - observationType: RISK_ANALYSIS
    - metadata: { ... }
  end note
else User Request
  User -> Kafka : publish(EmergenceRequestEvent)
else Coherence Feedback
  Coherence -> Kafka : publish(ResolutionRequiresEmergenceEvent)
else Scheduled Analysis
  Kafka -> Kafka : scheduled trigger
end

Kafka -> EmergenceEngine : consume(trigger)

' ============================================================
' ANALYSIS PHASE
' ============================================================

== Analysis Phase ==

EmergenceEngine -> EmergenceEngine : createEmergenceProcess(INITIATED)
EmergenceEngine -> Postgres : save(EmergenceProcess)

EmergenceEngine -> EmergenceEngine : setStatus(ANALYZING)

alt Observation-based Trigger
  EmergenceEngine -> LLM : interpretObservation(sourceUri, observationType)
  activate LLM
  note right of LLM
    LLM fetches observation from URI,
    extracts intent, identifies
    affected concepts, suggests
    primitive types to create.
  end note
  LLM --> EmergenceEngine : ObservationInterpretation
  deactivate LLM
  
  EmergenceEngine -> Postgres : save(Observation)
end

EmergenceEngine -> Neo4j : queryRelatedPrimitives(scope)
Neo4j --> EmergenceEngine : existingPrimitives[]

EmergenceEngine -> EmergenceEngine : selectStrategy(triggerType, primitiveTypes)

' ============================================================
' PROPOSAL PHASE
' ============================================================

== Proposal Phase ==

EmergenceEngine -> EmergenceEngine : setStatus(PROPOSING)

EmergenceEngine -> LLM : synthesizePrimitives(observations, context, strategy)
activate LLM
note right of LLM
  LLM generates:
  - Proposed primitives (JSON)
  - Rationale for each
  - Confidence scores
  - Suggested relationships
end note
LLM --> EmergenceEngine : ProposedPrimitive[]
deactivate LLM

loop for each ProposedPrimitive
  EmergenceEngine -> Neo4j : assessImpact(proposedPrimitive)
  Neo4j --> EmergenceEngine : ImpactAssessment
  
  EmergenceEngine -> Postgres : save(ProposedPrimitive)
end

' ============================================================
' PRE-APPROVAL COHERENCE CHECK
' ============================================================

== Pre-Approval Coherence Check ==

EmergenceEngine -> Coherence : checkProposalCoherence(proposedPrimitives[])
activate Coherence

Coherence -> Neo4j : detectPotentialConflicts(proposals)
Neo4j --> Coherence : potentialConflicts[]

Coherence -> LLM : semanticCoherenceAnalysis(proposals, existing)
LLM --> Coherence : semanticIssues[]

Coherence --> EmergenceEngine : CoherenceReport
deactivate Coherence

alt Coherence Issues Found
  EmergenceEngine -> LLM : refineProposals(issues)
  LLM --> EmergenceEngine : refinedProposals[]
  EmergenceEngine -> Postgres : updateProposals()
end

' ============================================================
' APPROVAL PHASE
' ============================================================

== Approval Phase ==

EmergenceEngine -> EmergenceEngine : setStatus(AWAITING_APPROVAL)

EmergenceEngine -> Postgres : getConfiguration(scope)
Postgres --> EmergenceEngine : ProcessConfiguration

alt AutomationMode == FULLY_AUTONOMOUS and confidence > threshold
  EmergenceEngine -> EmergenceEngine : autoApprove()
  EmergenceEngine -> Postgres : setApprovalStatus(AUTO_APPROVED)
else AutomationMode == SEMI_AUTONOMOUS and low_risk
  EmergenceEngine -> EmergenceEngine : autoApprove()
else Requires Human Approval
  EmergenceEngine -> Approval : requestApproval(proposals, approvers)
  Approval -> User : notifyApprovalRequired()
  
  alt Approved
    User -> Approval : approve(proposals)
    Approval -> EmergenceEngine : approved()
  else Rejected
    User -> Approval : reject(proposals, reason)
    Approval -> EmergenceEngine : rejected(reason)
    EmergenceEngine -> EmergenceEngine : setStatus(FAILED)
    EmergenceEngine -> Postgres : save()
    return
  end
end

' ============================================================
' EXECUTION PHASE
' ============================================================

== Execution Phase ==

EmergenceEngine -> EmergenceEngine : setStatus(EXECUTING)

loop for each approved ProposedPrimitive
  EmergenceEngine -> Postgres : createPrimitive(primitive)
  Postgres --> EmergenceEngine : createdPrimitive
  
  EmergenceEngine -> Neo4j : indexPrimitive(createdPrimitive)
  
  alt Primitive is Policy or BehavioralRule
    EmergenceEngine -> Postgres : setStatus(DRAFT)
    note right
      Constraints start in DRAFT.
      Separate workflow to propose/approve/publish.
    end note
  end
  
  EmergenceEngine -> Kafka : publish(PrimitiveCreatedEvent)
end

' ============================================================
' COMPLETION PHASE
' ============================================================

== Completion Phase ==

EmergenceEngine -> EmergenceEngine : setStatus(COMPLETED)
EmergenceEngine -> Postgres : save(completedAt)

EmergenceEngine -> Kafka : publish(EmergenceCompletedEvent)

note right
  EmergenceCompletedEvent triggers:
  - UI notification to user
  - Downstream processes
  - Audit logging
end note

@enduml
