@startuml sie-explanation-engine-uc-v1

' ============================================================
' VISUAL THEME
' ============================================================

left to right direction
skinparam shadowing false
skinparam roundcorner 12
skinparam ArrowColor #57606A
skinparam DefaultFontName "SansSerif"
skinparam backgroundColor #FFFFFF

skinparam actorBackgroundColor #FFFFFF
skinparam actorBorderColor #57606A

skinparam usecaseBackgroundColor #F6F8FA
skinparam usecaseBorderColor #57606A

skinparam rectangleBackgroundColor #FFFFFF
skinparam rectangleBorderColor #57606A

skinparam noteBackgroundColor #FFF8C5
skinparam noteBorderColor #57606A

' ============================================================

title UC - SIE Explanation Engine - v1

' ============================================================
' ACTORS
' ============================================================

actor "Developer" as Developer
actor "Policy Author" as PolicyAuthor
actor "Auditor" as Auditor
actor "Support Engineer" as Support
actor "Security Analyst" as SecAnalyst

actor "CSDSL Engine" as CsdslEngine <<system>>
actor "LLM Service" as LLM <<system>>
actor "Decision Log" as DecisionLog <<system>>
actor "Trace Store" as TraceStore <<system>>

' ============================================================
' USE CASES
' ============================================================

rectangle "Explanation Engine" {

  ' --- Decision Explanation ---
  package "Decision Explanation" {
    usecase "Provide Human-Readable\nJustification" as UC_HumanReadable
    usecase "Link Decision to\nGoverning Policy" as UC_LinkToPolicy
    usecase "Identify Triggering\nConstraint" as UC_TriggeringConstraint
    usecase "Generate Stakeholder\nExplanation" as UC_StakeholderExplanation
  }

  ' --- Evaluation Trace ---
  package "Evaluation Trace" {
    usecase "Capture Step-by-Step\nEvaluation" as UC_StepByStep
    usecase "Record Intermediate\nValues" as UC_IntermediateValues
    usecase "Provide Debuggable\nLogs" as UC_DebuggableLogs
    usecase "Support Replay\nand Comparison" as UC_ReplayCompare
  }

  ' --- Causal Attribution ---
  package "Causal Attribution" {
    usecase "Identify Root\nCause Constraints" as UC_RootCause
    usecase "Distinguish Necessary vs\nSufficient Conditions" as UC_NecessarySufficient
    usecase "Rank Contributing\nFactors" as UC_RankFactors
    usecase "Build Causal\nChains" as UC_CausalChains
  }

  ' --- Counterfactual Reasoning ---
  package "Counterfactual Reasoning" {
    usecase "Explain What Would\nChange Decision" as UC_WhatWouldChange
    usecase "Identify Minimal\nChange for Outcome" as UC_MinimalChange
    usecase "Simulate Alternative\nScenarios" as UC_SimulateAlternatives
    usecase "Preview Policy\nImpact" as UC_PreviewImpact
  }
}

' ============================================================
' RELATIONSHIPS - Actors to Use Cases
' ============================================================

' Developer interactions
Developer --> UC_TriggeringConstraint
Developer --> UC_StepByStep
Developer --> UC_DebuggableLogs
Developer --> UC_WhatWouldChange
Developer --> UC_MinimalChange

' Policy Author interactions
PolicyAuthor --> UC_LinkToPolicy
PolicyAuthor --> UC_SimulateAlternatives
PolicyAuthor --> UC_PreviewImpact
PolicyAuthor --> UC_RankFactors

' Auditor interactions
Auditor --> UC_HumanReadable
Auditor --> UC_IntermediateValues
Auditor --> UC_ReplayCompare
Auditor --> UC_CausalChains

' Support Engineer interactions
Support --> UC_StakeholderExplanation
Support --> UC_RootCause
Support --> UC_NecessarySufficient

' Security Analyst interactions
SecAnalyst --> UC_TriggeringConstraint
SecAnalyst --> UC_RootCause
SecAnalyst --> UC_CausalChains
SecAnalyst --> UC_ReplayCompare

' ============================================================
' RELATIONSHIPS - System Actors
' ============================================================

UC_HumanReadable --> LLM
UC_LinkToPolicy --> DecisionLog
UC_TriggeringConstraint --> DecisionLog
UC_StakeholderExplanation --> LLM

UC_StepByStep --> TraceStore
UC_IntermediateValues --> TraceStore
UC_DebuggableLogs --> TraceStore
UC_ReplayCompare --> TraceStore

UC_RootCause --> TraceStore
UC_NecessarySufficient --> CsdslEngine
UC_RankFactors --> CsdslEngine
UC_CausalChains --> TraceStore

UC_WhatWouldChange --> CsdslEngine
UC_MinimalChange --> CsdslEngine
UC_SimulateAlternatives --> CsdslEngine
UC_PreviewImpact --> CsdslEngine

' ============================================================
' RELATIONSHIPS - Include/Extend
' ============================================================

UC_HumanReadable ..> UC_LinkToPolicy : <<include>>
UC_StepByStep ..> UC_IntermediateValues : <<include>>
UC_RootCause ..> UC_CausalChains : <<include>>
UC_WhatWouldChange ..> UC_SimulateAlternatives : <<include>>
UC_RankFactors ..> UC_NecessarySufficient : <<include>>

' ============================================================
' NOTES
' ============================================================

note right of UC_HumanReadable
  **Decision Explanation Example:**
  
  Decision: DENIED
  Reason: "Deployment blocked because
  the service lacks required health
  check endpoints (liveness, readiness)
  as mandated by Platform Policy P-2431"
end note

note right of UC_StepByStep
  **Evaluation Trace:**
  
  1. Load context: service=order-api
  2. Evaluate: hasHealthChecks → false
  3. Evaluate: isTier1 → true
  4. Rule: tier1 requires health checks
  5. Result: VIOLATION
end note

note right of UC_WhatWouldChange
  **Counterfactual Query:**
  
  Q: "What would make this deploy pass?"
  
  A: Add these endpoints:
  - /health/live
  - /health/ready
  
  Or: Request exception via JIRA-12345
end note

note right of UC_RootCause
  **Causal Attribution:**
  
  Immediate cause: Missing health check
  Policy cause: Platform Policy P-2431
  Business cause: SLA requirement 99.9%
  
  Root: Reliability mandate from CTO
end note

@enduml
