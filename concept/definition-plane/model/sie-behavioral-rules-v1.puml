@startuml sie-behavioral-rules-v1

' ============================================================
' VISUAL THEME
' ============================================================

skinparam shadowing false
skinparam linetype ortho
skinparam groupInheritance 2

skinparam classFontSize 11
skinparam classAttributeFontSize 10
skinparam classFontStyle bold
skinparam classAttributeFontStyle plain

skinparam ArrowColor #57606A
skinparam ArrowThickness 1
skinparam ArrowFontSize 9

skinparam ClassBackgroundColor #F6F8FA
skinparam ClassBorderColor #57606A
skinparam ClassBorderThickness 1

skinparam NoteBackgroundColor #FFF8C5
skinparam NoteBorderColor #57606A
skinparam NoteFontSize 10

skinparam PackageBorderColor #57606A
skinparam PackageBackgroundColor #FFFFFF
skinparam PackageFontStyle bold

skinparam stereotypeABorderColor #57606A
skinparam stereotypeCBorderColor #57606A

frame "CD - SIE Behavioral Rules Model - v1" as BehavioralRulesModel {

  ' ============================================================
  ' BEHAVIORAL RULE
  ' ============================================================
  
  package "Behavioral Rule" as BRPkg {
    
    class BehavioralRule <<entity>> {
      + id : RuleId
      + name : string
      + description : string
      + priority : Priority
      + enabled : boolean
      --
      + trigger : Trigger
      + conditions : Condition[]
      + actions : Action[]
      + cooldown : Duration?
      + maxExecutions : int?
    }
    
    class Trigger <<value>> {
      + type : TriggerType
      + source : string
      + filter : CsdslExpression?
    }
    
    enum TriggerType {
      VIOLATION
      STATE_CHANGE
      SCHEDULE
      MANUAL
      THRESHOLD
    }
    
    class Condition <<value>> {
      + expression : CsdslExpression
      + description : string
    }
    
    BehavioralRule *-- "1" Trigger
    BehavioralRule *-- "*" Condition
    Trigger --> TriggerType
  }
  
  ' ============================================================
  ' ACTIONS
  ' ============================================================
  
  package "Actions" as ActionsPkg {
    
    abstract class Action <<entity>> {
      + id : ActionId
      + name : string
      + description : string
      + timeout : Duration
      + retryPolicy : RetryPolicy?
    }
    
    class RemediationAction <<entity>> {
      + playbook : PlaybookRef
      + parameters : Map<string, any>
      + rollbackAction : ActionRef?
    }
    
    class NotificationAction <<entity>> {
      + channel : NotificationChannel
      + recipients : Recipient[]
      + template : TemplateRef
      + severity : Severity
    }
    
    class EscalationAction <<entity>> {
      + escalationPath : EscalationPath
      + slaDeadline : Duration
      + autoEscalate : boolean
    }
    
    class ApprovalAction <<entity>> {
      + approvers : Approver[]
      + requiredApprovals : int
      + timeout : Duration
      + defaultAction : ActionRef?
    }
    
    Action <|-- RemediationAction
    Action <|-- NotificationAction
    Action <|-- EscalationAction
    Action <|-- ApprovalAction
    
    BehavioralRule *-- "*" Action
  }
  
  ' ============================================================
  ' PLAYBOOKS
  ' ============================================================
  
  package "Playbooks" as PlaybookPkg {
    
    class Playbook <<entity>> {
      + id : PlaybookId
      + name : string
      + description : string
      + version : Version
      --
      + steps : PlaybookStep[]
      + rollbackSteps : PlaybookStep[]
      + preconditions : Condition[]
      + riskLevel : RiskLevel
    }
    
    class PlaybookStep <<entity>> {
      + order : int
      + name : string
      + type : StepType
      + target : TargetSelector
      + parameters : Map<string, any>
      + continueOnFailure : boolean
    }
    
    enum StepType {
      COMMAND
      API_CALL
      SCRIPT
      WAIT
      APPROVAL_GATE
      ROLLBACK_CHECKPOINT
    }
    
    enum RiskLevel {
      LOW
      MEDIUM
      HIGH
      CRITICAL
    }
    
    Playbook *-- "*" PlaybookStep
    PlaybookStep --> StepType
    Playbook --> RiskLevel
    RemediationAction --> Playbook : playbook
  }
  
  ' ============================================================
  ' EXECUTION TRACKING
  ' ============================================================
  
  package "Execution Tracking" as ExecutionPkg {
    
    class RuleExecution <<entity>> {
      + id : ExecutionId
      + ruleId : RuleId
      + triggeredAt : Timestamp
      + triggeredBy : TriggerContext
      --
      + status : ExecutionStatus
      + startedAt : Timestamp?
      + completedAt : Timestamp?
      + actions : ActionExecution[]
    }
    
    class ActionExecution <<entity>> {
      + actionId : ActionId
      + status : ExecutionStatus
      + startedAt : Timestamp
      + completedAt : Timestamp?
      + result : ActionResult?
      + error : Error?
    }
    
    enum ExecutionStatus {
      PENDING
      RUNNING
      WAITING_APPROVAL
      SUCCEEDED
      FAILED
      ROLLED_BACK
      CANCELLED
    }
    
    class ActionResult <<value>> {
      + success : boolean
      + output : any?
      + changesApplied : Change[]
      + rollbackInfo : RollbackInfo?
    }
    
    RuleExecution *-- "*" ActionExecution
    ActionExecution --> ExecutionStatus
    ActionExecution --> ActionResult
    
    BehavioralRule "1" -- "*" RuleExecution : executions
  }
  
  ' ============================================================
  ' ESCALATION PATH
  ' ============================================================
  
  package "Escalation" as EscalationPkg {
    
    class EscalationPath <<entity>> {
      + id : PathId
      + name : string
      + levels : EscalationLevel[]
    }
    
    class EscalationLevel <<value>> {
      + order : int
      + responders : Responder[]
      + escalateAfter : Duration
      + notificationChannel : NotificationChannel
    }
    
    class Responder <<value>> {
      + type : ResponderType
      + reference : string
    }
    
    enum ResponderType {
      USER
      GROUP
      ROLE
      ON_CALL_SCHEDULE
    }
    
    EscalationPath *-- "*" EscalationLevel
    EscalationLevel *-- "*" Responder
    Responder --> ResponderType
    EscalationAction --> EscalationPath
  }
}

note as ModelNote
  **Behavioral Rules Model**
  
  Part of the **Remediation Plane**
  
  Defines:
  • Rules (trigger → conditions → actions)
  • Playbooks (remediation recipes)
  • Execution tracking (audit)
  • Escalation paths
  
  Rules are owned by **Definition Plane**
  and executed by **Remediation Plane**
end note

@enduml
